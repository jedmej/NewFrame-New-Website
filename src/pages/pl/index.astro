---
import Page from '../../layouts/Page.astro';
import { useTranslations } from '../../i18n/translations';
import Hero from '../../components/sections/Hero.astro';
import About from '../../components/sections/About.astro';
import ProcessAlternative from '../../components/sections/ProcessAlternative.astro';
import WorkSelectedMinimal from '../../components/sections/WorkSelectedMinimal.astro';
import WaysToWorkProductGrid from '../../components/sections/WaysToWorkProductGrid.astro';
import Testimonials from '../../components/sections/Testimonials.astro';

const t = useTranslations('pl');
---

<Page lang="pl" title={t.seo.title} description={t.seo.description}>
  <Hero lang="pl" />
  <About lang="pl" />
  <WorkSelectedMinimal lang="pl" />
  <WaysToWorkProductGrid lang="pl" />
  <ProcessAlternative lang="pl" />
  <Testimonials lang="pl" />
</Page>
