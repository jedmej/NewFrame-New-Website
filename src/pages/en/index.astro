---
import Page from '../../layouts/Page.astro';
import { useTranslations } from '../../i18n/translations';
import Hero from '../../components/sections/Hero.astro';
import About from '../../components/sections/About.astro';
import ProcessAlternative from '../../components/sections/ProcessAlternative.astro';
import WorkSelectedMinimal from '../../components/sections/WorkSelectedMinimal.astro';
import WaysToWorkProductGrid from '../../components/sections/WaysToWorkProductGrid.astro';
import Testimonials from '../../components/sections/Testimonials.astro';

const t = useTranslations('en');
---

<Page lang="en" title={t.seo.title} description={t.seo.description}>
  <Hero lang="en" />
  <About lang="en" />
  <WorkSelectedMinimal lang="en" />
  <WaysToWorkProductGrid lang="en" />
  <ProcessAlternative lang="en" />
  <Testimonials lang="en" />
</Page>
