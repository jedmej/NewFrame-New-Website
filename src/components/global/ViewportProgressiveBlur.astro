<div class="viewport-progressive-blur" data-viewport-progressive-blur aria-hidden="true">
  <div class="viewport-progressive-blur__layer viewport-progressive-blur__layer--soft"></div>
  <div class="viewport-progressive-blur__layer viewport-progressive-blur__layer--medium"></div>
  <div class="viewport-progressive-blur__layer viewport-progressive-blur__layer--strong"></div>
  <div class="viewport-progressive-blur__layer viewport-progressive-blur__layer--deep"></div>
</div>

<style>
  .viewport-progressive-blur {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 120;
    height: clamp(4.8rem, 10.4vh, 7.2rem);
    overflow: hidden;
    pointer-events: none;
    contain: strict;
  }

  .viewport-progressive-blur__layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: rgba(20, 18, 15, 0.01);
  }

  .viewport-progressive-blur__layer--soft {
    -webkit-backdrop-filter: blur(1px);
    backdrop-filter: blur(1px);
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 25%);
    mask-image: linear-gradient(180deg, transparent 0%, #000 25%);
  }

  .viewport-progressive-blur__layer--medium {
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    -webkit-mask-image: linear-gradient(180deg, transparent 24%, #000 52%);
    mask-image: linear-gradient(180deg, transparent 24%, #000 52%);
  }

  .viewport-progressive-blur__layer--strong {
    -webkit-backdrop-filter: blur(7px);
    backdrop-filter: blur(7px);
    -webkit-mask-image: linear-gradient(180deg, transparent 48%, #000 78%);
    mask-image: linear-gradient(180deg, transparent 48%, #000 78%);
  }

  .viewport-progressive-blur__layer--deep {
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    -webkit-mask-image: linear-gradient(180deg, transparent 72%, #000 100%);
    mask-image: linear-gradient(180deg, transparent 72%, #000 100%);
  }

  @media (max-width: 767px) {
    .viewport-progressive-blur {
      height: 5.2rem;
    }
  }

  @media (max-width: 1279px), (hover: none), (pointer: coarse) {
    .viewport-progressive-blur {
      display: none;
    }
  }

  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .viewport-progressive-blur {
      display: none;
    }
  }
</style>

<script>
  let cleanupFn: (() => void) | null = null;

  function init() {
    cleanupFn?.();
    cleanupFn = null;

    const blur = document.querySelector<HTMLElement>('[data-viewport-progressive-blur]');
    if (!blur) return;

    const ac = new AbortController();

    // Slide the blur band below the viewport over the final stretch of
    // scroll so the footer reads sharp at the very bottom of the page.
    // Transform (not opacity) on purpose: Chromium drops backdrop-filter
    // snapshots when an ancestor hits opacity 0 and does not reliably
    // restore them when it becomes visible again.
    const fadeDistance = 320;
    let lastShift = -1;

    const update = () => {
      const doc = document.scrollingElement ?? document.documentElement;
      const maxScroll = doc.scrollHeight - window.innerHeight;
      const remaining = maxScroll - window.scrollY;
      const progress = Math.max(0, Math.min(1, remaining / fadeDistance));
      const shift = Math.round((1 - progress) * 1000) / 10;
      if (shift === lastShift) return;
      lastShift = shift;
      blur.style.transform = `translate3d(0, ${shift}%, 0)`;
    };

    update();
    window.addEventListener('scroll', update, { signal: ac.signal, passive: true });
    window.addEventListener('resize', update, { signal: ac.signal });

    cleanupFn = () => {
      ac.abort();
      blur.style.transform = '';
    };
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
