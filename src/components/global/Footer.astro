---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const email = 'hello@newframe.studio';
const footerMeta = [
  'NEWFRAME ©26',
  'DESIGN STUDIO',
  'WARSAW BASED',
];

const emailSubject = lang === 'pl' ? 'Zapytanie o projekt, New Frame Studio' : 'Project inquiry, New Frame Studio';

const footerLinks = [
  { label: lang === 'pl' ? 'Start' : 'Home', href: `/${lang}/` },
  { label: t.nav.work, href: `/${lang}/#work` },
  { label: t.nav.scope, href: `/${lang}/#scope` },
  { label: t.nav.services, href: `/${lang}/#ways-to-work` },
  { label: t.nav.process, href: `/${lang}/#services` },
  { label: t.nav.contact, href: `/${lang}/#contact` },
  { label: t.footer.privacy, href: `/${lang}/privacy/` },
];
---

<footer id="contact" class="relative z-50 overflow-hidden footer-shell">
  <div id="footer-wipe-in" class="absolute top-0 left-0 right-0 h-screen z-30 pointer-events-none"
       style="background-color: var(--color-bg);"></div>

  <div class="footer-surface">
    <canvas id="footer-shader-canvas" class="footer-shader" aria-hidden="true"></canvas>
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-cta-cell">
          <h2 id="footer-cta" class="footer-cta">{t.footer.cta}</h2>
          <p class="footer-contact-prompt">{t.contact.prompt}</p>
        </div>

        <div class="footer-contact-stack footer-email-cell">
          <a
            href={`mailto:${email}?subject=${encodeURIComponent(emailSubject)}`}
            class="footer-contact-link group"
            data-cursor="CLICK"
            aria-label={`Email ${email}`}
          >
            <span class="footer-cell-kicker">{t.footer.email}</span>
            <span class="footer-email footer-email-address">hello@<wbr />newframe.studio</span>
            <span class="footer-cell-arrow" aria-hidden="true">↗</span>
          </a>

          <div class="footer-meta-card" aria-label="Newframe studio meta">
            {footerMeta.map((item, index) => (
              <span class:list={['footer-meta-line', { 'footer-meta-line--brand': index === 0 }]}>
                {item}
              </span>
            ))}
          </div>
        </div>

        <nav class="footer-nav-cell" aria-label={t.footer.navigation}>
          <ul class="footer-link-grid">
            {footerLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link group">
                  <span class="footer-link-index" aria-hidden="true"></span>
                  <span class="scramble-target">{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="footer-mark-cell" aria-hidden="true">
          <span class="footer-mark-logo"></span>
        </div>
      </div>

      <div class="footer-bottom">
        <div class="footer-brand">
          <span class="footer-brand-mark" aria-hidden="true"></span>
          <span>NEW FRAME</span>
        </div>

        <p>&copy; {year} New Frame Studio · {t.footer.rights}</p>

        <button id="back-to-top" class="footer-top-button group">
          <span>{t.footer.backToTop}</span>
          <svg aria-hidden="true" class="transition-transform duration-500 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 10l7-7m0 0l7 7m-7-7v18" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-shell {
    color: var(--color-dark-text);
  }

  .footer-surface {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .footer-shader {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.72;
    pointer-events: none;
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: 100svh;
    align-content: center;
    gap: 1.5rem;
    width: min(100%, 1400px);
    margin: 0 auto;
    padding: clamp(4.5rem, 7svh, 6.5rem) 1.5rem clamp(2rem, 4svh, 3rem);
  }

  @media (min-width: 768px) {
    .footer-inner {
      padding-inline: 2.5rem;
    }
  }

  .footer-availability {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    color: rgba(243, 234, 223, 0.66);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .footer-status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 0.45rem rgba(201, 70, 57, 0.12);
  }

  .footer-grid {
    display: grid;
    border: 1px solid rgba(243, 234, 223, 0.12);
    background: rgba(17, 24, 32, 0.42);
    backdrop-filter: blur(10px) saturate(1.08);
    -webkit-backdrop-filter: blur(10px) saturate(1.08);
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
    }
  }

  .footer-cta-cell,
  .footer-email-cell,
  .footer-nav-cell,
  .footer-mark-cell {
    min-width: 0;
    border-bottom: 1px solid rgba(243, 234, 223, 0.12);
  }

  .footer-cta-cell {
    display: flex;
    min-height: clamp(28rem, 43vw, 40rem);
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 5vw, 5rem);
  }

  @media (min-width: 1024px) {
    .footer-cta-cell {
      grid-column: 1 / 8;
      grid-row: 1;
      border-right: 1px solid rgba(243, 234, 223, 0.12);
    }
  }

  .footer-cta {
    max-width: 10.5em;
    color: var(--color-dark-text);
    font-family: var(--font-serif);
    font-size: clamp(4rem, 8.2vw, 9.8rem);
    font-weight: 400;
    line-height: 0.86;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .footer-word {
    display: inline-block;
    white-space: nowrap;
    will-change: transform, opacity;
  }

  .footer-contact-prompt {
    max-width: 39rem;
    margin-top: clamp(1.5rem, 3vw, 2.75rem);
    font-family: var(--font-mono);
    font-size: clamp(1.08rem, 1.12vw, 1.28rem);
    line-height: 1.64;
    letter-spacing: 0.02em;
    color: rgba(243, 234, 223, 0.62);
    text-wrap: pretty;
  }

  .footer-contact-stack {
    position: relative;
    display: grid;
    min-height: clamp(22rem, 33vw, 34rem);
    grid-template-rows: repeat(2, minmax(0, 1fr));
    color: var(--color-dark-text);
  }

  @media (min-width: 1024px) {
    .footer-contact-stack {
      grid-column: 8 / 13;
      grid-row: 1;
    }
  }

  .footer-contact-link,
  .footer-meta-card {
    position: relative;
    display: grid;
    min-width: 0;
    align-content: end;
    gap: 1rem;
    border-bottom: 1px solid rgba(243, 234, 223, 0.12);
    padding: clamp(1.5rem, 3vw, 3rem);
    color: inherit;
  }

  .footer-contact-link {
    text-decoration: none;
    transition:
      background-color 0.45s var(--ease-out-expo),
      color 0.45s var(--ease-out-expo);
  }

  .footer-meta-card {
    border-bottom: 0;
  }

  .footer-meta-line {
    color: rgba(243, 234, 223, 0.62);
    font-family: var(--font-mono);
    font-size: clamp(0.8rem, 0.9vw, 1rem);
    line-height: 1.35;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-meta-line--brand {
    color: var(--color-dark-text);
  }

  .footer-contact-link:last-child {
    border-bottom: 0;
  }

  .footer-contact-link:hover,
  .footer-contact-link:focus-visible {
    background: rgba(243, 234, 223, 0.075);
    color: #fff;
  }

  .footer-cell-kicker {
    color: rgba(243, 234, 223, 0.36);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .footer-email {
    max-width: 100%;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 2.85vw, 3.4rem);
    font-style: italic;
    line-height: 0.95;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .footer-cell-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 1.35rem;
    line-height: 1;
    transition: transform 0.45s var(--ease-out-expo);
  }

  .footer-contact-link:hover .footer-cell-arrow,
  .footer-contact-link:focus-visible .footer-cell-arrow {
    transform: translate(0.25rem, -0.25rem);
  }

  .footer-nav-cell {
    padding: 0;
  }

  @media (min-width: 1024px) {
    .footer-nav-cell {
      grid-column: 1 / 12;
      grid-row: 2;
      border-right: 1px solid rgba(243, 234, 223, 0.12);
      border-bottom: 0;
    }
  }

  .footer-link-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    height: 100%;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (min-width: 768px) {
    .footer-link-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .footer-link-grid {
      grid-template-columns: repeat(7, minmax(8rem, 1fr));
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .footer-link-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .footer-link-grid li {
    display: flex;
    min-width: 0;
    border-right: 1px solid rgba(243, 234, 223, 0.12);
  }

  .footer-link-grid li:last-child {
    border-right: 0;
  }

  .footer-link-grid li:nth-child(n + 3) {
    border-top: 1px solid rgba(243, 234, 223, 0.12);
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .footer-link-grid li:nth-child(4n) {
      border-right: 0;
    }

    .footer-link-grid li:nth-child(n + 3) {
      border-top: 0;
    }

    .footer-link-grid li:nth-child(n + 5) {
      border-top: 1px solid rgba(243, 234, 223, 0.12);
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .footer-link-grid li:nth-child(4n) {
      border-right: 1px solid rgba(243, 234, 223, 0.12);
    }

    .footer-link-grid li:nth-child(n + 3) {
      border-top: 0;
    }

    .footer-link-grid li:nth-child(n + 5) {
      border-top: 1px solid rgba(243, 234, 223, 0.12);
    }

    .footer-link-grid li:last-child {
      border-right: 1px solid rgba(243, 234, 223, 0.12);
    }
  }

  @media (min-width: 1280px) {
    .footer-link-grid li:nth-child(n + 3) {
      border-top: 0;
    }
  }

  .footer-link {
    display: flex;
    flex: 1 1 auto;
    min-height: clamp(5.75rem, 7vw, 7.25rem);
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    color: rgba(243, 234, 223, 0.62);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 0.35s var(--ease-out-expo),
      color 0.3s var(--ease-out-expo);
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    background: rgba(243, 234, 223, 0.055);
    color: var(--color-dark-text);
  }

  .footer-link-index {
    width: 0.36rem;
    height: 0.36rem;
    flex: 0 0 auto;
    background: var(--color-accent);
    transform: rotate(45deg) scale(0.75);
    opacity: 0.7;
    transition:
      transform 0.35s var(--ease-out-expo),
      opacity 0.35s var(--ease-out-expo);
  }

  .footer-link:hover .footer-link-index,
  .footer-link:focus-visible .footer-link-index {
    opacity: 1;
    transform: rotate(45deg) scale(1);
  }

  .footer-mark-cell {
    display: grid;
    --footer-mark-size: clamp(3.5rem, 4vw, 4.5rem);
    min-height: calc(var(--footer-mark-size) + 24px);
    min-width: calc(var(--footer-mark-size) + 24px);
    place-items: center;
    padding: 12px;
    border-bottom: 0;
    color: rgba(243, 234, 223, 0.9);
  }

  @media (min-width: 1024px) {
    .footer-mark-cell {
      grid-column: 12 / 13;
      grid-row: 2;
      width: 100%;
      aspect-ratio: 1 / 1;
      min-height: 0;
      justify-self: end;
      align-self: stretch;
    }
  }

  .footer-mark-logo {
    display: block;
    width: var(--footer-mark-size);
    height: var(--footer-mark-size);
    background: currentColor;
    mask: url('/images/newframe-logo.svg') center / contain no-repeat;
    -webkit-mask: url('/images/newframe-logo.svg') center / contain no-repeat;
  }

  .footer-bottom {
    display: grid;
    gap: 1.25rem;
    align-items: center;
    padding-top: 1.5rem;
    color: rgba(243, 234, 223, 0.38);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    }
  }

  @media (max-width: 1023px) {
    .footer-bottom {
      display: flex;
      flex-direction: column;
      justify-content: center;
      justify-items: center;
      text-align: center;
      font-size: 0.72rem;
      line-height: 1.55;
      letter-spacing: 0.12em;
    }

    .footer-brand,
    .footer-top-button {
      justify-content: center;
    }

    .footer-top-button {
      justify-self: center;
    }
  }

  .footer-brand,
  .footer-top-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-brand-mark {
    width: 0.82rem;
    height: 0.82rem;
    border: 2px solid currentColor;
    box-shadow: 0.28rem 0.28rem 0 0 currentColor;
  }

  .footer-bottom p {
    margin: 0;
    text-align: center;
  }

  .footer-top-button {
    justify-self: start;
    border: 0;
    padding: 0;
    color: inherit;
    background: transparent;
    cursor: pointer;
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    transition: color 0.3s var(--ease-out-expo);
  }

  .footer-top-button:hover,
  .footer-top-button:focus-visible {
    color: rgba(243, 234, 223, 0.78);
  }

  .footer-top-button svg {
    width: 0.9rem;
    height: 0.9rem;
  }

  @media (min-width: 768px) {
    .footer-top-button {
      justify-self: end;
    }
  }

  @media (max-width: 767px) {
    .footer-inner {
      padding: 4.5rem 1rem 1.25rem;
    }

    .footer-availability {
      margin-bottom: 2rem;
      font-size: 0.64rem;
      letter-spacing: 0.14em;
    }

    .footer-cta-cell {
      min-height: 18.5rem;
      padding: 2rem 1.25rem;
    }

    .footer-cta {
      max-width: 8.75em;
      font-size: clamp(3rem, 16vw, 4.5rem);
      line-height: 0.9;
    }

    .footer-contact-prompt {
      margin-top: 1.25rem;
      font-size: 1.08rem;
      line-height: 1.62;
    }

    .footer-contact-stack {
      min-height: 0;
      grid-template-rows: none;
    }

    .footer-contact-link,
    .footer-meta-card {
      min-height: 9.5rem;
      gap: 0.75rem;
      padding: 1.25rem;
    }

    .footer-meta-line {
      font-size: clamp(0.72rem, 3.15vw, 0.88rem);
      line-height: 1.45;
      letter-spacing: 0.1em;
    }

    .footer-email {
      padding-right: 1.8rem;
      font-size: clamp(1.85rem, 10vw, 2.65rem);
      white-space: normal;
      overflow-wrap: anywhere;
    }

    .footer-email-address {
      font-size: clamp(1.55rem, 8.2vw, 2.05rem);
      overflow-wrap: normal;
      word-break: normal;
    }

    .footer-cell-arrow {
      top: 1.25rem;
      right: 1.25rem;
      font-size: 1.1rem;
    }

    .footer-link-grid li:nth-child(2n) {
      border-right: 0;
    }

    .footer-link-grid li:last-child {
      grid-column: 1 / -1;
      border-right: 0;
    }

    .footer-link {
      min-height: 4.85rem;
      padding: 0.85rem;
      font-size: 0.64rem;
      letter-spacing: 0.1em;
    }

    .footer-mark-cell {
      --footer-mark-size: 4.25rem;
      min-height: 9.5rem;
      padding: 1.25rem;
    }

    .footer-bottom {
      width: 100%;
      gap: 1.05rem;
      font-size: clamp(0.72rem, 2.55vw, 0.82rem);
      line-height: 1.5;
      letter-spacing: 0.085em;
    }

    .footer-brand,
    .footer-top-button,
    .footer-bottom p {
      width: 100%;
      text-align: center;
    }

    .footer-bottom p {
      text-wrap: balance;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { SplitText } from 'gsap/SplitText';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';
  import type { ShaderInstance } from 'shaders/js';

  gsap.registerPlugin(SplitText, ScrollTrigger, ScrambleTextPlugin);

  let cleanupFn: (() => void) | null = null;

  function initFooter() {
    cleanupFn?.();
    cleanupFn = null;

    const ac = new AbortController();
    const { signal } = ac;
    const scrollTriggers: ScrollTrigger[] = [];
    const timelines: gsap.core.Timeline[] = [];
    let splitInstance: any = null;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouchLayout = window.matchMedia('(max-width: 1023px)').matches;
    const shaderCanvas = document.getElementById('footer-shader-canvas') as HTMLCanvasElement | null;
    let shaderInstance: ShaderInstance | null = null;
    let shaderDisposed = false;
    let shaderResizeFrame = 0;
    let shaderResizeTimer: ReturnType<typeof setTimeout> | null = null;
    let shaderResizeObserver: ResizeObserver | null = null;

    const resizeShaderToCanvas = () => {
      if (!shaderCanvas || !shaderInstance || shaderDisposed) return;

      shaderCanvas.style.width = '';
      shaderCanvas.style.height = '';
      const rect = shaderCanvas.getBoundingClientRect();
      if (rect.width > 0 && rect.height > 0) {
        shaderInstance.resize(Math.round(rect.width), Math.round(rect.height));
      }
    };

    const scheduleShaderResize = () => {
      if (shaderResizeTimer) window.clearTimeout(shaderResizeTimer);
      shaderResizeTimer = window.setTimeout(() => {
        shaderResizeFrame = window.requestAnimationFrame(resizeShaderToCanvas);
      }, 120);
    };

    if (shaderCanvas && !prefersReducedMotion) {
      shaderCanvas.style.width = '';
      shaderCanvas.style.height = '';
      import('shaders/js').then(({ createShader }) => createShader(shaderCanvas, {
        components: [
          {
            type: 'SolidColor',
            id: 'idmmbht0k6sfod45zuq',
            props: {
              color: '#09060f00',
            },
          },
          {
            type: 'GridDistortion',
            id: 'idmmbj5gb3owu3efr8',
            props: {
              decay: 3.6,
              gridSize: 26,
              intensity: 1.25,
              radius: 1.1,
            },
            children: [
              {
                type: 'Pixelate',
                id: 'idmmbhss4cxdb5pyi6j',
                props: {
                  gap: {
                    type: 'map',
                    curve: 0.35,
                    source: 'idmmbhthud5inxgebqc',
                    channel: 'alphaInverted',
                    inputMax: 1,
                    inputMin: 0,
                    outputMax: 0.82,
                    outputMin: 0.1,
                  },
                  scale: 104,
                },
                children: [
                  {
                    type: 'Plasma',
                    id: 'idmmbhsq0prs1cmevaa',
                    props: {
                      balance: 57,
                      colorA: '#C54538',
                      contrast: 1.6,
                      density: 2,
                      intensity: 1.8,
                      speed: 2,
                    },
                  },
                ],
              },
            ],
          },
          {
            type: 'SineWave',
            id: 'idmmbhthud5inxgebqc',
            props: {
              amplitude: 0.1,
              position: {
                x: 0.5,
                y: 1,
              },
              softness: 0.8,
              thickness: 0.5,
              visible: false,
            },
          },
        ],
      })).then((shader) => {
        if (shaderDisposed) {
          shader.destroy();
          return;
        }

        shaderInstance = shader;
        resizeShaderToCanvas();
        window.addEventListener('resize', scheduleShaderResize, { signal });
        shaderResizeObserver = new ResizeObserver(scheduleShaderResize);
        shaderResizeObserver.observe(shaderCanvas.parentElement ?? shaderCanvas);
      }).catch((error) => {
        console.warn('Footer shader failed to initialize', error);
      });
    }

    // Entrance wipe — cream overlay clips away to reveal footer
    const footerWipe = document.getElementById('footer-wipe-in');
    const footer = document.getElementById('contact');
    if (footerWipe && footer && !prefersReducedMotion && !isTouchLayout) {
      const wipeTween = gsap.fromTo(footerWipe,
        { clipPath: 'inset(0% 0% 0% 0%)' },
        {
          clipPath: 'inset(0% 0% 100% 0%)',
          ease: 'none',
          scrollTrigger: {
            trigger: footer,
            start: 'top bottom',
            end: 'bottom bottom',
            scrub: true,
          },
        }
      );
      if (wipeTween.scrollTrigger) scrollTriggers.push(wipeTween.scrollTrigger);
    } else if (footerWipe) {
      footerWipe.style.display = 'none';
    }

    // Back to top — use Lenis if available
    const btn = document.getElementById('back-to-top');
    btn?.addEventListener('click', () => {
      const lenis = (window as any).lenis;
      if (lenis) {
        lenis.scrollTo(0);
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }, { signal });

    // SplitText word animation on giant CTA
    const ctaEl = document.getElementById('footer-cta');
    if (ctaEl) {
      delete ctaEl.dataset.animated;

      splitInstance = new SplitText(ctaEl, {
        type: 'words',
        wordsClass: 'footer-word',
      });

      const tween = gsap.fromTo(splitInstance.words,
        { y: 60, opacity: 0, rotateX: -40 },
        {
          y: 0,
          opacity: 1,
          rotateX: 0,
          duration: 0.8,
          stagger: 0.02,
          ease: 'power4.out',
          scrollTrigger: {
            trigger: ctaEl,
            start: 'top 85%',
            once: true,
          },
        }
      );
      if (tween.scrollTrigger) scrollTriggers.push(tween.scrollTrigger);
    }

    const footerRevealItems = [
      document.querySelector('.footer-contact-prompt'),
      ...Array.from(document.querySelectorAll('.footer-contact-link')),
      document.querySelector('.footer-nav-cell'),
      document.querySelector('.footer-mark-cell'),
      document.querySelector('.footer-bottom'),
    ].filter((item): item is Element => item instanceof Element);

    if (footerRevealItems.length > 0 && !prefersReducedMotion) {
      gsap.set(footerRevealItems, {
        y: 34,
        opacity: 0,
        filter: 'blur(9px)',
        willChange: 'transform, opacity, filter',
      });

      const footerTl = gsap.timeline({
        defaults: { ease: 'expo.out' },
        scrollTrigger: {
          trigger: document.getElementById('contact'),
          start: 'top 66%',
          once: true,
        },
        onComplete: () => {
          gsap.set(footerRevealItems, { clearProps: 'willChange,filter,transform,opacity' });
        },
      });
      timelines.push(footerTl);
      if (footerTl.scrollTrigger) scrollTriggers.push(footerTl.scrollTrigger);

      footerTl.to(footerRevealItems, {
        y: 0,
        opacity: 1,
        filter: 'blur(0px)',
        duration: 0.95,
        stagger: 0.07,
      }, 0.18);
    }

    const lockScrambleWidth = (el: Element) => {
      const target = el as HTMLElement;
      const width = Math.ceil(target.getBoundingClientRect().width);
      if (width > 0) {
        target.style.display = 'inline-block';
        target.style.minWidth = `${width}px`;
      }
    };

    // Scramble text on hover for footer links
    document.querySelectorAll('.footer-link').forEach((link) => {
      const target = link.querySelector('.scramble-target');
      if (!target) return;
      const original = target.textContent || '';
      lockScrambleWidth(target);
      link.addEventListener('mouseenter', () => {
        gsap.to(target, {
          duration: 0.5,
          scrambleText: { text: original, chars: 'abcdefghijklmnopqrstuvwxyz', speed: 0.4 },
        });
      }, { signal });
    });

    cleanupFn = () => {
      shaderDisposed = true;
      if (shaderResizeTimer) window.clearTimeout(shaderResizeTimer);
      cancelAnimationFrame(shaderResizeFrame);
      shaderResizeObserver?.disconnect();
      shaderInstance?.destroy();
      ac.abort();
      timelines.forEach((tl) => tl.kill());
      scrollTriggers.forEach((st) => st.kill());
      gsap.killTweensOf(footerRevealItems);
      if (splitInstance) splitInstance.revert();
    };
  }

  initFooter();
  document.addEventListener('astro:after-swap', initFooter);
</script>
