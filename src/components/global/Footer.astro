---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const email = 'hello@newframe.studio';
const footerMeta = [
  'NEWFRAME ©26',
  'DESIGN STUDIO',
  'WARSAW BASED',
];

const emailSubject = lang === 'pl' ? 'Zapytanie o projekt, New Frame Studio' : 'Project inquiry, New Frame Studio';

const footerLinks = [
  { label: lang === 'pl' ? 'Start' : 'Home', href: `/${lang}/` },
  { label: t.nav.work, href: `/${lang}/#work` },
  { label: t.nav.scope, href: `/${lang}/#scope` },
  { label: t.nav.services, href: `/${lang}/#ways-to-work` },
  { label: t.nav.contact, href: `/${lang}/#contact` },
  { label: t.footer.privacy, href: `/${lang}/privacy/` },
];
---

<footer id="contact" class="relative z-50 overflow-hidden footer-shell">
  <div class="footer-surface">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-cta-cell">
          <h2 id="footer-cta" class="footer-cta">{t.footer.cta}</h2>
          <p class="footer-contact-prompt">{t.contact.prompt}</p>
        </div>

        <div class="footer-contact-stack footer-email-cell">
          <a
            href={`mailto:${email}?subject=${encodeURIComponent(emailSubject)}`}
            class="footer-contact-link group"
            data-cursor="CLICK"
            aria-label={`Email ${email}`}
          >
            <span class="footer-email footer-email-address">hello@newframe.studio</span>
          </a>

          <div class="footer-meta-card" aria-label="Newframe studio meta">
            {footerMeta.map((item, index) => (
              <span class:list={['footer-meta-line', { 'footer-meta-line--brand': index === 0 }]}>
                {item}
              </span>
            ))}
          </div>
        </div>

        <nav class="footer-nav-cell" aria-label={t.footer.navigation}>
          <ul class="footer-link-grid">
            {footerLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link group">
                  <span class="scramble-target">{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <div class="footer-bottom">
        <p>&copy; {year} New Frame Studio · {t.footer.rights}</p>
      </div>
    </div>

    <div class="footer-wordmark-shader" data-footer-wordmark-shader aria-hidden="true"></div>
  </div>
</footer>

<style>
  .footer-shell {
    --footer-cream: rgba(243, 234, 223, 0.9);
    --footer-cream-muted: rgba(243, 234, 223, 0.62);
    --footer-cream-soft: rgba(243, 234, 223, 0.38);
    --footer-line: rgba(243, 234, 223, 0.12);
    z-index: 100;
    color: var(--color-dark-text);
  }

  .footer-surface {
    position: relative;
    box-sizing: border-box;
    min-height: 100svh;
    overflow: hidden;
    background: transparent;
  }

  .footer-inner {
    position: relative;
    box-sizing: border-box;
    z-index: 2;
    display: grid;
    min-height: 100svh;
    align-content: center;
    gap: clamp(1.25rem, 1.25vw, 1.5rem);
    width: min(100%, 1760px);
    margin: 0 auto;
    padding: clamp(5.5rem, 6.8svh, 5.5rem) clamp(1.25rem, 4.17vw, 5rem) clamp(8.5rem, 10.5svh, 8.5rem);
  }

  .footer-grid {
    display: grid;
    min-height: clamp(31rem, 47.7svh, 38.75rem);
    background: transparent;
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: minmax(0, 1fr) minmax(26rem, 36.5rem);
    }
  }

  .footer-cta-cell,
  .footer-email-cell,
  .footer-nav-cell {
    min-width: 0;
  }

  .footer-cta-cell {
    display: flex;
    min-height: clamp(28rem, 47.7svh, 38.75rem);
    flex-direction: column;
    justify-content: center;
    padding: clamp(2.5rem, 4.17vw, 5rem);
    padding-right: 0;
  }

  @media (min-width: 1024px) {
    .footer-cta-cell {
      grid-row: 1;
    }
  }

  .footer-cta {
    max-width: 6.8em;
    color: var(--color-dark-text);
    font-family: var(--font-serif);
    font-size: clamp(4.375rem, 6.1vw, 7.3rem);
    font-weight: 300;
    line-height: 0.86;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .footer-word {
    display: inline-block;
    white-space: nowrap;
    will-change: transform, opacity;
  }

  .footer-contact-prompt {
    max-width: 37.5rem;
    margin-top: clamp(2rem, 3vw, 2.625rem);
    font-family: var(--font-mono);
    font-size: clamp(1.02rem, 0.94vw, 1.125rem);
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--footer-cream-muted);
    text-wrap: pretty;
  }

  .footer-contact-stack {
    position: relative;
    display: grid;
    min-height: clamp(28rem, 47.7svh, 38.75rem);
    grid-template-rows: repeat(2, minmax(0, 1fr));
    color: var(--color-dark-text);
  }

  @media (min-width: 1024px) {
    .footer-contact-stack {
      grid-row: 1;
    }
  }

  .footer-contact-link,
  .footer-meta-card {
    position: relative;
    display: grid;
    min-width: 0;
    align-content: center;
    justify-items: end;
    gap: clamp(1rem, 0.94vw, 1.125rem);
    padding: clamp(2rem, 2.5vw, 3rem);
    color: inherit;
    text-align: right;
  }

  .footer-contact-link {
    text-decoration: none;
    transition:
      color 0.45s var(--ease-out-expo);
  }

  .footer-meta-card {
    border-top: 0;
  }

  .footer-meta-line {
    width: 100%;
    color: var(--footer-cream-muted);
    font-family: var(--font-mono);
    font-size: clamp(0.86rem, 0.78vw, 0.94rem);
    line-height: 1.35;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .footer-meta-line--brand {
    color: var(--color-dark-text);
  }

  .footer-contact-link:last-child {
    border-bottom: 0;
  }

  .footer-contact-link:hover,
  .footer-contact-link:focus-visible {
    color: #fff;
  }

  .footer-email {
    max-width: 100%;
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 2.6vw, 3.125rem);
    font-weight: 200;
    font-style: normal;
    line-height: 0.95;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .footer-nav-cell {
    grid-column: 1 / -1;
    padding: 0;
    border-top: 1px solid var(--footer-line);
  }

  @media (min-width: 1024px) {
    .footer-nav-cell {
      grid-row: 2;
      border-bottom: 0;
    }
  }

  .footer-link-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    min-height: clamp(5.5rem, 8.92svh, 7.25rem);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (min-width: 768px) {
    .footer-link-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .footer-link-grid {
      grid-template-columns: repeat(7, minmax(8rem, 1fr));
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .footer-link-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .footer-link-grid li {
    display: flex;
    min-width: 0;
  }

  .footer-link-grid li:last-child {
    border-right: 0;
  }

  .footer-link {
    display: flex;
    flex: 1 1 auto;
    min-height: clamp(5.5rem, 8.92svh, 7.25rem);
    align-items: center;
    justify-content: center;
    padding: 1rem;
    color: var(--footer-cream-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 0.35s var(--ease-out-expo),
      color 0.3s var(--ease-out-expo);
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-dark-text);
  }

  .footer-bottom {
    display: flex;
    justify-content: center;
    color: var(--footer-cream-soft);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .footer-bottom p {
    margin: 0;
    text-align: center;
  }

  .footer-wordmark-shader {
    position: absolute;
    z-index: 1;
    bottom: clamp(-3rem, -2.5vw, -1.4rem);
    left: 2.53vw;
    width: 94.95vw;
    height: clamp(8.5rem, 14.9vw, 17.875rem);
    filter: saturate(0.82) brightness(0.58) contrast(0.98);
    opacity: 0.84;
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .footer-inner {
      padding: 4.5rem 2rem 7.5rem;
    }

    .footer-grid {
      min-height: 0;
    }

    .footer-cta-cell {
      min-height: 18.5rem;
      padding: 0 0 2.25rem;
    }

    .footer-cta {
      max-width: 6em;
      font-size: clamp(3.2rem, 17vw, 4.6rem);
      line-height: 0.9;
    }

    .footer-contact-prompt {
      margin-top: 1.25rem;
      font-size: 1.08rem;
      line-height: 1.5;
    }

    .footer-contact-stack {
      min-height: 0;
      grid-template-rows: none;
      border-top: 1px solid var(--footer-line);
    }

    .footer-contact-link,
    .footer-meta-card {
      min-height: 9.5rem;
      justify-items: start;
      gap: 0.75rem;
      padding: 1.5rem 0;
      text-align: left;
    }

    .footer-meta-line {
      font-size: clamp(0.72rem, 3.15vw, 0.88rem);
      line-height: 1.45;
      letter-spacing: 0.1em;
    }

    .footer-email {
      font-size: clamp(1.35rem, 7.4vw, 2.2rem);
      white-space: nowrap;
      overflow-wrap: normal;
    }

    .footer-email-address {
      font-size: clamp(1.2rem, 6.5vw, 2.05rem);
      overflow-wrap: normal;
      word-break: normal;
    }

    .footer-link-grid {
      display: flex;
      min-height: 0;
      flex-direction: column;
      border-top: 1px solid var(--footer-line);
    }

    .footer-link-grid li {
      border-bottom: 1px solid var(--footer-line);
    }

    .footer-link {
      min-height: 3.7rem;
      justify-content: center;
      padding: 0;
      font-size: 0.72rem;
      letter-spacing: 0.11em;
      text-align: center;
    }

    .footer-bottom {
      width: 100%;
      gap: 1.05rem;
      font-size: clamp(0.72rem, 2.55vw, 0.82rem);
      line-height: 1.5;
      letter-spacing: 0.085em;
    }

    .footer-bottom p {
      width: 100%;
      text-align: center;
    }

    .footer-bottom p {
      text-wrap: balance;
    }

    .footer-wordmark-shader {
      bottom: 1.25rem;
      left: 0.75rem;
      width: calc(100% - 1.5rem);
      height: clamp(4.5rem, 12.5vw, 5rem);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { SplitText } from 'gsap/SplitText';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';
  import type { LiquidMetalWordmarkHandle } from '../../scripts/liquidMetalWordmarkShader';

  gsap.registerPlugin(SplitText, ScrollTrigger, ScrambleTextPlugin);

  let cleanupFn: (() => void) | null = null;

  function initFooter() {
    cleanupFn?.();
    cleanupFn = null;

    const ac = new AbortController();
    const { signal } = ac;
    const scrollTriggers: ScrollTrigger[] = [];
    const timelines: gsap.core.Timeline[] = [];
    let splitInstance: any = null;
    let wordmarkShader: LiquidMetalWordmarkHandle | null = null;
    let wordmarkShaderDisposed = false;
    let wordmarkObserver: IntersectionObserver | null = null;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const wordmarkShaderMount = document.querySelector<HTMLElement>('[data-footer-wordmark-shader]');

    // Mount the wordmark shader only once the footer approaches the viewport,
    // so the shader runtime stays off the initial-load path.
    const mountWordmarkShader = async () => {
      if (wordmarkShader || wordmarkShaderDisposed || !wordmarkShaderMount) return;
      try {
        const { mountLiquidMetalWordmarkShader } = await import('../../scripts/liquidMetalWordmarkShader');
        if (wordmarkShaderDisposed) return;
        wordmarkShader = mountLiquidMetalWordmarkShader(wordmarkShaderMount);
      } catch (error) {
        console.warn('[footer] Failed to load wordmark shader', error);
      }
    };

    if (wordmarkShaderMount && !prefersReducedMotion) {
      if ('IntersectionObserver' in window) {
        wordmarkObserver = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              wordmarkObserver?.disconnect();
              wordmarkObserver = null;
              void mountWordmarkShader();
            }
          },
          { rootMargin: '150% 0%' }
        );
        wordmarkObserver.observe(wordmarkShaderMount);
      } else {
        void mountWordmarkShader();
      }
    }

    // SplitText word animation on giant CTA
    const ctaEl = document.getElementById('footer-cta');
    if (ctaEl) {
      splitInstance = new SplitText(ctaEl, {
        type: 'words',
        wordsClass: 'footer-word',
      });

      const tween = gsap.fromTo(splitInstance.words,
        {
          y: 60,
          opacity: 0,
          rotateX: -40,
          filter: 'blur(12px)',
          willChange: 'transform, opacity, filter',
        },
        {
          y: 0,
          opacity: 1,
          rotateX: 0,
          filter: 'blur(0px)',
          duration: 0.8,
          stagger: 0.02,
          ease: 'power4.out',
          onComplete: () => {
            gsap.set(splitInstance.words, { clearProps: 'willChange,filter,transform,opacity' });
          },
          scrollTrigger: {
            trigger: ctaEl,
            start: 'top 85%',
            once: true,
          },
        }
      );
      if (tween.scrollTrigger) scrollTriggers.push(tween.scrollTrigger);
    }

    const footerPrompt = document.querySelector('.footer-contact-prompt');
    const footerContactLink = document.querySelector('.footer-contact-link');
    const footerMetaCard = document.querySelector('.footer-meta-card');
    const footerNavItems = Array.from(document.querySelectorAll('.footer-link-grid li'));
    const footerBottomItems = Array.from(document.querySelectorAll('.footer-bottom > *'));
    const footerRevealItems = [
      footerPrompt,
      footerContactLink,
      footerMetaCard,
      ...footerNavItems,
      ...footerBottomItems,
    ].filter((item): item is Element => item instanceof Element);

    if (footerRevealItems.length > 0 && !prefersReducedMotion) {
      gsap.set(footerRevealItems, {
        y: 34,
        opacity: 0,
        filter: 'blur(9px)',
        willChange: 'transform, opacity, filter',
      });

      const footerTl = gsap.timeline({
        defaults: { ease: 'expo.out' },
        scrollTrigger: {
          trigger: document.getElementById('contact'),
          start: 'top 66%',
          once: true,
        },
        onComplete: () => {
          gsap.set(footerRevealItems, { clearProps: 'willChange,filter,transform,opacity' });
        },
      });
      timelines.push(footerTl);
      if (footerTl.scrollTrigger) scrollTriggers.push(footerTl.scrollTrigger);

      if (footerPrompt) {
        footerTl.to(footerPrompt, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.82 }, 0.14);
      }

      if (footerContactLink) {
        footerTl.to(footerContactLink, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.9 }, 0.28);
      }

      if (footerMetaCard) {
        footerTl.to(footerMetaCard, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.9 }, 0.42);
      }

      if (footerNavItems.length > 0) {
        footerTl.to(footerNavItems, {
          y: 0,
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.78,
          stagger: 0.055,
        }, 0.58);
      }

      if (footerBottomItems.length > 0) {
        footerTl.to(footerBottomItems, {
          y: 0,
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.72,
          stagger: 0.06,
        }, 0.92);
      }
    }

    const lockScrambleWidth = (el: Element) => {
      const target = el as HTMLElement;
      const width = Math.ceil(target.getBoundingClientRect().width);
      if (width > 0) {
        target.style.display = 'inline-block';
        target.style.minWidth = `${width}px`;
      }
    };

    // Scramble text on hover for footer links
    document.querySelectorAll('.footer-link').forEach((link) => {
      const target = link.querySelector('.scramble-target');
      if (!target) return;
      const original = target.textContent || '';
      lockScrambleWidth(target);
      link.addEventListener('mouseenter', () => {
        gsap.to(target, {
          duration: 0.5,
          scrambleText: { text: original, chars: 'abcdefghijklmnopqrstuvwxyz', speed: 0.4 },
        });
      }, { signal });
    });

    cleanupFn = () => {
      ac.abort();
      wordmarkShaderDisposed = true;
      wordmarkObserver?.disconnect();
      wordmarkObserver = null;
      wordmarkShader?.destroy();
      wordmarkShader = null;
      timelines.forEach((tl) => tl.kill());
      scrollTriggers.forEach((st) => st.kill());
      gsap.killTweensOf(footerRevealItems);
      if (splitInstance) {
        gsap.killTweensOf(splitInstance.words);
        splitInstance.revert();
      }
    };
  }

  initFooter();
  document.addEventListener('astro:after-swap', initFooter);
</script>
