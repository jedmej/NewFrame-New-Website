<div id="page-shader-background" class="page-shader-background" aria-hidden="true">
  <canvas id="page-scroll-shader-canvas" class="page-shader-background__canvas"></canvas>
  <div class="page-shader-background__tint"></div>
</div>

<style>
  .page-shader-background {
    --page-time-rgb: 196 196 196;
    --page-time-accent-rgb: 252 248 240;
    --page-time-tint-opacity: 0;
    position: fixed;
    inset: -8vh -8vw;
    z-index: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }

  .page-shader-background__canvas {
    display: block;
    width: 100%;
    height: 100%;
    filter: saturate(0.92) contrast(0.95) brightness(1.03);
  }

  .page-shader-background__tint {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(circle at 74% 22%, rgb(var(--page-time-accent-rgb) / 0.88), transparent 36%),
      linear-gradient(135deg, rgb(var(--page-time-rgb) / 0.94), transparent 58%),
      rgb(var(--page-time-rgb) / 0.72);
    filter: saturate(1.16);
    opacity: var(--page-time-tint-opacity);
    pointer-events: none;
    transition: opacity 220ms var(--ease-out-quart);
  }

  :global(.page-content--scroll-shader) {
    position: relative;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .page-shader-background {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import type { ShaderInstance } from 'shaders/js';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupFn: (() => void) | null = null;

  function initPageShaderBackground() {
    cleanupFn?.();
    cleanupFn = null;

    const shell = document.getElementById('page-shader-background');
    const shaderCanvas = document.getElementById('page-scroll-shader-canvas') as HTMLCanvasElement | null;
    const tintLayer = shell?.querySelector<HTMLElement>('.page-shader-background__tint') ?? null;
    const hero = document.getElementById('hero');
    const footer = document.getElementById('contact');
    const ac = new AbortController();
    const { signal } = ac;
    const scrollTriggers: ScrollTrigger[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let shaderInstance: ShaderInstance | null = null;
    let shaderDisposed = false;
    let shaderResizeFrame = 0;
    let shaderResizeTimer: ReturnType<typeof setTimeout> | null = null;
    let shaderResizeObserver: ResizeObserver | null = null;
    let shaderMotionFrame = 0;
    let shaderSpeed = 1.05;
    let shaderTargetSpeed = 1.05;

    if (!shell || !shaderCanvas || prefersReducedMotion) {
      cleanupFn = () => {
        ac.abort();
      };
      return;
    }

    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
    const timeStops = [
      { progress: 0, color: [196, 196, 196], accent: [252, 248, 240], opacity: 0 },
      { progress: 0.28, color: [238, 224, 190], accent: [255, 244, 203], opacity: 0.16 },
      { progress: 0.58, color: [245, 103, 28], accent: [255, 187, 66], opacity: 0.54 },
      { progress: 0.78, color: [92, 65, 132], accent: [247, 112, 130], opacity: 0.48 },
      { progress: 1, color: [6, 12, 30], accent: [54, 80, 156], opacity: 0.78 },
    ];

    const mix = (from: number, to: number, progress: number) => from + (to - from) * progress;
    const smoothstep = (value: number) => value * value * (3 - 2 * value);
    const ambientShaderSpeed = 1.05;
    const fastShaderSpeed = 3.3;
    const voronoiShaderId = 'idmoz9mn6uq7jt4z0kp';

    const getTimeTint = (progress: number) => {
      const nextProgress = clamp(progress, 0, 1);
      const nextStopIndex = timeStops.findIndex((stop) => stop.progress >= nextProgress);
      const upperIndex = nextStopIndex === -1 ? timeStops.length - 1 : Math.max(1, nextStopIndex);
      const lower = timeStops[upperIndex - 1];
      const upper = timeStops[upperIndex];
      const localProgress = smoothstep(clamp((nextProgress - lower.progress) / (upper.progress - lower.progress), 0, 1));

      return {
        color: lower.color.map((channel, index) => Math.round(mix(channel, upper.color[index], localProgress))),
        accent: lower.accent.map((channel, index) => Math.round(mix(channel, upper.accent[index], localProgress))),
        opacity: mix(lower.opacity, upper.opacity, localProgress),
      };
    };

    const setTimeTint = () => {
      const viewportHeight = Math.max(window.innerHeight, 1);
      const heroBottom = hero ? hero.getBoundingClientRect().bottom + window.scrollY : 0;
      const footerTop = footer ? footer.getBoundingClientRect().top + window.scrollY : ScrollTrigger.maxScroll(window);
      const rangeStart = heroBottom - viewportHeight * 0.15;
      const rangeEnd = footerTop - viewportHeight * 0.82;
      const progress = rangeEnd > rangeStart
        ? clamp((window.scrollY - rangeStart) / (rangeEnd - rangeStart), 0, 1)
        : 0;
      const tint = getTimeTint(progress);

      shell?.style.setProperty('--page-time-rgb', tint.color.join(' '));
      shell?.style.setProperty('--page-time-accent-rgb', tint.accent.join(' '));
      shell?.style.setProperty('--page-time-tint-opacity', tint.opacity.toFixed(3));
      if (tintLayer) tintLayer.style.opacity = tint.opacity.toFixed(3);
    };

    const setShaderVisibility = () => {
      const viewportHeight = Math.max(window.innerHeight, 1);
      const heroRect = hero?.getBoundingClientRect();
      const footerRect = footer?.getBoundingClientRect();
      const heroFade = heroRect ? clamp((viewportHeight - heroRect.bottom) / (viewportHeight * 0.45), 0, 1) : 1;
      const footerFade = footerRect ? clamp((footerRect.top - viewportHeight * 0.08) / (viewportHeight * 0.6), 0, 1) : 1;
      const opacity = 0.72 * heroFade * footerFade;

      shell.style.opacity = opacity.toFixed(3);
      shell.style.visibility = opacity > 0.01 ? 'visible' : 'hidden';
      setTimeTint();
    };

    const setShaderSpeedFromVelocity = (velocity: number) => {
      const velocityProgress = smoothstep(clamp(Math.abs(velocity) / 2600, 0, 1));
      shaderTargetSpeed = mix(ambientShaderSpeed, fastShaderSpeed, velocityProgress);
    };

    const animateShaderSpeed = () => {
      shaderMotionFrame = window.requestAnimationFrame(animateShaderSpeed);
      if (!shaderInstance || shaderDisposed) return;

      const easing = shaderTargetSpeed > shaderSpeed ? 0.075 : 0.026;
      shaderSpeed = mix(shaderSpeed, shaderTargetSpeed, easing);
      shaderTargetSpeed = mix(shaderTargetSpeed, ambientShaderSpeed, 0.018);

      if (Math.abs(shaderSpeed - shaderTargetSpeed) < 0.002 && Math.abs(shaderTargetSpeed - ambientShaderSpeed) < 0.002) {
        shaderSpeed = ambientShaderSpeed;
        shaderTargetSpeed = ambientShaderSpeed;
      }

      shaderInstance.update(voronoiShaderId, {
        speed: Number(shaderSpeed.toFixed(3)),
      });
    };

    const resizeShaderToCanvas = () => {
      shaderResizeFrame = 0;
      if (!shaderCanvas || !shaderInstance || shaderDisposed) return;

      shaderCanvas.style.width = '';
      shaderCanvas.style.height = '';
      const rect = shaderCanvas.getBoundingClientRect();
      if (rect.width > 0 && rect.height > 0) {
        shaderInstance.resize(Math.round(rect.width), Math.round(rect.height));
      }
    };

    const scheduleShaderResize = () => {
      if (shaderResizeTimer) window.clearTimeout(shaderResizeTimer);
      shaderResizeTimer = window.setTimeout(() => {
        if (shaderResizeFrame) window.cancelAnimationFrame(shaderResizeFrame);
        shaderResizeFrame = window.requestAnimationFrame(resizeShaderToCanvas);
        setShaderVisibility();
      }, 120);
    };

    shaderCanvas.style.width = '';
    shaderCanvas.style.height = '';
    import('shaders/js').then(({ createShader }) => createShader(shaderCanvas, {
      components: [
        {
          type: 'Blob',
          id: 'idmozyext3ts4o5d9ra',
          props: {
            center: {
              x: 0.26,
              y: 0.07,
            },
            colorA: '#000000',
            colorB: '#000000',
            size: 0.85,
            softness: 1.5,
            speed: 0.8,
            visible: false,
          },
        },
        {
          type: 'SolidColor',
          id: 'idmozyfgxcqpgfru0wa',
          props: {
            color: '#c4c4c4',
          },
        },
        {
          type: 'Voronoi',
          id: 'idmoz9mn6uq7jt4z0kp',
          props: {
            colorA: '#a69f9f',
            colorB: '#fcf8f0',
            colorBorder: '#fcf8f0',
            colorSpace: 'oklch',
            edgeIntensity: 0.55,
            edgeSoftness: 0.18,
            scale: 3,
            seed: 33,
            speed: ambientShaderSpeed,
          },
        },
        {
          type: 'LinearBlur',
          id: 'idmozyecqfrupud2rs7',
          props: {
            angle: 36,
            intensity: 300,
            visible: true,
          },
        },
        {
          type: 'ChromaticAberration',
          id: 'idmozyyew4xw5h7jbxr',
          props: {
            strength: 0.15,
            visible: true,
          },
        },
      ],
    })).then((shader) => {
      if (shaderDisposed) {
        shader.destroy();
        return;
      }

      shaderInstance = shader;
      resizeShaderToCanvas();
      animateShaderSpeed();
      window.addEventListener('resize', scheduleShaderResize, { signal });
      window.addEventListener('orientationchange', scheduleShaderResize, { signal });
      shaderResizeObserver = new ResizeObserver(scheduleShaderResize);
      shaderResizeObserver.observe(shaderCanvas.parentElement ?? shaderCanvas);
    }).catch((error) => {
      console.warn('Page shader failed to initialize', error);
    });

    scrollTriggers.push(ScrollTrigger.create({
      trigger: document.documentElement,
      start: 0,
      end: () => ScrollTrigger.maxScroll(window),
      invalidateOnRefresh: true,
      onUpdate: (self) => {
        setShaderVisibility();
        setShaderSpeedFromVelocity(self.getVelocity());
      },
      onRefresh: setShaderVisibility,
    }));

    setShaderVisibility();

    cleanupFn = () => {
      shaderDisposed = true;
      if (shaderResizeTimer) window.clearTimeout(shaderResizeTimer);
      if (shaderResizeFrame) window.cancelAnimationFrame(shaderResizeFrame);
      if (shaderMotionFrame) window.cancelAnimationFrame(shaderMotionFrame);
      shaderResizeObserver?.disconnect();
      shaderInstance?.destroy();
      scrollTriggers.forEach((st) => st.kill());
      ac.abort();
    };
  }

  initPageShaderBackground();
  document.addEventListener('astro:after-swap', initPageShaderBackground);
</script>
