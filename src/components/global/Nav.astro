---
import type { Lang } from '../../i18n/translations';
import { useTranslations, getAlternateUrl } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const altLang = lang === 'en' ? 'pl' : 'en';
const altUrl = getAlternateUrl(Astro.url, altLang);
const mobileMenuButtonLabel = lang === 'pl' ? 'Otwórz menu' : 'Open menu';
const navAriaLabel = lang === 'pl' ? 'Główna nawigacja' : 'Primary navigation';
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 w-full z-[100] transition-transform duration-500 text-[var(--color-text)]"
  aria-label={navAriaLabel}
>
  <div class="nav-progressive-blur" aria-hidden="true">
    <div class="nav-progressive-blur__layer nav-progressive-blur__layer--soft"></div>
    <div class="nav-progressive-blur__layer nav-progressive-blur__layer--medium"></div>
    <div class="nav-progressive-blur__layer nav-progressive-blur__layer--strong"></div>
    <div class="nav-progressive-blur__layer nav-progressive-blur__layer--deep"></div>
  </div>

  <div class="nav-shell">
    <!-- Left: Logo -->
    <div class="nav-section nav-section--brand flex items-center">
      <a
        href={`/${lang}/`}
        id="logo-link"
        class="nav-brand group flex items-center gap-3 relative overflow-hidden"
        transition:name="logo"
        style="height: 1.35rem;"
      >
        <span id="logo-text" class="text-sm font-semibold tracking-tight uppercase block" style="font-family: var(--font-display)">
          New Frame<sup class="text-[0.5em] align-super opacity-40 ml-0.5">®</sup>
        </span>
        <svg id="logo-icon" class="absolute left-1/2 -translate-x-1/2 w-auto block" style="height: 1.35rem; top: 100%;" viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="300" height="100" transform="matrix(-1 0 0 1 400 400)" fill="currentColor"/>
          <rect width="100" height="400" transform="matrix(-1 0 0 1 500 100)" fill="currentColor"/>
          <rect width="300" height="100" transform="matrix(1 0 0 -1 100 100)" fill="currentColor"/>
          <rect width="100" height="400" transform="matrix(1 0 0 -1 0 400)" fill="currentColor"/>
        </svg>
      </a>
    </div>

    <!-- Center: Desktop Nav Links -->
    <div class="nav-section nav-section--links hidden lg:flex items-center">
      <a href={`/${lang}/#work`} class="nav-link text-mono-xs opacity-60 hover:opacity-100 hover:text-[var(--color-accent)] transition-[color,opacity] duration-300">
        {t.nav.work}
      </a>
      <a href={`/${lang}/#scope`} class="nav-link text-mono-xs opacity-60 hover:opacity-100 hover:text-[var(--color-accent)] transition-[color,opacity] duration-300">
        {t.nav.scope}
      </a>
      <a href={`/${lang}/#ways-to-work`} class="nav-link text-mono-xs opacity-60 hover:opacity-100 hover:text-[var(--color-accent)] transition-[color,opacity] duration-300">
        {t.nav.services}
      </a>
      <a href={`/${lang}/#services`} class="nav-link text-mono-xs opacity-60 hover:opacity-100 hover:text-[var(--color-accent)] transition-[color,opacity] duration-300">
        {t.nav.process}
      </a>
      <a href={`/${lang}/#contact`} class="nav-link text-mono-xs opacity-60 hover:opacity-100 hover:text-[var(--color-accent)] transition-[color,opacity] duration-300">
        {t.nav.contact}
      </a>
    </div>

    <!-- Right: CTA + Mobile Menu -->
    <div class="nav-section nav-section--actions flex items-center justify-end gap-4">
      <!-- Language Selector -->
      <a
        href={altUrl}
        class="nav-link nav-lang hidden lg:inline-flex text-mono-xs opacity-40 hover:opacity-100 transition-opacity"
        data-lang-switch={altLang}
      >
        {altLang.toUpperCase()}
      </a>

      <!-- Let's Talk CTA -->
      <a
        href={`/${lang}/#contact`}
        class="nav-cta hidden lg:inline-flex items-center gap-2 text-mono-xs opacity-70 hover:opacity-100 hover:text-[var(--color-accent)] transition-[color,opacity,border-color,background-color] duration-300 group"
        data-magnetic="0.35"
      >
        <span>{t.contact.cta}</span>
        <svg class="nav-cta-arrow w-3 h-3 transition-transform duration-300 ease-out" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M1 11L11 1M11 1H3M11 1V9"/>
        </svg>
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex min-h-10 min-w-10 flex-col justify-center gap-1.5 p-2 -mr-2"
        aria-label={mobileMenuButtonLabel}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="menu-line w-6 h-px transition-[background-color,transform,width] duration-300 bg-[var(--color-text)]" aria-hidden="true"></span>
        <span class="menu-line w-4 h-px transition-[background-color,transform,width] duration-300 ml-auto bg-[var(--color-text)]" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[99] bg-[var(--color-bg)] flex flex-col items-end justify-end px-4 pb-12 pointer-events-none"
  style="clip-path: inset(0 0 100% 0);"
  aria-hidden="true"
>
  <div class="flex flex-col items-end gap-2">
    <a href={`/${lang}/#work`} class="mobile-menu-link text-display-lg text-right opacity-0 translate-y-8">{t.nav.work}</a>
    <a href={`/${lang}/#scope`} class="mobile-menu-link text-display-lg text-right opacity-0 translate-y-8">{t.nav.scope}</a>
    <a href={`/${lang}/#ways-to-work`} class="mobile-menu-link text-display-lg text-right opacity-0 translate-y-8">{t.nav.services}</a>
    <a href={`/${lang}/#services`} class="mobile-menu-link text-display-lg text-right opacity-0 translate-y-8">{t.nav.process}</a>
    <a href={`/${lang}/#contact`} class="mobile-menu-link text-display-lg text-right opacity-0 translate-y-8">{t.nav.contact}</a>
  </div>
  <div class="flex items-center gap-6 mt-10 opacity-0 translate-y-8 mobile-menu-link">
    <a href={altUrl} class="text-mono-xs opacity-60 hover:opacity-100 transition-opacity" data-lang-switch={altLang}>
      {altLang.toUpperCase()}
    </a>
  </div>
</div>

<style>
  #main-nav {
    --nav-top-inset: max(1rem, env(safe-area-inset-top));
    --nav-blur-height: clamp(6.75rem, 13vh, 9.25rem);
    --nav-content-height: 5.75rem;
    --nav-ink: var(--color-text);
    opacity: 0;
    pointer-events: none;
  }

  #main-nav.nav-on-dark {
    --nav-ink: var(--color-dark-text);
  }

  #main-nav.nav-menu-open {
    transform: translateY(0);
  }

  .nav-progressive-blur {
    position: absolute;
    top: 0;
    right: 0;
    left: 0;
    z-index: 0;
    height: var(--nav-blur-height);
    overflow: hidden;
    pointer-events: none;
    contain: strict;
  }

  .nav-progressive-blur__layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: rgba(244, 244, 244, 0.015);
  }

  .nav-progressive-blur__layer--soft {
    -webkit-backdrop-filter: blur(1px);
    backdrop-filter: blur(1px);
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 74%, transparent 100%);
    mask-image: linear-gradient(180deg, #000 0%, #000 74%, transparent 100%);
  }

  .nav-progressive-blur__layer--medium {
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 48%, transparent 76%);
    mask-image: linear-gradient(180deg, #000 0%, #000 48%, transparent 76%);
  }

  .nav-progressive-blur__layer--strong {
    -webkit-backdrop-filter: blur(7px);
    backdrop-filter: blur(7px);
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 22%, transparent 52%);
    mask-image: linear-gradient(180deg, #000 0%, #000 22%, transparent 52%);
  }

  .nav-progressive-blur__layer--deep {
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 10%, transparent 34%);
    mask-image: linear-gradient(180deg, #000 0%, #000 10%, transparent 34%);
  }

  .nav-shell {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: var(--nav-content-height);
    align-items: start;
    padding: var(--nav-top-inset) clamp(1.25rem, 3.8vw, 4rem) 0;
    pointer-events: none;
  }

  .nav-section {
    pointer-events: auto;
  }

  .nav-brand,
  .nav-section--links .nav-link,
  .nav-section--actions > .nav-link,
  .nav-cta,
  #mobile-menu-btn {
    color: var(--nav-ink);
    transition:
      color 0.24s var(--ease-out-quart),
      opacity 0.24s var(--ease-out-quart);
  }

  .nav-brand {
    width: max-content;
  }

  .nav-cta {
    min-height: 2.35rem;
  }

  .nav-section .nav-link:hover,
  .nav-section .nav-cta:hover {
    color: currentColor;
  }

  .menu-line {
    background: currentColor;
  }

  @media (max-width: 1023px) {
    #main-nav {
      --nav-top-inset: max(0.875rem, env(safe-area-inset-top));
      --nav-blur-height: 7.25rem;
      --nav-content-height: 4.5rem;
    }

    .nav-shell {
      display: flex;
      min-height: var(--nav-content-height);
      align-items: flex-start;
      justify-content: space-between;
      padding: var(--nav-top-inset) clamp(1rem, 4vw, 1.35rem) 0;
    }

    .nav-section--brand,
    .nav-section--actions {
      min-height: 2.5rem;
    }

    .nav-section--brand {
      align-items: center;
    }

    .nav-brand {
      height: 2.5rem !important;
      padding-top: 0.55rem;
    }

    #mobile-menu {
      top: 0;
      right: 0;
      bottom: 0;
      left: 0;
      z-index: 99;
      align-items: stretch;
      justify-content: flex-start;
      padding: calc(var(--nav-top-inset) + 4.65rem) clamp(1rem, 4vw, 1.35rem) 1.25rem;
      overflow: hidden;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--color-bg) 88%, transparent) 0%,
          color-mix(in srgb, var(--color-bg) 80%, transparent) 42%,
          color-mix(in srgb, var(--color-bg) 66%, transparent) 100%
        );
      -webkit-backdrop-filter: blur(24px) saturate(1.08);
      backdrop-filter: blur(24px) saturate(1.08);
    }

    #mobile-menu > div:first-child {
      align-items: stretch;
      gap: 0;
      width: 100%;
    }

    #mobile-menu > div:last-child {
      margin-top: 0;
      padding: 1rem 0 0;
      border-top: 1px solid rgba(20, 18, 15, 0.1);
    }

    .mobile-menu-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 3.65rem;
      padding: 0;
      border-top: 1px solid rgba(20, 18, 15, 0.1);
      font-family: var(--font-mono);
      font-size: clamp(0.82rem, 3.25vw, 1rem);
      line-height: 1;
      letter-spacing: 0.14em;
      text-align: left;
      text-transform: uppercase;
    }

    .mobile-menu-link:first-child {
      border-top: 0;
    }

    .mobile-menu-link::after {
      width: 0.38rem;
      height: 0.38rem;
      flex: 0 0 auto;
      margin-left: 1rem;
      background: var(--color-accent);
      content: '';
      transform: rotate(45deg);
    }

    #mobile-menu > .mobile-menu-link {
      min-height: auto;
      padding: 0;
      border-top: 0;
      color: var(--color-text-muted);
    }

    #mobile-menu > .mobile-menu-link::after {
      content: none;
    }

    #mobile-menu-btn {
      margin-right: -0.5rem;
    }
  }

  @media (min-width: 1024px) {
    .nav-shell {
      grid-template-columns: minmax(12rem, 1fr) auto minmax(12rem, 1fr);
      column-gap: clamp(1.25rem, 2vw, 2.25rem);
    }

    .nav-section--brand {
      justify-content: flex-start;
    }

    .nav-section--links {
      min-height: 2.35rem;
      justify-content: center;
      gap: clamp(1.35rem, 2.7vw, 3.35rem);
      padding-inline: clamp(0.65rem, 1.2vw, 1.15rem);
    }

    .nav-section--actions {
      justify-content: flex-end;
      gap: clamp(1rem, 1.8vw, 1.75rem);
    }
  }

  @media (min-width: 1024px) and (max-width: 1180px) {
    .nav-shell {
      padding-inline: clamp(1.1rem, 2.2vw, 2rem);
    }

    .nav-section--links {
      gap: clamp(1.25rem, 2.25vw, 2rem);
    }
  }

  #mobile-menu-btn {
    border: 1px solid transparent;
    transition:
      border-color 0.28s var(--ease-out-expo),
      background-color 0.28s var(--ease-out-expo);
  }

  #mobile-menu-btn:focus-visible {
    outline: none;
    border-color: rgba(201, 70, 57, 0.58);
    background: rgba(247, 242, 233, 0.34);
  }

  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .nav-progressive-blur__layer {
      display: none;
    }

    .nav-progressive-blur {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #main-nav {
      opacity: 1;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';

  gsap.registerPlugin(ScrambleTextPlugin);

  let cleanupFn: (() => void) | null = null;

  function initNav() {
    cleanupFn?.();
    cleanupFn = null;

    const nav = document.getElementById('main-nav');
    if (!nav) return;

    const ac = new AbortController();
    const { signal } = ac;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const timelines: gsap.core.Timeline[] = [];
    let navToneFrame = 0;

    const runIntro = () => {
      const logoLink = document.getElementById('logo-link');
      const navLinks = Array.from(nav.querySelectorAll('.nav-section--links .nav-link'));
      const actionItems = Array.from(nav.querySelectorAll('.nav-section--actions > .nav-link, .nav-section--actions > .nav-cta, #mobile-menu-btn'));
      const revealItems = [logoLink, ...navLinks, ...actionItems].filter((item): item is Element => item instanceof Element);

      if (prefersReducedMotion || revealItems.length === 0) {
        gsap.set(nav, { opacity: 1, clearProps: 'transform,filter' });
        gsap.set(revealItems, { clearProps: 'all' });
        return;
      }

      gsap.set(nav, { opacity: 1 });
      gsap.set(revealItems, {
        y: -18,
        opacity: 0,
        filter: 'blur(8px)',
        willChange: 'transform, opacity, filter',
      });

      const tl = gsap.timeline({
        defaults: { ease: 'expo.out' },
        onComplete: () => {
          gsap.set(revealItems, { clearProps: 'willChange,filter,transform,opacity' });
        },
      });
      timelines.push(tl);

      tl.to(revealItems, {
        y: 0,
        opacity: 1,
        filter: 'blur(0px)',
        duration: 0.95,
        stagger: {
          each: 0.055,
          from: 'start',
        },
      }, 0.12);
    };

    runIntro();

    const parseCssColor = (value: string) => {
      const color = value.trim();
      const hex = color.match(/^#([0-9a-f]{3}|[0-9a-f]{6})$/i);
      if (hex) {
        const raw = hex[1];
        const normalized = raw.length === 3
          ? raw.split('').map((char) => char + char).join('')
          : raw;
        return {
          r: Number.parseInt(normalized.slice(0, 2), 16),
          g: Number.parseInt(normalized.slice(2, 4), 16),
          b: Number.parseInt(normalized.slice(4, 6), 16),
        };
      }

      const rgb = color.match(/rgba?\(([^)]+)\)/i);
      if (!rgb) return null;

      const channels = rgb[1].split(',').map((part) => Number.parseFloat(part.trim()));
      if (channels.length < 3 || channels.some((channel) => Number.isNaN(channel))) return null;

      return { r: channels[0], g: channels[1], b: channels[2] };
    };

    const getLuminance = ({ r, g, b }: { r: number; g: number; b: number }) => {
      const srgb = [r, g, b].map((channel) => {
        const value = channel / 255;
        return value <= 0.03928
          ? value / 12.92
          : Math.pow((value + 0.055) / 1.055, 2.4);
      });

      return srgb[0] * 0.2126 + srgb[1] * 0.7152 + srgb[2] * 0.0722;
    };

    const updateNavTone = () => {
      navToneFrame = 0;

      const band = document.querySelector<HTMLElement>('[data-offer-process-band]');
      if (!band) {
        nav.classList.remove('nav-on-dark');
        return;
      }

      const navSampleY = window.innerWidth >= 1024
        ? Math.max(42, window.innerHeight * 0.055)
        : Math.max(34, window.innerHeight * 0.05);
      const bandRect = band.getBoundingClientRect();
      const isOverBand = bandRect.top <= navSampleY && bandRect.bottom >= navSampleY;
      const bg = parseCssColor(getComputedStyle(band).getPropertyValue('--offer-process-bg'));
      const isDarkBand = !!bg && getLuminance(bg) < 0.36;

      nav.classList.toggle('nav-on-dark', isOverBand && isDarkBand);
    };

    const scheduleNavToneUpdate = () => {
      if (navToneFrame) return;
      navToneFrame = window.requestAnimationFrame(updateNavTone);
    };

    updateNavTone();
    window.addEventListener('scroll', scheduleNavToneUpdate, { signal, passive: true });
    window.addEventListener('resize', scheduleNavToneUpdate, { signal, passive: true });
    document.addEventListener('astro:page-load', scheduleNavToneUpdate, { signal });

    const lockScrambleWidth = (el: Element) => {
      const target = el as HTMLElement;
      const width = Math.ceil(target.getBoundingClientRect().width);
      if (width > 0) {
        target.style.display = 'inline-block';
        target.style.minWidth = `${width}px`;
      }
    };

    // Scramble text on hover for nav links
    nav.querySelectorAll('.nav-link, .nav-cta span').forEach((el) => {
      const original = el.textContent || '';
      lockScrambleWidth(el);
      el.addEventListener('mouseenter', () => {
        gsap.to(el, {
          duration: 0.5,
          scrambleText: { text: original, chars: 'abcdefghijklmnopqrstuvwxyz', speed: 0.4 },
        });
      }, { signal });
    });

    // Animate CTA arrow: rotate to point right on hover
    const ctaLink = nav.querySelector('.nav-cta');
    const ctaArrow = nav.querySelector('.nav-cta-arrow');
    if (ctaLink && ctaArrow) {
      ctaLink.addEventListener('mouseenter', () => {
        gsap.to(ctaArrow, { rotation: 45, duration: 0.3, ease: 'power2.out' });
      }, { signal });
      ctaLink.addEventListener('mouseleave', () => {
        gsap.to(ctaArrow, { rotation: 0, duration: 0.3, ease: 'power2.out' });
      }, { signal });
    }

    // Logo hover: text slides up, SVG slides in from bottom
    const logoLink = document.getElementById('logo-link');
    const logoText = document.getElementById('logo-text');
    const logoIcon = document.getElementById('logo-icon');

    if (logoLink && logoText && logoIcon) {
      let logoTl: gsap.core.Timeline | null = null;

      logoLink.addEventListener('mouseenter', () => {
        if (logoTl) logoTl.kill();
        logoTl = gsap.timeline()
          .to(logoText, {
            y: '-100%',
            opacity: 0,
            duration: 0.25,
            ease: 'power3.in',
          })
          .fromTo(logoIcon,
            { y: '0%', opacity: 0 },
            {
              y: '-100%',
              opacity: 1,
              duration: 0.3,
              ease: 'power3.out',
            },
            '>-0.05'
          );
      }, { signal });

      logoLink.addEventListener('mouseleave', () => {
        if (logoTl) logoTl.kill();
        logoTl = gsap.timeline()
          .to(logoIcon, {
            y: '0%',
            opacity: 0,
            duration: 0.25,
            ease: 'power3.in',
          })
          .to(logoText, {
            y: '0%',
            opacity: 1,
            duration: 0.3,
            ease: 'power3.out',
          }, '>-0.05');
      }, { signal });
    }

    // Mobile menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuLines = menuBtn?.querySelectorAll('.menu-line');
    const menuLinks = mobileMenu?.querySelectorAll('.mobile-menu-link');
    const isPolish = document.documentElement.lang === 'pl';
    const openMenuLabel = isPolish ? 'Otwórz menu' : 'Open menu';
    const closeMenuLabel = isPolish ? 'Zamknij menu' : 'Close menu';
    let menuOpen = false;

    function openMenu() {
      menuOpen = true;
      nav.classList.add('nav-menu-open');
      mobileMenu!.style.pointerEvents = 'all';
      document.body.style.overflow = 'hidden';

      // Update aria states
      menuBtn!.setAttribute('aria-expanded', 'true');
      menuBtn!.setAttribute('aria-label', closeMenuLabel);
      mobileMenu!.setAttribute('aria-hidden', 'false');

      // Animate lines to X
      gsap.to(menuLines![0], { rotation: 45, y: 4, width: 24, duration: 0.3 });
      gsap.to(menuLines![1], { rotation: -45, y: -4, width: 24, marginLeft: 0, duration: 0.3 });

      // Expand as an attached panel below the floating nav
      gsap.to(mobileMenu!, {
        clipPath: 'inset(0 0 0% 0)',
        duration: 0.62,
        ease: 'expo.inOut',
      });

      // Stagger links in once the panel starts expanding
      gsap.to(menuLinks!, {
        opacity: 1,
        y: 0,
        duration: 0.42,
        stagger: 0.06,
        ease: 'power2.out',
        delay: 0.12,
      });
    }

    function closeMenu() {
      menuOpen = false;

      // Animate lines back
      gsap.to(menuLines![0], { rotation: 0, y: 0, duration: 0.3 });
      gsap.to(menuLines![1], { rotation: 0, y: 0, width: 16, marginLeft: 'auto', duration: 0.3 });

      // Collapse back into the floating nav
      gsap.to(mobileMenu!, {
        clipPath: 'inset(0 0 100% 0)',
        duration: 0.48,
        ease: 'expo.inOut',
        onComplete: () => {
          nav.classList.remove('nav-menu-open');
          mobileMenu!.style.pointerEvents = 'none';
          document.body.style.overflow = '';

          // Reset link positions for next open
          gsap.set(menuLinks!, { opacity: 0, y: 8 });
        },
      });

      // Update aria states
      menuBtn!.setAttribute('aria-expanded', 'false');
      menuBtn!.setAttribute('aria-label', openMenuLabel);
      mobileMenu!.setAttribute('aria-hidden', 'true');
    }

    menuBtn?.addEventListener('click', () => {
      if (menuOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    }, { signal });

    // Escape key closes menu and returns focus to button
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOpen && menuBtn) {
        closeMenu();
        menuBtn.focus();
      }
    }, { signal });

    // Focus trap inside mobile menu
    if (mobileMenu) {
      mobileMenu.addEventListener('keydown', (e) => {
        if (e.key !== 'Tab' || !menuOpen) return;

        const focusableEls = mobileMenu.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])');
        if (focusableEls.length === 0) return;

        const firstEl = focusableEls[0];
        const lastEl = focusableEls[focusableEls.length - 1];

        if (e.shiftKey) {
          if (document.activeElement === firstEl) {
            e.preventDefault();
            lastEl.focus();
          }
        } else {
          if (document.activeElement === lastEl) {
            e.preventDefault();
            firstEl.focus();
          }
        }
      }, { signal });
    }

    // Store language preference when switching via nav
    document.querySelectorAll('[data-lang-switch]').forEach(link => {
      link.addEventListener('click', () => {
        localStorage.setItem('preferred-lang', (link as HTMLElement).dataset.langSwitch!);
      }, { signal });
    });

    // Close menu on link click
    menuLinks?.forEach((link) => {
      link.addEventListener('click', () => {
        if (menuOpen) menuBtn?.click();
      }, { signal });
    });

    cleanupFn = () => {
      timelines.forEach((tl) => tl.kill());
      gsap.killTweensOf(nav);
      gsap.killTweensOf(nav.querySelectorAll('.nav-link, .nav-cta, #logo-link, #mobile-menu-btn, .nav-cta-arrow, .menu-line'));
      gsap.killTweensOf(mobileMenu?.querySelectorAll('.mobile-menu-link') || []);
      if (mobileMenu) {
        gsap.killTweensOf(mobileMenu);
      }
      nav.classList.remove('nav-menu-open');
      document.body.style.overflow = '';
      if (navToneFrame) {
        window.cancelAnimationFrame(navToneFrame);
        navToneFrame = 0;
      }
      ac.abort();
    };
  }

  // Init on page load and after view transitions
  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
