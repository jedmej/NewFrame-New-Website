---
const isDev = import.meta.env.DEV;
---

{isDev && (
  <script>
    import { createElement } from 'react';
    import { createRoot } from 'react-dom/client';
    import { Retune } from 'retune';

    let cleanupFn = null;

    function init() {
      cleanupFn?.();

      const controller = new AbortController();
      const existingRoot = document.getElementById('retune-overlay-root');
      existingRoot?.remove();

      const rootElement = document.createElement('div');
      rootElement.id = 'retune-overlay-root';
      document.body.append(rootElement);

      const root = createRoot(rootElement);
      root.render(createElement(Retune, { force: true, position: 'bottom-right' }));

      const outputButton = document.createElement('button');
      outputButton.type = 'button';
      outputButton.textContent = 'Retune output';
      outputButton.style.cssText = `
        position: fixed;
        right: 16px;
        bottom: 72px;
        z-index: 2147483647;
        border: 1px solid rgba(28, 25, 23, 0.12);
        border-radius: 999px;
        background: #fff;
        color: #1c1917;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        font: 500 12px/1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        padding: 10px 12px;
        cursor: pointer;
      `;

      const panel = document.createElement('div');
      panel.hidden = true;
      panel.style.cssText = `
        position: fixed;
        right: 16px;
        bottom: 118px;
        width: min(560px, calc(100vw - 32px));
        z-index: 2147483647;
        border: 1px solid rgba(28, 25, 23, 0.12);
        border-radius: 14px;
        background: #fff;
        color: #1c1917;
        box-shadow: 0 18px 54px rgba(0, 0, 0, 0.18);
        font: 400 12px/1.4 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        padding: 12px;
      `;

      const actions = document.createElement('div');
      actions.style.cssText = 'display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 10px;';

      const status = document.createElement('span');
      status.textContent = 'Retune output fallback';
      status.style.cssText = 'opacity: 0.65;';

      const actionGroup = document.createElement('div');
      actionGroup.style.cssText = 'display: flex; gap: 6px;';

      const textarea = document.createElement('textarea');
      textarea.readOnly = true;
      textarea.placeholder = 'No Retune changes yet.';
      textarea.style.cssText = `
        width: 100%;
        height: min(48vh, 420px);
        resize: vertical;
        border: 1px solid rgba(28, 25, 23, 0.14);
        border-radius: 10px;
        background: #f7f5f0;
        color: #1c1917;
        font: 12px/1.45 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        padding: 10px;
        outline: none;
      `;

      function makePanelButton(label) {
        const button = document.createElement('button');
        button.type = 'button';
        button.textContent = label;
        button.style.cssText = `
          border: 1px solid rgba(28, 25, 23, 0.14);
          border-radius: 999px;
          background: #fff;
          color: #1c1917;
          font: 500 12px/1 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
          padding: 8px 10px;
          cursor: pointer;
        `;
        return button;
      }

      const refreshButton = makePanelButton('Refresh');
      const copyButton = makePanelButton('Copy');
      const closeButton = makePanelButton('Close');

      async function refreshOutput() {
        const retune = window.__retune;
        const formatted = await retune?.getFormattedChanges?.();
        textarea.value = formatted || 'No changes recorded.';
        status.textContent = textarea.value === 'No changes recorded.' ? 'No Retune changes yet.' : 'Retune output loaded.';
      }

      async function copyOutput() {
        textarea.focus();
        textarea.select();

        try {
          await navigator.clipboard.writeText(textarea.value);
          status.textContent = 'Copied.';
          return;
        } catch {
          const copied = document.execCommand('copy');
          status.textContent = copied ? 'Copied.' : 'Select text and press Command+C.';
        }
      }

      outputButton.addEventListener('click', async () => {
        panel.hidden = !panel.hidden;
        if (!panel.hidden) await refreshOutput();
      }, { signal: controller.signal });

      refreshButton.addEventListener('click', refreshOutput, { signal: controller.signal });
      copyButton.addEventListener('click', copyOutput, { signal: controller.signal });
      closeButton.addEventListener('click', () => {
        panel.hidden = true;
      }, { signal: controller.signal });

      document.addEventListener('keydown', async (event) => {
        if (event.altKey && event.shiftKey && event.key.toLowerCase() === 'd') {
          event.preventDefault();
          panel.hidden = !panel.hidden;
          if (!panel.hidden) await refreshOutput();
        }
      }, { signal: controller.signal });

      actionGroup.append(refreshButton, copyButton, closeButton);
      actions.append(status, actionGroup);
      panel.append(actions, textarea);
      document.body.append(outputButton, panel);

      cleanupFn = () => {
        controller.abort();
        root.unmount();
        rootElement.remove();
        outputButton.remove();
        panel.remove();
      };
    }

    init();
    document.addEventListener('astro:after-swap', init);
  </script>
)}
