---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="ways-to-work" class="ways-to-work">
  <div class="ways-to-work__inner">
    <div class="ways-to-work__label-row">
      <p class="text-mono-xs text-[var(--color-text)]">{t.waysToWork.label}</p>
      <div class="ways-to-work__line"></div>
    </div>

    <div class="ways-to-work__intro">
      <h2 class="ways-to-work__heading">{t.waysToWork.heading}</h2>
      <p class="ways-to-work__copy">{t.waysToWork.intro}</p>
    </div>

    <div class="ways-to-work__list">
      {t.waysToWork.items.map((item, index) => (
        <article class="ways-to-work__item">
          <div class="ways-to-work__index text-mono-xs">{String(index + 1).padStart(2, '0')}</div>
          <div class="ways-to-work__content">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <ul>
              {item.includes.map((entry) => (
                <li>{entry}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <p class="ways-to-work__pricing text-mono-xs">{t.waysToWork.pricing}</p>
  </div>
</section>

<style>
  .ways-to-work {
    position: relative;
    padding: clamp(7rem, 12vw, 11rem) 1.5rem;
    background: #E4DBD0;
    color: var(--color-text);
  }

  .ways-to-work::before {
    content: '';
    position: absolute;
    top: -1px;
    right: 0;
    left: 0;
    z-index: 0;
    height: min(72svh, 46rem);
    pointer-events: none;
    background: var(--color-bg-dark);
    opacity: var(--work-exit-transition-progress, 0);
    will-change: opacity;
  }

  .ways-to-work__inner {
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .ways-to-work {
      padding-inline: 2.5rem;
    }
  }

  .ways-to-work__inner {
    width: min(100%, 1400px);
    margin: 0 auto;
  }

  .ways-to-work__label-row {
    margin-bottom: clamp(3rem, 6vw, 5.5rem);
  }

  .ways-to-work__line {
    width: 100%;
    height: 1px;
    margin-top: 1rem;
    background: var(--color-line);
    transform-origin: left center;
  }

  .ways-to-work__intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  @media (min-width: 1024px) {
    .ways-to-work__intro {
      grid-template-columns: minmax(0, 0.95fr) minmax(14rem, 0.5fr);
      align-items: end;
    }
  }

  .ways-to-work__heading {
    max-width: 56rem;
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 6.75rem);
    line-height: 0.9;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .ways-to-work__copy {
    max-width: 29rem;
    font-family: var(--font-mono);
    font-size: clamp(1.08rem, 1.12vw, 1.28rem);
    line-height: 1.64;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .ways-to-work__list {
    display: grid;
    gap: 1rem;
  }

  .ways-to-work__item {
    --reveal-opacity: 1;
    --reveal-y: 0px;
    --reveal-blur: 0px;

    display: grid;
    grid-template-columns: clamp(3.75rem, 10vw, 5.75rem) minmax(0, 1fr);
    gap: 0;
    min-height: clamp(13rem, 20vw, 17.5rem);
    border: 1px solid var(--color-border-strong);
    background: rgba(247, 242, 233, 0.42);
    box-shadow: 0 1.4rem 4rem rgba(86, 56, 39, 0.06);
    opacity: var(--reveal-opacity);
    filter: blur(var(--reveal-blur));
    transform: translate3d(0, var(--reveal-y), 0);
    transition:
      border-color 0.45s var(--ease-out-expo),
      background-color 0.45s var(--ease-out-expo),
      transform 0.45s var(--ease-out-expo),
      box-shadow 0.45s var(--ease-out-expo);
    will-change: transform, opacity, filter;
  }

  .ways-to-work__item:hover {
    border-color: rgba(201, 70, 57, 0.32);
    background: rgba(247, 242, 233, 0.68);
    box-shadow: 0 1.8rem 4.6rem rgba(86, 56, 39, 0.1);
  }

  .ways-to-work__item.is-revealed {
    will-change: auto;
  }

  @media (min-width: 1024px) {
    .ways-to-work__item {
      grid-template-columns: clamp(5.25rem, 7vw, 6.75rem) minmax(0, 1fr);
    }
  }

  .ways-to-work__index {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 3vw, 2.75rem) clamp(0.75rem, 2vw, 1.5rem);
    border-right: 1px solid var(--color-border-strong);
    color: var(--color-accent);
    font-size: 0.78rem;
    line-height: 1;
    text-align: center;
  }

  .ways-to-work__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 1120px) {
    .ways-to-work__content {
      grid-template-columns: minmax(15rem, 0.72fr) minmax(17rem, 0.78fr) minmax(17rem, 0.72fr);
      align-items: stretch;
    }
  }

  @media (min-width: 768px) and (max-width: 1119px) {
    .ways-to-work__content > h3 {
      border-bottom: 1px solid var(--color-border-strong);
    }

    .ways-to-work__content > p {
      border-bottom: 1px solid var(--color-border-strong);
    }

    .ways-to-work__content > ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .ways-to-work__content > h3,
  .ways-to-work__content > p,
  .ways-to-work__content > ul {
    padding: clamp(1.5rem, 4vw, 4.75rem) clamp(1.25rem, 3.4vw, 3.4rem);
  }

  @media (min-width: 1120px) {
  .ways-to-work__content > p,
  .ways-to-work__content > ul {
      border-left: 1px solid var(--color-border-strong);
    }
  }

  .ways-to-work__content h3 {
    display: flex;
    align-items: center;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.6vw, 3.35rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .ways-to-work__content p,
  .ways-to-work__content li {
    font-family: var(--font-mono);
    font-size: clamp(0.96rem, 0.9vw, 1.06rem);
    line-height: 1.68;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .ways-to-work__content ul {
    display: grid;
    align-content: stretch;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ways-to-work__content > ul {
    padding: 0;
  }

  .ways-to-work__content > p {
    display: flex;
    align-items: center;
  }

  .ways-to-work__content li {
    display: flex;
    align-items: center;
    min-height: 3.45rem;
    padding: 0.9rem clamp(1.25rem, 2.6vw, 2.35rem);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) and (max-width: 1119px) {
    .ways-to-work__content li:nth-child(odd) {
      border-right: 1px solid var(--color-border-subtle);
    }

    .ways-to-work__content ul:not(:has(li:nth-child(odd):last-child)) li:nth-last-child(-n + 2) {
      border-bottom: 0;
    }

    .ways-to-work__content ul:has(li:nth-child(odd):last-child) li:last-child {
      border-bottom: 0;
    }

    .ways-to-work__content ul:has(li:nth-child(odd):last-child)::after {
      display: block;
      min-height: 3.45rem;
      content: '';
    }
  }

  .ways-to-work__content li:last-child {
    border-bottom: 0;
  }

  .ways-to-work__content li::before {
    content: '';
    width: 0.42rem;
    height: 0.42rem;
    flex: 0 0 auto;
    margin-right: 0.85rem;
    background: var(--color-accent);
    transform: rotate(45deg);
  }

  .ways-to-work__pricing {
    width: fit-content;
    max-width: 100%;
    margin-top: 2rem;
    margin-inline: auto;
    color: var(--color-text-subtle);
    text-align: center;
    overflow-wrap: anywhere;
  }

  @media (min-width: 1024px) {
    .ways-to-work__pricing {
      white-space: nowrap;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ways-to-work__item {
      --reveal-opacity: 1;
      --reveal-y: 0px;
      --reveal-blur: 0px;
      will-change: auto;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupFn: (() => void) | null = null;

  function initWaysToWork() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('ways-to-work');
    if (!section) return;

    const ac = new AbortController();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const scrollTriggers: ScrollTrigger[] = [];
    const timelines: gsap.core.Timeline[] = [];

    const label = section.querySelector('.ways-to-work__label-row');
    const line = section.querySelector('.ways-to-work__line');
    const heading = section.querySelector('.ways-to-work__heading');
    const copy = section.querySelector('.ways-to-work__copy');
    const items = Array.from(section.querySelectorAll<HTMLElement>('.ways-to-work__item'));
    const pricing = section.querySelector('.ways-to-work__pricing');

    if (prefersReducedMotion) {
      gsap.set([label, line, heading, copy, pricing, ...items].filter(Boolean), { clearProps: 'all' });
      items.forEach((item) => {
        item.style.setProperty('--reveal-opacity', '1');
        item.style.setProperty('--reveal-y', '0px');
        item.style.setProperty('--reveal-blur', '0px');
      });
    } else {
      gsap.set(line, { scaleX: 0 });
      gsap.set([label, heading, copy, pricing].filter(Boolean), {
        y: 28,
        opacity: 0,
        filter: 'blur(8px)',
      });

      const introTl = gsap.timeline({
        defaults: { ease: 'expo.out' },
        scrollTrigger: {
          trigger: section,
          start: 'top 74%',
          once: true,
        },
      });
      timelines.push(introTl);
      if (introTl.scrollTrigger) scrollTriggers.push(introTl.scrollTrigger);

      introTl
        .to(label, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.85 }, 0)
        .to(line, { scaleX: 1, duration: 1.15 }, 0.05)
        .to(heading, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.05 }, 0.18)
        .to(copy, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.95 }, 0.34);

      items.forEach((item, index) => {
        const itemParts = [
          item.querySelector('.ways-to-work__index'),
          item.querySelector('.ways-to-work__content > h3'),
          item.querySelector('.ways-to-work__content > p'),
          ...Array.from(item.querySelectorAll('.ways-to-work__content li')),
        ].filter((part): part is Element => part instanceof Element);

        gsap.set(itemParts, {
          y: 18,
          opacity: 0,
          filter: 'blur(6px)',
        });

        const revealTrigger = ScrollTrigger.create({
          trigger: item,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 0.45,
          onUpdate: () => {
            const rect = item.getBoundingClientRect();
            const viewport = window.innerHeight;
            const enter = Math.min(1, Math.max(0, (viewport - rect.top) / (viewport * 0.26)));
            const exit = Math.min(1, Math.max(0, rect.bottom / (viewport * 0.26)));
            const reveal = Math.min(enter, exit);
            const y = enter < exit ? (1 - reveal) * (26 + index * 3) : (1 - reveal) * -16;

            item.style.setProperty('--reveal-opacity', reveal.toFixed(3));
            item.style.setProperty('--reveal-y', `${y.toFixed(2)}px`);
            item.style.setProperty('--reveal-blur', `${((1 - reveal) * 13).toFixed(2)}px`);
          },
          onLeave: () => item.classList.add('is-revealed'),
          onEnterBack: () => item.classList.remove('is-revealed'),
        });
        scrollTriggers.push(revealTrigger);

        const partsTl = gsap.timeline({
          defaults: { ease: 'expo.out' },
          scrollTrigger: {
            trigger: item,
            start: 'top 78%',
            once: true,
          },
        });
        timelines.push(partsTl);
        if (partsTl.scrollTrigger) scrollTriggers.push(partsTl.scrollTrigger);

        partsTl.to(itemParts, {
          y: 0,
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.9,
          stagger: 0.045,
        }, index * 0.035);
      });

      if (pricing) {
        const pricingTl = gsap.timeline({
          defaults: { ease: 'expo.out' },
          scrollTrigger: {
            trigger: pricing,
            start: 'top 86%',
            once: true,
          },
        });
        timelines.push(pricingTl);
        if (pricingTl.scrollTrigger) scrollTriggers.push(pricingTl.scrollTrigger);

        pricingTl.to(pricing, {
          y: 0,
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.8,
        });
      }
    }

    cleanupFn = () => {
      timelines.forEach((tl) => tl.kill());
      scrollTriggers.forEach((trigger) => trigger.kill());
      gsap.killTweensOf(section.querySelectorAll('*'));
      ac.abort();
    };
  }

  initWaysToWork();
  document.addEventListener('astro:after-swap', initWaysToWork);
</script>
