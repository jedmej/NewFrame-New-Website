---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';
import { projects as allProjects } from '../../lib/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type ShowcaseProject = {
  key: keyof typeof t.work.projects;
  name: string;
  image?: string;
  imageAlt?: string;
  category: string;
  url: string;
  placeholder?: boolean;
};

type RailProject = ShowcaseProject & {
  displayIndex: number;
};

const projectKeyByUrl = {
  'https://urokitattoo.pl/': 'uroki',
  'https://panenkacreatives.com/': 'panenka',
  'https://esthetic.pl/': 'esthetic',
  'https://adfidence.com/': 'adfidence',
} satisfies Record<string, keyof typeof t.work.projects>;

const hubertProject: ShowcaseProject = {
  key: 'hubert',
  name: 'HUBERT',
  image: '/images/work/selected/hubert-1.webp',
  imageAlt: '/images/work/selected/hubert-2.webp',
  category: 'WEB',
  url: 'https://hubertkesik.com/',
};

const amvisProject: ShowcaseProject = {
  key: 'amvis',
  name: 'AMVIS',
  category: 'IN PROGRESS',
  url: '#',
  placeholder: true,
};

const selectedImages: Partial<Record<keyof typeof t.work.projects, { image: string; imageAlt?: string }>> = {
  uroki: {
    image: '/images/work/selected/uroki-1.avif',
    imageAlt: '/images/work/selected/uroki-2.avif',
  },
  panenka: {
    image: '/images/work/selected/panenka-1.png',
  },
  esthetic: {
    image: '/images/work/selected/esthetic-1.webp',
    imageAlt: '/images/work/selected/esthetic-2.avif',
  },
};

const keyedProjects: ShowcaseProject[] = allProjects.map((project) => {
  const key = projectKeyByUrl[project.url];
  if (!key) {
    throw new Error(`Missing selected work project key for ${project.name}`);
  }

  return { ...project, ...selectedImages[key], key };
});

const showcaseProjects = [hubertProject, ...keyedProjects, amvisProject];
const railProjects: RailProject[] = [0, 1].flatMap((rotationIndex) =>
  showcaseProjects.map((project, displayIndex) => ({
    ...project,
    image: rotationIndex === 1 ? (project.imageAlt ?? project.image) : project.image,
    displayIndex,
  }))
);
---

<section id="work-detroit" class="work-detroit" aria-label={t.work.altShowcaseLabel}>
  <div class="work-detroit__sticky">
    <div class="work-detroit__topline" aria-hidden="true">
      <span>{t.work.altEyebrow}</span>
      <span>{String(showcaseProjects.length).padStart(2, '0')} {t.work.counter} {String(showcaseProjects.length).padStart(2, '0')}</span>
    </div>

    <div class="work-detroit__copy">
      <h2 class="work-detroit__title">{t.work.altHeading}</h2>
      <p class="work-detroit__intro">{t.work.altIntro}</p>
    </div>

    <div class="work-detroit__stage" data-work-detroit-stage>
      {railProjects.map((project, index) => {
        const href = project.placeholder ? undefined : project.url;
        const meta = t.work.projects[project.key];
        return (
          <a
            class={`work-detroit__tile work-detroit__tile--${project.displayIndex + 1}${project.placeholder ? ' work-detroit__tile--placeholder' : ''}`}
            href={href}
            target={href ? '_blank' : undefined}
            rel={href ? 'noopener noreferrer' : undefined}
            data-work-detroit-tile
            style={`--index: ${index};`}
            aria-label={`${project.name}. ${project.category}. ${meta.description}`}
          >
            <span class="work-detroit__media">
              {project.image ? (
                <img
                  class="work-detroit__image"
                  src={project.image}
                  alt={`${project.name} project preview`}
                  loading="eager"
                  decoding="async"
                />
              ) : (
                <span class="work-detroit__placeholder">{project.name}</span>
              )}
            </span>
            <span class="work-detroit__caption">
              <span>{String(project.displayIndex + 1).padStart(2, '0')}</span>
              <span>{project.name}</span>
              <span>{project.category}</span>
            </span>
          </a>
        );
      })}
    </div>

    <div class="work-detroit__progress" aria-hidden="true">
      <span data-work-detroit-progress></span>
    </div>
  </div>
</section>

<style>
  .work-detroit {
    position: relative;
    min-height: 380vh;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .work-detroit__sticky {
    position: sticky;
    top: 0;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(1.15rem, 2vw, 1.8rem);
    isolation: isolate;
  }

  .work-detroit__topline {
    position: relative;
    z-index: 4;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: clamp(0.64rem, 0.8vw, 0.76rem);
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(10, 10, 10, 0.62);
    font-variant-numeric: tabular-nums;
  }

  .work-detroit__copy {
    position: relative;
    z-index: 3;
    width: min(100%, 1180px);
    padding-top: clamp(3.2rem, 6.5vw, 5.8rem);
    pointer-events: none;
  }

  .work-detroit__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.8rem, 9.4vw, 8.6rem);
    font-weight: 700;
    line-height: 0.78;
    letter-spacing: 0;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .work-detroit__intro {
    max-width: 27rem;
    margin: clamp(1.35rem, 2.4vw, 2rem) 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.45vw, 1.42rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: 0;
    text-transform: uppercase;
    color: rgba(10, 10, 10, 0.84);
    text-wrap: pretty;
  }

  .work-detroit__stage {
    --rail-x: 0px;
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    height: 76vh;
    pointer-events: none;
  }

  .work-detroit__tile {
    --caption-alpha: 0;
    --tile-left: 0px;
    --tile-width: 20rem;
    --tile-height: 20rem;
    position: absolute;
    left: var(--tile-left);
    bottom: 0;
    display: block;
    width: var(--tile-width);
    height: var(--tile-height);
    color: inherit;
    text-decoration: none;
    pointer-events: auto;
    transform: translate3d(var(--rail-x), 0, 0);
    transform-origin: left bottom;
    will-change: transform;
  }

  .work-detroit__media {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #111;
  }

  .work-detroit__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.94) contrast(1.02);
    outline: 1px solid rgba(0, 0, 0, 0.1);
    outline-offset: -1px;
    transition: filter 0.5s ease, transform 0.75s var(--ease-out-expo);
  }

  .work-detroit__tile:hover .work-detroit__image,
  .work-detroit__tile:focus-visible .work-detroit__image {
    filter: saturate(1.04) contrast(1.04);
    transform: scale(1.025);
  }

  .work-detroit__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 20% 20%, rgba(201, 70, 57, 0.34), transparent 32%),
      linear-gradient(135deg, #111, #24211d);
    color: #f4f0e8;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 0.82;
    letter-spacing: 0;
    text-align: center;
  }

  .work-detroit__caption {
    display: none;
    justify-content: space-between;
    gap: 0.7rem;
    padding-top: 0.62rem;
    font-family: var(--font-mono);
    font-size: clamp(0.56rem, 0.68vw, 0.66rem);
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(10, 10, 10, 0.76);
    opacity: var(--caption-alpha);
    font-variant-numeric: tabular-nums;
    transition: opacity 0.2s ease;
  }

  .work-detroit__caption span:nth-child(2) {
    flex: 1;
    text-align: center;
  }

  .work-detroit__progress {
    position: absolute;
    z-index: 5;
    left: clamp(1.15rem, 2vw, 1.8rem);
    right: clamp(1.15rem, 2vw, 1.8rem);
    bottom: clamp(1rem, 1.6vw, 1.4rem);
    height: 1px;
    background: rgba(10, 10, 10, 0.16);
  }

  .work-detroit__progress span {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
  }

  @media (max-width: 900px) {
    .work-detroit {
      min-height: auto;
    }

    .work-detroit__sticky {
      position: relative;
      min-height: auto;
      padding: 5rem 2rem 6rem;
    }

    .work-detroit__copy {
      width: 100%;
      padding-top: 4rem;
    }

    .work-detroit__title {
      font-size: clamp(4.2rem, 18vw, 8rem);
    }

    .work-detroit__stage {
      position: relative;
      inset: auto;
      height: auto;
      display: flex;
      flex-direction: column;
      gap: 3rem;
      padding-top: 4rem;
    }

    .work-detroit__tile,
    .work-detroit__tile:nth-child(n) {
      position: relative;
      left: auto;
      top: auto;
      width: min(100%, 25rem);
      height: auto;
      transform: none;
    }

    .work-detroit__tile:nth-child(even) {
      align-self: flex-end;
    }

    .work-detroit__media {
      aspect-ratio: 1;
      height: auto;
    }

    .work-detroit__caption {
      opacity: 1;
    }

    .work-detroit__progress {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .work-detroit__sticky {
      padding: 4.5rem 2rem 5.5rem;
    }

    .work-detroit__topline {
      font-size: 0.62rem;
      line-height: 1.35;
    }

    .work-detroit__intro {
      max-width: 21rem;
      font-size: 1rem;
    }

    .work-detroit__tile,
    .work-detroit__tile:nth-child(even) {
      align-self: center;
      width: min(100%, 21rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-detroit {
      min-height: auto;
    }

    .work-detroit__sticky {
      position: relative;
    }

    .work-detroit__tile {
      transform: none;
    }

    .work-detroit__caption {
      opacity: 1;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupWorkDetroit: (() => void) | null = null;

  function initWorkDetroit() {
    cleanupWorkDetroit?.();

    const section = document.getElementById('work-detroit');
    if (!section) return;

    const tiles = Array.from(section.querySelectorAll<HTMLElement>('[data-work-detroit-tile]'));
    const progress = section.querySelector<HTMLElement>('[data-work-detroit-progress]');
    const ac = new AbortController();
    const triggers: ScrollTrigger[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 900px)').matches;
    let currentProgress = 0;

    const visibleSlots = 5;
    const hiddenSlot = visibleSlots;
    const minHeightRatio = 0.05;
    const maxHeightRatio = 0.7;
    const aspectRatio = 1.1;
    const seamOverlap = 1;
    const rotationCount = 2;

    const positiveModulo = (value: number, divisor: number) => ((value % divisor) + divisor) % divisor;
    const lerp = (start: number, end: number, amount: number) => start + ((end - start) * amount);

    const setRailState = (progressValue: number) => {
      currentProgress = progressValue;
      const viewportWidth = window.innerWidth;
      const viewportHeight = window.innerHeight;
      const eased = gsap.parseEase('none')(progressValue);
      const slotShift = eased * hiddenSlot * rotationCount;
      const slotHeights = Array.from({ length: visibleSlots + 1 }, (_, slot) => {
        const ratio = minHeightRatio + ((maxHeightRatio - minHeightRatio) * (slot / hiddenSlot));
        return viewportHeight * ratio;
      });
      const slotWidths = slotHeights.map((height) => height * aspectRatio);
      const slotLefts = slotWidths.reduce<number[]>((lefts, width, index) => {
        if (index === 0) {
          lefts.push(-Math.min(24, width * 0.42));
          return lefts;
        }

        lefts.push(lefts[index - 1] + slotWidths[index - 1]);
        return lefts;
      }, []);
      const finalRight = slotLefts[visibleSlots - 1] + slotWidths[visibleSlots - 1];
      const rightCorrection = viewportWidth + Math.min(24, slotWidths[visibleSlots - 1] * 0.08) - finalRight;
      const correctedLefts = slotLefts.map((left, slot) => {
        const correctionAmount = Math.min(slot / (visibleSlots - 1), 1);
        return left + (rightCorrection * correctionAmount);
      });
      const correctedWidths = correctedLefts.map((left, slot) => {
        if (slot >= hiddenSlot) return slotWidths[slot];
        return correctedLefts[slot + 1] - left;
      });

      tiles.forEach((tile, index) => {
        const slot = positiveModulo(index + slotShift, tiles.length);
        const slotStart = Math.floor(slot);
        const slotProgress = slot - slotStart;
        const nextSlot = Math.min(slotStart + 1, hiddenSlot);
        const left = lerp(correctedLefts[slotStart] ?? correctedLefts[hiddenSlot], correctedLefts[nextSlot] ?? correctedLefts[hiddenSlot], slotProgress);
        const width = lerp(correctedWidths[slotStart] ?? correctedWidths[hiddenSlot], correctedWidths[nextSlot] ?? correctedWidths[hiddenSlot], slotProgress);
        const height = lerp(slotHeights[slotStart] ?? slotHeights[hiddenSlot], slotHeights[nextSlot] ?? slotHeights[hiddenSlot], slotProgress);

        tile.style.setProperty('--tile-left', `${left.toFixed(2)}px`);
        tile.style.setProperty('--tile-width', `${(width + seamOverlap).toFixed(2)}px`);
        tile.style.setProperty('--tile-height', `${height.toFixed(2)}px`);
        tile.style.setProperty('--rail-x', '0px');
        tile.style.opacity = slot <= hiddenSlot - 0.02 ? '1' : '0';
        tile.style.zIndex = slot <= hiddenSlot - 0.02 ? String(Math.round(slot * 10) + 1) : '0';
      });

      progress?.style.setProperty('transform', `scaleX(${progressValue.toFixed(4)})`);
    };

    const setTileProgress = (progressValue: number) => {
      setRailState(progressValue);
    };

    if (!prefersReducedMotion && !isMobile) {
      setTileProgress(0);
      const trigger = ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 0.8,
        onUpdate: (self) => setTileProgress(self.progress),
      });
      triggers.push(trigger);
    } else if (isMobile) {
      tiles.forEach((tile) => tile.style.setProperty('--caption-alpha', '1'));
    } else {
      setTileProgress(0);
    }

    tiles.forEach((tile) => {
      tile.addEventListener('pointerenter', () => tile.style.setProperty('--caption-alpha', '1'), { signal: ac.signal });
      tile.addEventListener('pointerleave', () => {
        if (isMobile || prefersReducedMotion) {
          tile.style.setProperty('--caption-alpha', '1');
          return;
        }

        setRailState(currentProgress);
      }, { signal: ac.signal });
    });

    cleanupWorkDetroit = () => {
      triggers.forEach((trigger) => trigger.kill());
      ac.abort();
    };
  }

  initWorkDetroit();
  document.addEventListener('astro:after-swap', initWorkDetroit);
</script>
