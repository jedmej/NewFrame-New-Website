---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="services"
  class="relative py-32 md:py-48"
>
  <div class="px-6 md:px-10 max-w-[1400px] mx-auto">
    <!-- Section label -->
    <div class="mb-12 md:mb-20">
      <h2 class="text-mono-xs text-[var(--color-text)]">{t.services.label}</h2>
      <div class="mt-4 w-full h-px bg-[var(--color-line)]" data-line></div>
    </div>

    <div class="services-header">
      <h2 class="services-heading">{t.services.heading}</h2>
      <p class="services-intro">{t.services.intro}</p>
    </div>

    <!-- Services grouped by category -->
    <div class="services-list">
      {t.services.groups.map((group, gi) => (
        <div class="service-group" data-group={gi}>
          <div class="service-group-inner">
            {/* Left: sticky category heading */}
            <div class="service-category-col">
              <div class="service-category-block">
                <h3 class="service-category">
                  <span class="service-category-index">{String(gi + 1).padStart(2, '0')}.</span>
                  <span>{group.category}</span>
                </h3>
                <p class="service-description">{group.description}</p>
              </div>
            </div>

            {/* Right: service items */}
            <div class="service-items-col">
              {group.items.map((service, si) => (
                <div class="service-row group" data-group-index={gi} data-item-index={si}>
                  <div class="service-row-inner">
                    <h4 class="service-title">{service.title}</h4>
                  </div>
                  <div class="service-item-line" aria-hidden="true">
                    <div class="service-line-fill"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="services-note text-mono-xs">{t.services.note}</p>
  </div>
</section>

<style>
  .services-header {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    margin-bottom: clamp(4rem, 8vw, 7rem);
  }

  #services {
    background: var(--color-bg);
  }

  @media (min-width: 900px) {
    .services-header {
      grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.6fr);
      align-items: start;
    }
  }

  .services-heading {
    max-width: 54rem;
    font-family: var(--font-serif);
    font-size: clamp(3.25rem, 8vw, 8rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 0;
    color: var(--color-text);
    text-wrap: balance;
  }

  .services-intro {
    max-width: 30rem;
    font-family: var(--font-mono);
    font-size: clamp(1.08rem, 1.12vw, 1.28rem);
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  /* ===== Group layout ===== */
  .service-item-line {
    width: 100%;
    height: 1px;
    overflow: hidden;
  }

  .service-line-fill {
    width: 100%;
    height: 100%;
    background-color: var(--color-line);
    transform: scaleX(0);
    transform-origin: right center;
  }

  .service-group-inner {
    --reveal-opacity: 1;
    --reveal-y: 0px;
    --reveal-blur: 0px;

    display: flex;
    flex-direction: row;
    gap: 0;
    padding-block: clamp(0.85rem, 2vw, 1.4rem);
    opacity: var(--reveal-opacity);
    filter: blur(var(--reveal-blur));
    transform: translate3d(0, var(--reveal-y), 0);
    will-change: transform, opacity, filter;
  }

  /* Left column: sticky category heading */
  .service-category-col {
    width: 35%;
    flex-shrink: 0;
    position: sticky;
    top: 3.5rem;
    align-self: flex-start;
    padding: 1rem 0;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .service-category-col {
      width: 40%;
      padding: 1.5rem 0;
      top: 4.5rem;
    }
  }

  .service-category {
    display: grid;
    gap: 0.65rem;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .service-category-index {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .service-category-block {
    display: grid;
    gap: 1rem;
    max-width: 26rem;
    padding-right: clamp(1rem, 3vw, 3rem);
  }

  .service-description {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 0.9vw, 1.06rem);
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .services-note {
    width: fit-content;
    max-width: 100%;
    margin-top: clamp(3rem, 6vw, 5rem);
    margin-inline: auto;
    color: var(--color-text-subtle);
    text-align: center;
  }

  @media (min-width: 768px) {
    .services-note {
      white-space: nowrap;
    }
  }

  @media (max-width: 767px) {
    .service-group-inner {
      display: grid;
      gap: 1rem;
    }

    .service-category-col {
      width: 100%;
      position: relative;
      top: auto;
    }

    .service-category {
      font-size: clamp(2.05rem, 8.8vw, 2.65rem);
      line-height: 1;
    }

    .service-category-index {
      font-size: 0.9rem;
    }

    .service-row.is-active .service-title {
      color: var(--color-text);
      transform: none;
    }

    .service-row.is-active .service-item-line .service-line-fill {
      background-color: var(--color-line);
    }
  }

  /* Right column: service items */
  .service-items-col {
    flex: 1;
  }

  @media (min-width: 768px) {
    .service-items-col {
      max-width: 50vh;
      margin-left: auto;
    }
  }

  .service-row-inner {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 0.875rem 0;
    cursor: default;
  }

  @media (min-width: 768px) {
    .service-row-inner {
      padding: 1.25rem 0;
    }
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 1.8vw, 2rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text);
    transition: transform 0.6s var(--ease-out-expo), color 0.5s var(--ease-out-expo);
    text-wrap: balance;
  }

  @media (max-width: 767px) {
    .service-title {
      font-size: clamp(1.75rem, 7.5vw, 2.35rem);
      line-height: 1.08;
    }
  }

  .service-row:hover .service-title,
  .service-row.is-active .service-title {
    transform: translateX(-4px);
    color: var(--color-accent);
  }

  .service-row:hover .service-item-line .service-line-fill,
  .service-row.is-active .service-item-line .service-line-fill {
    background-color: var(--color-accent);
    transform: scaleX(1) !important;
    transition: transform 0.6s var(--ease-out-expo), background-color 0.3s;
  }

  .service-group-inner.is-revealed {
    will-change: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-group-inner {
      --reveal-opacity: 1;
      --reveal-y: 0px;
      --reveal-blur: 0px;
      will-change: auto;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';

  gsap.registerPlugin(ScrollTrigger, ScrambleTextPlugin);

  let cleanupFn: (() => void) | null = null;

  function initServices() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('services');
    if (!section) return;

    const ac = new AbortController();
    const { signal } = ac;
    const scrollTriggers: ScrollTrigger[] = [];
    const timelines: gsap.core.Timeline[] = [];

    const rows = section.querySelectorAll('.service-row');
    const allLineFills = section.querySelectorAll('.service-line-fill');
    const lines = section.querySelectorAll('[data-line]');
    const labelBlock = section.querySelector('#services > div > div:first-child');
    const heading = section.querySelector('.services-heading');
    const intro = section.querySelector('.services-intro');
    const groups = Array.from(section.querySelectorAll<HTMLElement>('.service-group-inner'));
    const note = section.querySelector('.services-note');

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mobileQuery = window.matchMedia('(max-width: 767px)');

    if (prefersReducedMotion) {
      allLineFills.forEach((line) => {
        (line as HTMLElement).style.transform = 'scaleX(1)';
      });
      gsap.set([labelBlock, heading, intro, note, ...groups].filter(Boolean), { clearProps: 'all' });
      cleanupFn = () => ac.abort();
      return;
    }

    gsap.set([labelBlock, heading, intro, note].filter(Boolean), {
      y: 28,
      opacity: 0,
      filter: 'blur(8px)',
    });

    const introTl = gsap.timeline({
      defaults: { ease: 'expo.out' },
      scrollTrigger: {
        trigger: section,
        start: 'top 78%',
        once: true,
      },
    });
    timelines.push(introTl);
    if (introTl.scrollTrigger) scrollTriggers.push(introTl.scrollTrigger);

    introTl
      .to(labelBlock, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.8 }, 0)
      .to(heading, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 1.05 }, 0.16)
      .to(intro, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.95 }, 0.32);

    if (lines.length > 0) {
      gsap.set(lines, { scaleX: 0, transformOrigin: 'left' });
      const lineTween = gsap.to(lines, {
        scaleX: 1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 85%',
          once: true,
        },
      });
      if (lineTween.scrollTrigger) scrollTriggers.push(lineTween.scrollTrigger);
    }

    gsap.set(allLineFills, { scaleX: 0, transformOrigin: 'right center' });

    // Rows and their bottom rules stagger in together.
    rows.forEach((row, i) => {
      const inner = row.querySelector('.service-row-inner');
      const lineFill = row.querySelector('.service-line-fill');
      if (!inner) return;

      const rowTl = gsap.timeline({
        delay: mobileQuery.matches ? 0 : Math.min(i * 0.035, 0.18),
        scrollTrigger: {
          trigger: row,
          start: mobileQuery.matches ? 'top 88%' : 'top 86%',
          once: true,
        },
      });
      timelines.push(rowTl);
      if (rowTl.scrollTrigger) scrollTriggers.push(rowTl.scrollTrigger);

      rowTl.fromTo(
        inner,
        {
          opacity: 0,
          y: mobileQuery.matches ? 22 : 40,
          x: mobileQuery.matches ? 0 : 20,
          filter: 'blur(8px)',
        },
        {
          opacity: 1,
          y: 0,
          x: 0,
          filter: 'blur(0px)',
          duration: mobileQuery.matches ? 0.72 : 0.9,
          ease: 'power3.out',
        },
        0,
      );

      if (lineFill) {
        rowTl.fromTo(
          lineFill,
          { scaleX: 0, transformOrigin: 'right center' },
          {
            scaleX: 1,
            duration: mobileQuery.matches ? 0.74 : 0.95,
            ease: 'power3.inOut',
          },
          mobileQuery.matches ? 0.08 : 0.16,
        );
      }
    });

    // Category blocks fade in
    const categories = section.querySelectorAll('.service-category-block');
    categories.forEach((cat, i) => {
      const tween = gsap.fromTo(
        cat,
        { opacity: 0, y: mobileQuery.matches ? 22 : 30, filter: 'blur(8px)' },
        {
          opacity: 1,
          y: 0,
          filter: 'blur(0px)',
          duration: 0.8,
          ease: 'power3.out',
          delay: mobileQuery.matches ? 0 : 0.2 + i * 0.15,
          scrollTrigger: {
            trigger: cat,
            start: mobileQuery.matches ? 'top 88%' : 'top 85%',
            once: true,
          },
        },
      );
      if (tween.scrollTrigger) scrollTriggers.push(tween.scrollTrigger);
    });

    groups.forEach((group, index) => {
      const revealTrigger = ScrollTrigger.create({
        trigger: group,
        start: 'top bottom',
        end: 'bottom top',
        scrub: 0.45,
        onUpdate: () => {
          const rect = group.getBoundingClientRect();
          const viewport = window.innerHeight;
          const enter = Math.min(1, Math.max(0, (viewport - rect.top) / (viewport * 0.26)));
          const exit = Math.min(1, Math.max(0, rect.bottom / (viewport * 0.26)));
          const reveal = Math.min(enter, exit);
          const y = enter < exit ? (1 - reveal) * (24 + index * 3) : (1 - reveal) * -16;

          group.style.setProperty('--reveal-opacity', reveal.toFixed(3));
          group.style.setProperty('--reveal-y', `${y.toFixed(2)}px`);
          group.style.setProperty('--reveal-blur', `${((1 - reveal) * 13).toFixed(2)}px`);
        },
        onLeave: () => group.classList.add('is-revealed'),
        onEnterBack: () => group.classList.remove('is-revealed'),
      });
      scrollTriggers.push(revealTrigger);
    });

    const isTouch = window.matchMedia('(hover: none)').matches || window.innerWidth < 768;

    if (isTouch && window.innerWidth >= 768) {
      // Touch devices: scroll-triggered active state — only ONE row active at a time
      let activeIndex = -1;

      const activateRow = (index: number) => {
        if (index === activeIndex) return;
        activeIndex = index;
        rows.forEach((r, j) => {
          const el = r as HTMLElement;
          if (j === index) {
            el.classList.add('is-active');
          } else {
            el.classList.remove('is-active');
          }
        });
      };

      const deactivateAll = () => {
        if (activeIndex === -1) return;
        activeIndex = -1;
        rows.forEach((r) => {
          (r as HTMLElement).classList.remove('is-active');
        });
      };

      const servicesList = section.querySelector('.services-list') as HTMLElement;

      scrollTriggers.push(ScrollTrigger.create({
        trigger: servicesList,
        start: 'top 80%',
        end: 'bottom 20%',
        onUpdate: () => {
          const viewportCenter = window.innerHeight * 0.5;
          let closestIndex = -1;
          let closestDist = Infinity;

          rows.forEach((row, i) => {
            const rect = row.getBoundingClientRect();
            const rowCenter = rect.top + rect.height / 2;
            const dist = Math.abs(rowCenter - viewportCenter);
            if (dist < closestDist) {
              closestDist = dist;
              closestIndex = i;
            }
          });

          if (closestIndex >= 0 && closestDist < window.innerHeight * 0.3) {
            activateRow(closestIndex);
          } else {
            deactivateAll();
          }
        },
        onLeave: () => deactivateAll(),
        onLeaveBack: () => deactivateAll(),
      }));
    } else if (!isTouch) {
      const lockScrambleWidth = (el: Element) => {
        const target = el as HTMLElement;
        const width = Math.ceil(target.getBoundingClientRect().width);
        if (width > 0) {
          target.style.display = 'inline-block';
          target.style.minWidth = `${width}px`;
        }
      };

      // Desktop: scramble text on hover
      rows.forEach((row) => {
        const title = row.querySelector('.service-title');
        const titleOriginal = title?.textContent || '';
        if (title) lockScrambleWidth(title);

        row.addEventListener('mouseenter', () => {
          if (title) {
            gsap.to(title, {
              duration: 0.5,
              scrambleText: { text: titleOriginal, chars: 'abcdefghijklmnopqrstuvwxyz', speed: 0.4 },
            });
          }
        }, { signal });
      });
    }

    if (note) {
      const noteTween = gsap.to(note, {
        y: 0,
        opacity: 1,
        filter: 'blur(0px)',
        duration: 0.85,
        ease: 'expo.out',
        scrollTrigger: {
          trigger: note,
          start: 'top 88%',
          once: true,
        },
      });
      if (noteTween.scrollTrigger) scrollTriggers.push(noteTween.scrollTrigger);
    }

    cleanupFn = () => {
      ac.abort();
      timelines.forEach((tl) => tl.kill());
      scrollTriggers.forEach((st) => st.kill());
      gsap.killTweensOf(section.querySelectorAll('*'));
    };
  }

  initServices();
  document.addEventListener('astro:after-swap', initServices);
</script>
