---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const items = t.testimonials.items;
const totalStr = String(items.length).padStart(2, '0');
---

<section
  id="testimonials"
  class="testimonial-horizontal"
  aria-label={t.testimonials.label}
  data-testimonial-total={items.length}
>
  <div class="testimonial-horizontal__scroll">
    <div class="testimonial-horizontal__sticky">
      <div class="testimonial-horizontal__counter text-mono-xs" aria-hidden="true">
        <span id="testimonial-counter-active">01</span>
        <span>/</span>
        <span>{totalStr}</span>
      </div>

      <div class="testimonial-horizontal__stage" data-testimonial-stage>
        {items.map((item, i) => (
          <article
            class="testimonial-card"
            data-testimonial-card
            data-card-index={i}
            style={`--card-index: ${i};`}
          >
            <blockquote class="testimonial-card__quote">
              &ldquo;{item.quote}&rdquo;
            </blockquote>
            <footer class="testimonial-card__footer">
              <span>{item.name}</span>
              <span>{item.role.replace(/^(MANAGER|FOUNDER|ZAŁOŻYCIEL|ZAŁOŻYCIELKA),\s*/u, '')}</span>
            </footer>
          </article>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .testimonial-horizontal {
    --testimonial-ink: #ffffff;
    --testimonial-muted: rgba(255, 255, 255, 0.72);
    --testimonial-faint: rgba(255, 255, 255, 0.18);
    --testimonial-card-width: clamp(18.5rem, 36vw, 32.5rem);
    --testimonial-card-height: clamp(26rem, 62vh, 38.125rem);

    position: relative;
    color: var(--testimonial-ink);
  }

  .testimonial-horizontal__scroll {
    height: calc(100svh + (var(--testimonial-total, 3) * 64svh));
    min-height: 250svh;
  }

  .testimonial-horizontal__sticky {
    position: sticky;
    top: 0;
    display: grid;
    min-height: 100svh;
    grid-template-rows: auto minmax(0, 1fr) auto;
    row-gap: clamp(2.25rem, 6.5vh, 7.75rem);
    align-items: center;
    overflow: clip;
    padding: clamp(7rem, 15vh, 8.5rem) clamp(1.5rem, 5vw, 4.5rem) clamp(6.5rem, 13vh, 8rem);
  }

  .testimonial-horizontal__counter {
    justify-self: center;
    color: color-mix(in srgb, #C43E3D 52%, #ffffff);
    letter-spacing: 0.16em;
    font-variant-numeric: tabular-nums;
  }

  .testimonial-horizontal__stage {
    position: relative;
    width: 100%;
    height: min(62svh, 38.125rem);
    min-height: 31rem;
  }

  .testimonial-card {
    position: absolute;
    top: 50%;
    left: 50%;
    display: flex;
    width: var(--testimonial-card-width);
    height: var(--testimonial-card-height);
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(2rem, 3vw, 2.625rem);
    color: var(--testimonial-ink);
    transform: translate3d(-50%, -50%, 0);
    transform-origin: center;
    will-change: transform, opacity, filter;
  }

  .testimonial-card__quote {
    max-width: 11.5em;
    margin: auto 0;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.2vw, 2.875rem);
    line-height: 1.17;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .testimonial-card__footer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.2;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .testimonial-card__footer span:last-child {
    color: var(--testimonial-muted);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
  }

  @media (max-width: 767px) {
    .testimonial-horizontal__sticky {
      row-gap: clamp(1.75rem, 5vh, 3rem);
      padding: clamp(6.5rem, 14vh, 7.5rem) clamp(1.15rem, 5vw, 1.5rem) clamp(5.25rem, 11vh, 6.5rem);
    }

    .testimonial-horizontal__stage {
      height: 62svh;
      min-height: 28rem;
    }

    .testimonial-card {
      width: min(78vw, 22rem);
      height: min(58svh, 31rem);
      padding: 1.75rem;
    }

    .testimonial-card__quote {
      font-size: clamp(1.65rem, 7.4vw, 2.35rem);
      line-height: 1.12;
    }

  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-horizontal__scroll {
      height: auto;
      min-height: auto;
    }

    .testimonial-horizontal__sticky {
      position: relative;
    }

    .testimonial-horizontal__stage {
      display: grid;
      height: auto;
      min-height: auto;
      gap: 2rem;
    }

    .testimonial-card {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      max-width: 36rem;
      height: auto;
      min-height: 24rem;
      transform: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupFn: (() => void) | null = null;

  function initTestimonials() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('testimonials');
    if (!section) return;

    const ac = new AbortController();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sticky = section.querySelector<HTMLElement>('.testimonial-horizontal__sticky');
    const cards = Array.from(section.querySelectorAll<HTMLElement>('[data-testimonial-card]'));
    const counterActiveEl = document.getElementById('testimonial-counter-active');
    const scrollTriggers: ScrollTrigger[] = [];
    const totalCards = cards.length;

    if (!totalCards) {
      cleanupFn = () => ac.abort();
      return;
    }

    section.style.setProperty('--testimonial-total', String(totalCards));

    const clamp = (value: number) => Math.max(0, Math.min(1, value));
    const smooth = (value: number) => value * value * (3 - 2 * value);
    const interpolate = gsap.utils.interpolate;

    const renderCards = (progress: number) => {
      const exitBuffer = window.innerWidth < 768 ? 0.82 : 0.96;
      const track = progress * (Math.max(totalCards - 1, 1) + exitBuffer);
      const activeIndex = Math.min(totalCards - 1, Math.round(track));
      const exitProgress = clamp((track - Math.max(totalCards - 1, 1)) / exitBuffer);

      if (counterActiveEl) {
        counterActiveEl.textContent = String(activeIndex + 1).padStart(2, '0');
      }

      if (sticky) {
        sticky.style.transform = `translate3d(0, ${(-smooth(exitProgress) * 68).toFixed(2)}vh, 0)`;
      }

      cards.forEach((card, index) => {
        const offset = index - track;
        const absOffset = Math.abs(offset);
        const near = smooth(clamp(1 - absOffset));
        const side = offset < 0 ? -1 : 1;
        const x = offset * (window.innerWidth < 768 ? 74 : 46);
        const opacity = interpolate(0.42, 1, near);
        const blur = interpolate(3.5, 0, near);
        const trail = blur * (window.innerWidth < 768 ? 1.7 : 2.25);
        const trailOpacity = clamp((1 - near) * 0.18, 0, 0.18);
        const directionalBlur = blur > 0.08
          ? `blur(${blur.toFixed(2)}px) drop-shadow(-${trail.toFixed(2)}px 0 ${(trail * 1.1).toFixed(2)}px rgba(255, 255, 255, ${trailOpacity.toFixed(3)}))`
          : 'none';

        card.style.zIndex = String(Math.round(100 - absOffset * 10));
        card.style.opacity = opacity.toFixed(3);
        card.style.filter = directionalBlur;
        card.style.transform = `translate3d(calc(-50% + ${x.toFixed(2)}vw), -50%, 0)`;
        card.style.pointerEvents = absOffset < 0.6 ? 'auto' : 'none';

        if (absOffset > 1.65) {
          card.style.opacity = '0';
          card.style.transform = `translate3d(calc(-50% + ${side * 72}vw), -50%, 0)`;
        }
      });
    };

    renderCards(0);

    if (!prefersReducedMotion) {
      scrollTriggers.push(ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
        invalidateOnRefresh: true,
        onUpdate: (self) => renderCards(self.progress),
        onRefresh: (self) => renderCards(self.progress),
      }));
    } else {
      cards.forEach((card) => {
        card.style.opacity = '1';
        card.style.filter = 'none';
        card.style.transform = 'none';
      });
      if (sticky) sticky.style.transform = 'none';
    }

    cleanupFn = () => {
      scrollTriggers.forEach((st) => st.kill());
      cards.forEach((card) => {
        card.style.removeProperty('z-index');
        card.style.removeProperty('opacity');
        card.style.removeProperty('filter');
        card.style.removeProperty('transform');
        card.style.removeProperty('pointer-events');
      });
      sticky?.style.removeProperty('transform');
      ac.abort();
    };
  }

  initTestimonials();
  document.addEventListener('astro:after-swap', initTestimonials);
</script>
