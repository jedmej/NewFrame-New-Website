---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="hero" class="hero-clean" data-lang={lang} data-nav-tone="light" aria-label={t.hero.title}>
  <div class="hero-clean__content">
    <p class="hero-clean__credit">{t.hero.credit}</p>

    <div class="hero-clean__statement-wrap">
      <h1 id="hero-title" class="hero-clean__statement">
        {t.hero.statement}
      </h1>
    </div>
  </div>
</section>

<style>
  .hero-clean {
    position: relative;
    display: flex;
    min-height: 100svh;
    overflow: clip;
    isolation: isolate;
    background: transparent;
    color: var(--color-text);
  }

  .hero-clean__content {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
    min-height: 100svh;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(7.25rem, 13svh, 8.5rem) clamp(1.25rem, 3vw, 2.625rem) clamp(5rem, 8svh, 7rem);
  }

  .hero-clean__statement-wrap {
    display: flex;
    width: min(100%, 44rem);
    flex-direction: column;
    gap: clamp(1.25rem, 3svh, 2.125rem);
  }

  .hero-clean__statement {
    max-width: 10.8ch;
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(4.2rem, 7.35vw, 6.625rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 0.962;
    text-wrap: balance;
  }

  .hero-clean__statement :global(.hero-line) {
    display: block;
    overflow: hidden;
    padding-bottom: 0.04em;
    margin-bottom: -0.04em;
  }

  .hero-clean__statement :global(.hero-line-inner) {
    display: block;
    will-change: transform, opacity, filter;
  }

  .hero-clean__credit {
    max-width: 34rem;
    margin: 0;
    align-self: flex-end;
    color: rgba(20, 18, 15, 0.62);
    font-family: var(--font-mono);
    font-size: clamp(0.68rem, 0.88vw, 0.8125rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.25;
    text-align: right;
    text-transform: uppercase;
  }

  @media (max-width: 1023px) {
    .hero-clean__content {
      padding-top: calc(max(0.875rem, env(safe-area-inset-top)) + 6rem);
    }

    .hero-clean__statement {
      max-width: 9.8ch;
      font-size: clamp(3.85rem, 12.5vw, 6.2rem);
    }
  }

  @media (max-width: 767px) {
    .hero-clean__content {
      padding-right: 1.25rem;
      padding-bottom: clamp(2.25rem, 6svh, 3.5rem);
      padding-left: 1.25rem;
    }

    .hero-clean__statement-wrap {
      gap: 1.15rem;
    }

    .hero-clean__statement {
      max-width: 9.4ch;
      font-size: clamp(3.4rem, 15.5vw, 4.9rem);
      line-height: 0.97;
    }

    .hero-clean__credit {
      max-width: 17rem;
      font-size: 0.68rem;
      line-height: 1.45;
      text-align: left;
      align-self: flex-start;
    }
  }

  @media (max-height: 760px) and (min-width: 768px) {
    .hero-clean__statement {
      font-size: clamp(3.7rem, 6.7vw, 5.7rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-clean__statement :global(.hero-line-inner) {
      will-change: auto;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(SplitText);

  let cleanupFn: (() => void) | null = null;

  function initHero() {
    cleanupFn?.();
    cleanupFn = null;

    const hero = document.getElementById('hero');
    const title = document.getElementById('hero-title');
    const credit = hero?.querySelector('.hero-clean__credit');
    const ac = new AbortController();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const splitInstances: SplitText[] = [];
    const timelines: gsap.core.Timeline[] = [];

    if (!hero || !title || prefersReducedMotion) {
      gsap.set([title, credit].filter(Boolean), { clearProps: 'all' });
      cleanupFn = () => ac.abort();
      return;
    }

    const split = new SplitText(title, {
      type: 'lines',
      linesClass: 'hero-line',
      mask: 'lines',
    });
    splitInstances.push(split);

    split.lines.forEach((line) => {
      const inner = document.createElement('span');
      inner.className = 'hero-line-inner';
      while (line.firstChild) inner.appendChild(line.firstChild);
      line.appendChild(inner);
    });

    const lineInners = split.lines
      .map((line) => line.querySelector('.hero-line-inner'))
      .filter((line): line is HTMLElement => line instanceof HTMLElement);

    gsap.set(lineInners, {
      yPercent: 112,
      opacity: 0,
      filter: 'blur(10px)',
    });
    gsap.set(credit, {
      y: 14,
      opacity: 0,
      filter: 'blur(6px)',
    });

    const tl = gsap.timeline({
      defaults: { ease: 'expo.out' },
      onComplete: () => {
        gsap.set([credit, ...lineInners].filter(Boolean), { clearProps: 'willChange,filter,transform,opacity' });
      },
    });
    timelines.push(tl);

    tl.to(lineInners, {
        yPercent: 0,
        opacity: 1,
        filter: 'blur(0px)',
        duration: 1.08,
        stagger: 0.08,
      }, 0.12)
      .to(credit, {
        y: 0,
        opacity: 1,
        filter: 'blur(0px)',
        duration: 0.9,
      }, 0.42);

    cleanupFn = () => {
      timelines.forEach((timeline) => timeline.kill());
      gsap.killTweensOf([credit, ...lineInners].filter(Boolean));
      splitInstances.forEach((splitInstance) => splitInstance.revert());
      ac.abort();
    };
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
