---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  data-lang={lang}
  class="relative w-full min-h-[100svh] flex flex-col overflow-hidden"
>
  <canvas id="hero-background-shader-canvas" class="hero-background-shader" aria-hidden="true"></canvas>

  <div class="hero-shell relative flex w-full min-h-[100svh] flex-col">
    <div class="hero-grid">
      <div class="hero-panel hero-panel--title">
        <div id="hero-offer" class="hero-offer">
          <h1
            id="hero-title"
            class="hero-offer__statement"
            aria-label={t.hero.statement}
          >
            {t.hero.statement}
          </h1>
          <p class="hero-offer__subcopy">{t.hero.subcopy}</p>
          <div class="hero-offer__actions">
            <a href={`/${lang}/#contact`} class="hero-offer__link hero-offer__link--primary" data-cursor="CLICK">
              <svg viewBox="0 0 12 12" aria-hidden="true">
                <path d="M1 11L11 1M11 1H3M11 1V9" />
              </svg>
              <span>{t.hero.primaryCta}</span>
            </a>
            <span class="hero-offer__divider" aria-hidden="true"></span>
            <a href={`/${lang}/#work`} class="hero-offer__link" data-cursor="CLICK">{t.hero.secondaryCta}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-shell {
    z-index: 2;
    padding-top: 5rem;
  }

  #hero {
    isolation: isolate;
    background: var(--color-bg);
  }

  .hero-background-shader {
    position: absolute;
    display: block;
    pointer-events: none;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    opacity: 1;
  }

  .hero-grid {
    display: flex;
    flex: 1 0 auto;
    flex-direction: column;
    width: 100%;
    min-height: calc(100svh - 10.5rem);
  }

  .hero-panel {
    min-width: 0;
  }

  .hero-panel--title {
    display: flex;
    flex: 1;
    min-height: 0;
    align-items: center;
    padding: clamp(2rem, 8svh, 4rem) 1.5rem clamp(2.75rem, 9svh, 4.75rem);
  }

  .hero-offer {
    display: flex;
    width: min(100%, 62rem);
    flex-direction: column;
    color: var(--color-text);
    text-align: left;
    text-shadow:
      0 0.08em 0.34em rgba(239, 235, 226, 0.32),
      0 1rem 3rem rgba(239, 235, 226, 0.22);
  }

  .hero-offer__statement {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(3.25rem, 15vw, 6.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .hero-offer__statement span {
    font-style: italic;
  }

  .hero-offer__subcopy {
    max-width: 36rem;
    margin: 1.5rem 0 0;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: clamp(1rem, 4.4vw, 1.1875rem);
    font-weight: 400;
    line-height: 1.58;
    letter-spacing: -0.01em;
    text-wrap: pretty;
  }

  .hero-offer__actions {
    display: flex;
    width: 100%;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-offer__link {
    display: inline-flex;
    min-height: 3.25rem;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid currentColor;
    padding: 0 0 1rem;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    line-height: 1;
    text-transform: uppercase;
  }

  .hero-offer__link svg {
    width: 0.95rem;
    height: 0.95rem;
    flex: 0 0 auto;
    margin-right: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .hero-offer__divider {
    display: none;
  }

  .hero-offer__link:hover,
  .hero-offer__link:focus-visible {
    color: var(--color-accent);
  }

  .hero-offer__link--primary {
    color: var(--color-accent);
  }

  @media (min-width: 1024px) {
    .hero-shell {
      padding-top: 5.875rem;
    }

    .hero-grid {
      min-height: calc(100svh - 5.875rem);
    }

    .hero-panel {
      min-height: calc(100svh - 5.875rem);
    }

    .hero-panel--title {
      align-items: stretch;
      border-left: 1px solid var(--color-border-strong);
      padding: clamp(3rem, 5.2vw, 4rem) clamp(3rem, 4.8vw, 5.5rem) clamp(3rem, 5.6vh, 4.5rem);
    }

    .hero-offer {
      display: grid;
      width: 100%;
      min-height: 100%;
      grid-template-columns: minmax(0, 30rem) minmax(12rem, 1fr) minmax(0, 24rem);
      grid-template-rows: auto 1fr auto;
      column-gap: clamp(2rem, 5vw, 6rem);
      align-items: start;
    }

    .hero-offer__statement {
      grid-column: 1;
      max-width: none;
      font-size: clamp(2.95rem, 3.58vw, 4.85rem);
      line-height: 0.94;
      text-align: left;
    }

    #hero[data-lang='pl'] .hero-offer__statement {
      max-width: none;
      font-size: clamp(2.75rem, 3.35vw, 4.55rem);
    }

    .hero-offer__subcopy {
      grid-column: 3;
      max-width: none;
      margin: clamp(0.25rem, 1.2vh, 1rem) 0 0;
      font-size: clamp(0.875rem, 0.92vw, 1.05rem);
      line-height: 1.52;
      text-align: right;
    }

    .hero-offer__actions {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: flex-start;
      justify-content: center;
      gap: clamp(2.75rem, 4.8vw, 5.5rem);
      width: min(100%, 72rem);
      margin: auto auto 0;
    }

    .hero-offer__link {
      min-height: 3.25rem;
      padding-bottom: 1rem;
      font-size: 0.8125rem;
      white-space: nowrap;
    }

    .hero-offer__link--primary {
      width: min(34vw, 32rem);
      justify-content: center;
    }

    .hero-offer__link:not(.hero-offer__link--primary) {
      width: min(34vw, 32rem);
    }

    .hero-offer__divider {
      display: block;
      width: 1px;
      height: 3rem;
      flex: 0 0 auto;
      background-color: var(--color-border-strong);
    }

  }

  @media (min-width: 1536px) {
    .hero-panel--title {
      padding-right: clamp(4.5rem, 5vw, 6rem);
      padding-left: clamp(4.5rem, 5vw, 6rem);
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-shell {
      padding-top: 5rem;
    }

    .hero-grid {
      min-height: calc(100svh - 5rem);
    }

    .hero-panel--title {
      align-items: stretch;
      padding: clamp(3rem, 6svh, 4.25rem) 3rem clamp(3.75rem, 7svh, 5rem);
    }

    .hero-offer {
      min-height: 100%;
      display: grid;
      grid-template-rows: auto 1fr auto auto;
      justify-content: stretch;
    }

    .hero-offer__statement {
      max-width: 42rem;
      font-size: clamp(4rem, 8.6vw, 5.55rem);
      line-height: 0.92;
    }

    .hero-offer__subcopy {
      max-width: 42rem;
      align-self: end;
      margin-top: clamp(13rem, 30svh, 19rem);
    }

    .hero-offer__actions {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
      margin-top: clamp(1.5rem, 3svh, 2.25rem);
    }

    .hero-offer__link--primary {
      flex: 1 1 0;
      width: auto;
      justify-content: flex-start;
    }

    .hero-offer__link:not(.hero-offer__link--primary) {
      flex: 0 1 13rem;
      width: auto;
    }

    .hero-offer__divider {
      display: block;
      width: 1px;
      height: 3rem;
      flex: 0 0 auto;
      background-color: var(--color-border-strong);
    }

  }

  @media (min-width: 860px) and (max-width: 1023px) {
    .hero-panel--title {
      padding-top: clamp(1.5rem, 3svh, 2.25rem);
    }

    .hero-offer__statement {
      max-width: 40rem;
      font-size: clamp(4.4rem, 7.35vw, 4.85rem);
      line-height: 0.88;
    }
  }

  @media (max-width: 767px) {
    .hero-shell {
      padding-top: 4.75rem;
    }

    .hero-grid {
      min-height: calc(100svh - 4.75rem);
    }

    .hero-panel--title {
      align-items: stretch;
      padding: clamp(1.85rem, 5.6svh, 3rem) 1.5rem clamp(1.75rem, 5svh, 3rem);
    }

    .hero-offer {
      min-height: 100%;
      display: grid;
      grid-template-rows: auto 1fr auto auto;
      justify-content: stretch;
    }

    .hero-offer__statement {
      font-size: clamp(3.25rem, 14.2vw, 4.65rem);
      max-width: min(100%, 23rem);
      line-height: 0.92;
    }

    .hero-offer__subcopy {
      max-width: 25rem;
      align-self: end;
      margin-top: clamp(7rem, 24svh, 13.5rem);
      font-size: 1rem;
      line-height: 1.55;
    }

    .hero-offer__actions {
      margin-top: 1.35rem;
    }

    .hero-offer__link {
      font-size: 0.625rem;
      letter-spacing: 0.14em;
      line-height: 1.15;
    }

  }

  @media (max-height: 760px) {
    .hero-offer__subcopy {
      margin-top: clamp(2rem, 9svh, 4rem);
    }

    .hero-offer__actions {
      margin-top: 1.25rem;
    }
  }

  @media (min-width: 1024px) and (max-height: 760px) {
    .hero-panel--title {
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
    }

    .hero-offer__statement {
      font-size: clamp(4.25rem, 5.4vw, 5.8rem);
    }
  }

</style>

<script>
  import type { ShaderInstance } from 'shaders/js';

  let cleanupFn: (() => void) | null = null;

  function initHero() {
    cleanupFn?.();
    cleanupFn = null;

    const shaderCanvas = document.getElementById('hero-background-shader-canvas') as HTMLCanvasElement | null;
    const ac = new AbortController();
    const { signal } = ac;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let shaderInstance: ShaderInstance | null = null;
    let shaderDisposed = false;
    let shaderResizeFrame = 0;
    let shaderResizeObserver: ResizeObserver | null = null;

    const resizeShaderToCanvas = () => {
      shaderResizeFrame = 0;
      if (!shaderCanvas || !shaderInstance || shaderDisposed) return;

      shaderCanvas.style.width = '';
      shaderCanvas.style.height = '';
      const rect = shaderCanvas.getBoundingClientRect();
      if (rect.width > 0 && rect.height > 0) {
        shaderInstance.resize(Math.round(rect.width), Math.round(rect.height));
      }
    };

    const scheduleShaderResize = () => {
      if (shaderResizeFrame) window.cancelAnimationFrame(shaderResizeFrame);
      shaderResizeFrame = window.requestAnimationFrame(resizeShaderToCanvas);
    };

    if (shaderCanvas && !prefersReducedMotion) {
      shaderCanvas.style.width = '';
      shaderCanvas.style.height = '';
      import('shaders/js').then(({ createShader }) => createShader(shaderCanvas, {
        components: [
          {
            type: 'Swirl',
            id: 'idmopuqc7pml2j3z58j',
            props: {
              colorA: '#EFEAE1',
              colorB: '#dbd3c5',
              detail: 1.7,
              visible: true,
            },
          },
          {
            type: 'ImageTexture',
            id: 'idmp8izvgso13bcjfkh',
            props: {
              objectFit: 'none',
              url: new URL('/images/newframe-logo.svg', window.location.origin).href,
              transform: {
                scale: 0.5,
              },
            },
          },
          {
            type: 'ChromaFlow',
            id: 'idlr5w8x2qm9k3v7n2a',
            props: {
              baseColor: '#18181a',
              downColor: '#6600ff',
              leftColor: '#aa00ee',
              momentum: 13,
              rightColor: '#ff0066',
              upColor: '#ff00aa',
              visible: false,
            },
          },
          {
            type: 'FlutedGlass',
            id: 'idmopubojpm8gm5raws',
            props: {
              angle: 0,
              aberration: 0.5,
              blendMode: 'normal',
              edges: 'stretch',
              frequency: 6,
              highlight: 0.12,
              highlightColor: '#ffffff',
              highlightSoftness: 0,
              lightAngle: 30,
              maskType: 'alpha',
              opacity: 1,
              refraction: 1.5,
              shape: 'waves',
              softness: 0,
              speed: 0.2,
              transform: {
                offsetX: 0,
                offsetY: 0,
                rotation: 0,
                scale: 1,
                anchorX: 0.5,
                anchorY: 0.5,
                edges: 'transparent',
              },
              waveAmplitude: 0.05,
              waveFrequency: 1.8,
              visible: true,
            },
          },
          {
            type: 'FilmGrain',
            id: 'idmopv498snizgmx7xn',
            props: {
              strength: 0.05,
              visible: true,
            },
          },
          {
            type: 'CursorRipples',
            id: 'idmp8j8cmkjmxa4rvkv',
            props: {
              chromaticSplit: 3,
              decay: 20,
              intensity: 11.6,
            },
          },
        ],
      })).then((shader) => {
        if (shaderDisposed) {
          shader.destroy();
          return;
        }
        shaderInstance = shader;
        resizeShaderToCanvas();
        window.addEventListener('resize', scheduleShaderResize, { signal });
        window.addEventListener('orientationchange', scheduleShaderResize, { signal });
        shaderResizeObserver = new ResizeObserver(scheduleShaderResize);
        shaderResizeObserver.observe(shaderCanvas.parentElement ?? shaderCanvas);
      }).catch((error) => {
        console.warn('Hero shader failed to initialize', error);
      });
    }

    cleanupFn = () => {
      shaderDisposed = true;
      if (shaderResizeFrame) window.cancelAnimationFrame(shaderResizeFrame);
      shaderResizeObserver?.disconnect();
      shaderInstance?.destroy();
      ac.abort();
    };
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
