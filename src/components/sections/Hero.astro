---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="hero" class="hero-clean" data-lang={lang} data-nav-tone="light" aria-label={t.hero.title}>
  <a class="hero-clean__center-wordmark" href={`/${lang}/`} data-hero-wordmark aria-label="NewFrame">
    <span class="hero-clean__center-logo-text" aria-hidden="true">
      NewFrame<sup>®</sup>
    </span>
  </a>

  <div class="hero-clean__content">
    <p class="hero-clean__credit">{t.hero.credit}</p>

    <div class="hero-clean__statement-wrap">
      <h1 id="hero-title" class="hero-clean__statement">
        {t.hero.statement}
      </h1>
    </div>
  </div>
</section>

<style>
  .hero-clean {
    position: relative;
    display: flex;
    min-height: 100svh;
    overflow: visible;
    background: transparent;
    color: var(--color-text);
  }

  .hero-clean__center-wordmark {
    position: fixed;
    top: 50%;
    left: 50%;
    z-index: 121;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text);
    transition: color 0.24s var(--ease-out-quart);
    text-decoration: none;
    transform: translate3d(-50%, -50%, 0);
    transform-origin: center;
    will-change: transform;
  }

  .hero-clean__center-logo-text {
    display: block;
    color: currentColor;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .hero-clean__center-logo-text sup {
    margin-left: 0.125rem;
    font-size: 0.5em;
    line-height: 0;
    opacity: 0.4;
    vertical-align: super;
  }

  .hero-clean__content {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
    min-height: 100svh;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(7.25rem, 13svh, 8.5rem) clamp(1.25rem, 3vw, 2.625rem) clamp(5rem, 8svh, 7rem);
  }

  .hero-clean__statement-wrap {
    display: flex;
    width: min(100%, 44rem);
    flex-direction: column;
    gap: clamp(1.25rem, 3svh, 2.125rem);
    will-change: transform, opacity, filter;
  }

  .hero-clean__statement {
    max-width: 10.8ch;
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(4.2rem, 7.35vw, 6.625rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 0.962;
    text-wrap: balance;
  }

  .hero-clean__statement :global(.hero-line) {
    display: block;
    overflow: hidden;
    padding-bottom: 0.04em;
    margin-bottom: -0.04em;
    transform-origin: left center;
    will-change: transform, opacity, filter;
  }

  .hero-clean__statement :global(.hero-line-inner) {
    display: block;
    will-change: transform, opacity, filter;
  }

  .hero-clean__credit {
    max-width: 34rem;
    margin: 0;
    align-self: flex-end;
    color: rgba(20, 18, 15, 0.62);
    font-family: var(--font-mono);
    font-size: clamp(0.68rem, 0.88vw, 0.8125rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.25;
    text-align: right;
    text-transform: uppercase;
  }

  @media (max-width: 1023px) {
    .hero-clean__center-wordmark {
      position: absolute;
      z-index: 3;
      pointer-events: none;
    }

    .hero-clean__content {
      padding-top: calc(max(0.875rem, env(safe-area-inset-top)) + 6rem);
    }

    .hero-clean__statement {
      max-width: 9.8ch;
      font-size: clamp(3.85rem, 12.5vw, 6.2rem);
    }
  }

  @media (max-width: 767px) {
    .hero-clean__content {
      padding-right: 2rem;
      padding-bottom: clamp(2.25rem, 6svh, 3.5rem);
      padding-left: 2rem;
    }

    .hero-clean__statement-wrap {
      gap: 1.15rem;
    }

    .hero-clean__statement {
      max-width: 9.4ch;
      font-size: clamp(3.4rem, 15.5vw, 4.9rem);
      line-height: 0.97;
    }

    .hero-clean__credit {
      max-width: 17rem;
      margin-left: auto;
      font-size: 0.68rem;
      line-height: 1.45;
      text-align: right;
      align-self: flex-end;
    }
  }

  @media (max-height: 760px) and (min-width: 768px) {
    .hero-clean__statement {
      font-size: clamp(3.7rem, 6.7vw, 5.7rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-clean__statement :global(.hero-line-inner) {
      will-change: auto;
    }

    .hero-clean__statement :global(.hero-line),
    .hero-clean__statement-wrap {
      will-change: auto;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { SplitText } from 'gsap/SplitText';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(SplitText, ScrollTrigger);

  let cleanupFn: (() => void) | null = null;

  function initHero() {
    cleanupFn?.();
    cleanupFn = null;

    const hero = document.getElementById('hero');
    const title = document.getElementById('hero-title');
    const credit = hero?.querySelector('.hero-clean__credit');
    const wordmark = hero?.querySelector<HTMLElement>('[data-hero-wordmark]');
    const wordmarkText = wordmark?.querySelector<HTMLElement>('.hero-clean__center-logo-text');
    const ac = new AbortController();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const splitInstances: SplitText[] = [];
    const scrollTriggers: ScrollTrigger[] = [];
    const timelines: gsap.core.Timeline[] = [];
    const wordmarkPlaceholder = document.createComment('hero-wordmark-position');
    const wordmarkOriginalParent = wordmark?.parentNode ?? null;

    if (!hero || !title || prefersReducedMotion) {
      gsap.set([title, credit, wordmark, wordmarkText].filter(Boolean), { clearProps: 'all' });
      cleanupFn = () => ac.abort();
      return;
    }

    if (wordmark && wordmarkOriginalParent && wordmark.parentElement !== document.body) {
      wordmarkOriginalParent.insertBefore(wordmarkPlaceholder, wordmark);
      document.body.appendChild(wordmark);
    }

    const split = new SplitText(title, {
      type: 'lines',
      linesClass: 'hero-line',
    });
    splitInstances.push(split);

    split.lines.forEach((line) => {
      const inner = document.createElement('span');
      inner.className = 'hero-line-inner';
      while (line.firstChild) inner.appendChild(line.firstChild);
      line.appendChild(inner);
    });

    const lineInners = split.lines
      .map((line) => line.querySelector('.hero-line-inner'))
      .filter((line): line is HTMLElement => line instanceof HTMLElement);
    const lineMasks = split.lines.filter((line): line is HTMLElement => line instanceof HTMLElement);

    gsap.set(lineInners, {
      yPercent: 112,
      opacity: 0,
      filter: 'blur(10px)',
    });
    gsap.set(credit, {
      y: 14,
      opacity: 0,
    });
    gsap.set(lineMasks, {
      y: 0,
      yPercent: 0,
      opacity: 1,
      filter: 'blur(0px)',
      transformOrigin: 'left center',
    });

    if (wordmark) {
      gsap.set(wordmark, {
        xPercent: -50,
        yPercent: -50,
        x: 0,
        y: 0,
        opacity: 1,
        filter: 'blur(0px)',
      });
    }

    if (wordmarkText) {
      gsap.set(wordmarkText, { fontSize: '1.75rem' });
    }

    const tl = gsap.timeline({
      defaults: { ease: 'expo.out' },
      onComplete: () => {
        gsap.set(lineMasks, { overflow: 'visible' });
        gsap.set(lineInners, { clearProps: 'willChange' });
        gsap.set(credit, { clearProps: 'willChange,filter' });
      },
    });
    timelines.push(tl);

    tl.to(lineInners, {
        yPercent: 0,
        opacity: 1,
        filter: 'blur(0px)',
        duration: 1.08,
        stagger: 0.08,
      }, 0.12)
      .to(credit, {
        y: 0,
        opacity: 1,
        duration: 0.9,
      }, 0.42);

    const exitTl = gsap.timeline({ paused: true, defaults: { ease: 'none' } });
    timelines.push(exitTl);

    exitTl.set(lineMasks, { overflow: 'visible' }, 0);

    lineMasks.forEach((line, index) => {
      const lineDepth = Math.max(0, lineMasks.length - 1 - index);
      exitTl.to(line, {
        y: () => -window.innerHeight * (0.018 + lineDepth * 0.024),
        yPercent: -26 - lineDepth * 18,
        opacity: 0,
        filter: `blur(${7 + lineDepth * 3}px)`,
        duration: 0.62,
      }, index * 0.055);
    });

    exitTl
      .to(credit, {
        y: () => -window.innerHeight * 0.06,
        opacity: 0,
        duration: 0.52,
      }, 0)
      .to('.hero-clean__statement-wrap', {
        y: () => -window.innerHeight * 0.025,
        duration: 0.72,
      }, 0.02);

    const exitTrigger = ScrollTrigger.create({
      trigger: hero,
      start: 'top top',
      end: 'bottom top',
      scrub: 0.2,
      animation: exitTl,
      invalidateOnRefresh: true,
    });
    scrollTriggers.push(exitTrigger);

    if (wordmark && window.innerWidth >= 1024) {
      const wordmarkTl = gsap.timeline({ paused: true, defaults: { ease: 'none' } });
      timelines.push(wordmarkTl);

      wordmarkTl.to(wordmark, {
        x: () => {
          const navBrand = document.getElementById('logo-link');
          const navRect = navBrand?.getBoundingClientRect();
          if (!navRect) return 0;
          return navRect.left + navRect.width / 2 - window.innerWidth / 2;
        },
        y: () => {
          const navBrand = document.getElementById('logo-link');
          const navRect = navBrand?.getBoundingClientRect();
          if (!navRect) return 0;
          return navRect.top + navRect.height / 2 - window.innerHeight / 2;
        },
        duration: 1,
      }, 0);

      if (wordmarkText) {
        wordmarkTl.to(wordmarkText, {
          fontSize: '0.875rem',
          duration: 1,
        }, 0);
      }

      const wordmarkTrigger = ScrollTrigger.create({
        trigger: hero,
        start: 'top top',
        end: () => `+=${Math.max(220, window.innerHeight * 0.42)}`,
        scrub: 0.65,
        animation: wordmarkTl,
        invalidateOnRefresh: true,
      });
      scrollTriggers.push(wordmarkTrigger);
    }

    cleanupFn = () => {
      scrollTriggers.forEach((st) => st.kill());
      timelines.forEach((timeline) => timeline.kill());
      gsap.killTweensOf([credit, wordmark, wordmarkText, ...lineMasks, ...lineInners].filter(Boolean));
      gsap.set(credit, { clearProps: 'willChange,filter,transform,opacity' });
      gsap.set(wordmark, { clearProps: 'all' });
      gsap.set(wordmarkText, { clearProps: 'fontSize' });
      if (wordmark && wordmarkPlaceholder.parentNode) {
        wordmarkPlaceholder.parentNode.insertBefore(wordmark, wordmarkPlaceholder);
        wordmarkPlaceholder.remove();
      }
      splitInstances.forEach((splitInstance) => splitInstance.revert());
      ac.abort();
    };
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
