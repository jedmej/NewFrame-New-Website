---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';
import { projects as allProjects } from '../../lib/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type GridProject = {
  key: keyof typeof t.work.projects;
  name: string;
  image?: string;
  category: string;
  url: string;
  placeholder?: boolean;
  tone?: 'warm' | 'cool';
};

const hubertProject: GridProject = {
  key: 'hubert',
  name: 'HUBERT',
  image: '/images/work/hubert.jpg',
  category: 'WEB',
  url: 'https://hubertkesik.com/',
};

const amvisProject: GridProject = {
  key: 'amvis',
  name: 'AMVIS',
  category: 'IN PROGRESS',
  url: '#',
  placeholder: true,
  tone: 'cool',
};

const projectKeyByUrl = {
  'https://urokitattoo.pl/': 'uroki',
  'https://panenkacreatives.com/': 'panenka',
  'https://esthetic.pl/': 'esthetic',
  'https://adfidence.com/': 'adfidence',
} satisfies Record<string, keyof typeof t.work.projects>;

const keyedProjects: GridProject[] = allProjects.map((project) => {
  const key = projectKeyByUrl[project.url];
  if (!key) {
    throw new Error(`Missing selected work project key for ${project.name}`);
  }
  return { ...project, key };
});

const gridProjects: GridProject[] = [hubertProject, ...keyedProjects, amvisProject];
const firstProject = gridProjects[0];
const firstMeta = t.work.projects[firstProject.key];
---

<section
  id="work-minimal"
  class="work-grid-reference"
  aria-label={t.work.label}
  style={`--work-items: ${gridProjects.length};`}
>
  <span id="work" class="work-grid-reference__anchor" aria-hidden="true"></span>

  <div class="work-grid-reference__stage">
    <canvas id="work-minimal-shader-canvas" class="work-grid-reference__shader" aria-hidden="true"></canvas>

    <div class="work-grid-reference__cards" role="list" aria-label={t.work.carouselLabel}>
      {gridProjects.map((project, index) => {
        const href = project.placeholder ? undefined : project.url;
        const meta = t.work.projects[project.key];

        return (
          <a
            href={href}
            target={href ? '_blank' : undefined}
            rel={href ? 'noopener noreferrer' : undefined}
            role="listitem"
            class={`work-grid-reference__card${project.placeholder ? ' work-grid-reference__card--placeholder' : ''}${project.tone ? ` work-grid-reference__card--${project.tone}` : ''}`}
            data-work-card
            data-index={index}
            data-title={project.name}
            data-category={project.category}
            data-description={meta.description}
            data-roles={meta.roles.join(' / ')}
            data-label={href ? t.work.viewProject : t.work.previewProject}
            style={`--card-index: ${index};`}
            aria-label={`${project.name}. ${project.category}. ${meta.description}`}
          >
            <span class="work-grid-reference__media">
              {project.image ? (
                <img src={project.image} alt={`${project.name} ${project.category}`} loading={index < 2 ? 'eager' : 'lazy'} />
              ) : (
                <span class="work-grid-reference__placeholder-mark">
                  <span>{project.name}</span>
                </span>
              )}
            </span>
            <span class="work-grid-reference__mobile-copy">
              <span>{String(index + 1).padStart(2, '0')} / {project.category}</span>
              <strong>{project.name}</strong>
              <span>{meta.description}</span>
            </span>
          </a>
        );
      })}
    </div>

    <div class="work-grid-reference__details" aria-live="polite">
      <h2 data-work-title>{firstProject.name}</h2>
      <p data-work-description>{firstMeta.description}</p>
      <p class="work-grid-reference__roles" data-work-roles>{firstMeta.roles.join(' / ')}</p>
    </div>

    <div class="work-grid-reference__counter" aria-hidden="true"><span class="work-grid-reference__counter-zero">0</span><span class="work-grid-reference__counter-digit" data-work-number>1</span></div>
  </div>
</section>

<style>
  .work-grid-reference {
    position: relative;
    height: calc(var(--work-items) * 100svh);
    min-height: 360svh;
    background:
      radial-gradient(circle at 18% 18%, rgba(201, 70, 57, 0.11), transparent 28rem),
      linear-gradient(180deg, var(--color-bg-dark), var(--color-bg-dark-soft));
    color: var(--color-dark-text);
    isolation: isolate;
  }

  .work-grid-reference__anchor {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .work-grid-reference__stage {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    overflow: hidden;
  }

  .work-grid-reference__stage::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(20, 18, 15, 0.32), transparent 34%, transparent 66%, rgba(20, 18, 15, 0.12)),
      linear-gradient(180deg, rgba(243, 234, 223, 0.045), transparent 32%);
  }

  .work-grid-reference__shader {
    position: absolute;
    inset: -10%;
    z-index: 0;
    display: block;
    width: 120%;
    height: 120%;
    opacity: 0.68;
    filter: saturate(1.02) brightness(0.9);
    pointer-events: none;
  }

  .work-grid-reference__cards {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .work-grid-reference__card {
    --card-x: 0px;
    --card-y: 0px;
    --velocity-shift: 0px;
    --card-opacity: 1;
    --card-blur: 0px;
    --card-brightness: 1;
    --card-saturation: 1;
    --card-grayscale: 0%;
    --image-parallax-x: 0px;
    --image-parallax-y: 0px;
    --image-scale: 1.06;
    position: absolute;
    top: 50%;
    left: 50%;
    display: block;
    width: clamp(18rem, 28vw, 34rem);
    aspect-ratio: 1;
    color: inherit;
    text-decoration: none;
    opacity: var(--card-opacity);
    filter:
      blur(var(--card-blur))
      grayscale(var(--card-grayscale))
      brightness(var(--card-brightness))
      saturate(var(--card-saturation));
    transform:
      translate3d(
        calc(-50% + var(--card-x) + var(--velocity-shift)),
        calc(-50% + var(--card-y) + var(--velocity-shift)),
        0
      );
    transition:
      opacity 0.42s var(--ease-out-quart),
      filter 0.42s var(--ease-out-quart);
    will-change: transform, opacity, filter;
    pointer-events: auto;
  }

  .work-grid-reference__media {
    position: absolute;
    inset: 0;
    display: block;
    overflow: hidden;
    border-radius: 2px;
    background: rgba(243, 234, 223, 0.08);
    box-shadow: 0 1rem 2.25rem rgba(0, 0, 0, 0.28);
  }

  .work-grid-reference__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    outline: 1px solid rgba(255, 255, 255, 0.1);
    outline-offset: -1px;
    transform:
      translate3d(var(--image-parallax-x), var(--image-parallax-y), 0)
      scale(var(--image-scale));
    transition: transform 0.7s var(--ease-out-quart);
    will-change: transform;
  }

  .work-grid-reference__card:focus-visible .work-grid-reference__media {
    outline: 1px solid var(--color-dark-text);
    outline-offset: 0.45rem;
  }

  .work-grid-reference__card--placeholder .work-grid-reference__media,
  .work-grid-reference__card--cool .work-grid-reference__media {
    background:
      radial-gradient(circle at 70% 24%, rgba(243, 234, 223, 0.16), transparent 12rem),
      radial-gradient(circle at 24% 78%, rgba(201, 70, 57, 0.18), transparent 10rem),
      linear-gradient(135deg, rgba(243, 234, 223, 0.075), rgba(243, 234, 223, 0.02)),
      var(--color-bg-dark);
  }

  .work-grid-reference__placeholder-mark {
    position: absolute;
    inset: 1px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(243, 234, 223, 0.12);
  }

  .work-grid-reference__placeholder-mark::before,
  .work-grid-reference__placeholder-mark::after {
    content: '';
    position: absolute;
    inset: 14%;
    border: 1px solid rgba(243, 234, 223, 0.11);
    transform: rotate(-8deg);
  }

  .work-grid-reference__placeholder-mark::after {
    inset: 23%;
    transform: rotate(7deg);
  }

  .work-grid-reference__placeholder-mark span {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 6.5rem);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: 0;
    color: var(--color-dark-text);
  }

  .work-grid-reference__details {
    position: absolute;
    z-index: 5;
    top: clamp(6.5rem, 14svh, 8rem);
    right: clamp(1.25rem, 3vw, 3.5rem);
    width: min(25rem, 26vw);
    pointer-events: none;
  }

  .work-grid-reference__roles {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(243, 234, 223, 0.5);
    font-variant-numeric: tabular-nums;
  }

  .work-grid-reference__details h2 {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 3.5vw, 4.4rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: 0;
    color: var(--color-dark-text);
    text-wrap: balance;
  }

  :global(.work-grid-reference__title-word) {
    display: inline-block;
    white-space: nowrap;
  }

  :global(.work-grid-reference__title-char) {
    display: inline-block;
    will-change: transform, opacity, filter;
  }

  .work-grid-reference__details p[data-work-description] {
    margin: 0;
    color: rgba(243, 234, 223, 0.76);
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.18vw, 1.32rem);
    font-weight: 500;
    line-height: 1.24;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .work-grid-reference__roles {
    margin-top: 1.2rem;
    color: rgba(243, 234, 223, 0.42);
    line-height: 1.35;
  }

  .work-grid-reference__counter {
    position: absolute;
    z-index: 5;
    left: clamp(1.25rem, 8vw, 9rem);
    bottom: clamp(1.5rem, 4.8vw, 5rem);
    font-family: var(--font-display);
    font-size: clamp(7.5rem, 16vw, 17rem);
    font-weight: 700;
    line-height: 0.78;
    letter-spacing: 0;
    color: var(--color-dark-text);
    font-variant-numeric: tabular-nums;
    pointer-events: none;
    display: inline-flex;
    align-items: baseline;
  }

  .work-grid-reference__counter-zero,
  .work-grid-reference__counter-digit {
    display: inline-block;
  }

  .work-grid-reference__counter-digit {
    will-change: transform, opacity, filter;
  }

  .work-grid-reference__mobile-copy {
    display: none;
  }

  @media (max-width: 1180px) {
    .work-grid-reference__card {
      width: clamp(16rem, 38vw, 27rem);
    }

    .work-grid-reference__details {
      top: clamp(6rem, 13svh, 7.5rem);
      right: clamp(1.5rem, 4vw, 3rem);
      width: min(22rem, 32vw);
    }

    .work-grid-reference__counter {
      font-size: clamp(6rem, 18vw, 11rem);
    }
  }

  @media (max-width: 840px) {
    .work-grid-reference {
      height: auto;
      min-height: auto;
      overflow: hidden;
      padding: 5.5rem 1.25rem 7rem;
      background:
        radial-gradient(circle at 18% 12%, rgba(201, 70, 57, 0.12), transparent 18rem),
        linear-gradient(180deg, var(--color-bg-dark), var(--color-bg-dark-soft));
    }

    .work-grid-reference__stage {
      position: relative;
      height: auto;
      overflow: visible;
    }

    .work-grid-reference__shader {
      inset: -5rem -35%;
      width: 170%;
      height: 26rem;
      opacity: 0.42;
    }

    .work-grid-reference__stage::before,
    .work-grid-reference__details,
    .work-grid-reference__counter {
      display: none;
    }

    .work-grid-reference__cards {
      position: relative;
      inset: auto;
      display: grid;
      gap: 4rem;
      justify-items: center;
      pointer-events: auto;
    }

    .work-grid-reference__card {
      position: relative;
      top: auto;
      left: auto;
      width: min(calc(100vw - 4rem), 21rem);
      margin-inline: 0;
      opacity: 1;
      filter: none;
      --card-blur: 0px;
      --image-parallax-x: 0px;
      --image-parallax-y: 0px;
      transform: none;
      will-change: auto;
    }

    .work-grid-reference__card:nth-child(even) {
      transform: translateX(min(4vw, 1rem));
    }

    .work-grid-reference__card:nth-child(odd):not(:first-child) {
      transform: translateX(max(-4vw, -1rem));
    }

    .work-grid-reference__media {
      position: relative;
      aspect-ratio: 1;
      box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.28);
    }

    .work-grid-reference__mobile-copy {
      display: grid;
      gap: 0.65rem;
      margin-top: 1rem;
    }

    .work-grid-reference__mobile-copy span:first-child {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(243, 234, 223, 0.45);
      font-variant-numeric: tabular-nums;
    }

    .work-grid-reference__mobile-copy strong {
      font-family: var(--font-display);
      font-size: clamp(1.9rem, 11vw, 3rem);
      font-weight: 700;
      line-height: 0.9;
      letter-spacing: 0;
      color: var(--color-dark-text);
    }

    .work-grid-reference__mobile-copy span:last-child {
      color: rgba(243, 234, 223, 0.72);
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 500;
      line-height: 1.35;
      letter-spacing: 0;
      max-width: 100%;
      text-wrap: pretty;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-grid-reference {
      height: auto;
      min-height: auto;
      padding: 6rem 1.25rem 7rem;
    }

    .work-grid-reference__stage {
      position: relative;
      height: auto;
      overflow: visible;
    }

    .work-grid-reference__details,
    .work-grid-reference__counter {
      display: none;
    }

    .work-grid-reference__cards {
      position: relative;
      inset: auto;
    }

    .work-grid-reference__cards {
      display: grid;
      gap: 4rem;
    }

    .work-grid-reference__card {
      position: relative;
      top: auto;
      left: auto;
      width: min(100%, 28rem);
      margin-inline: auto;
      opacity: 1;
      filter: none;
      --card-blur: 0px;
      --image-parallax-x: 0px;
      --image-parallax-y: 0px;
      transform: none;
      will-change: auto;
    }

    .work-grid-reference__media {
      position: relative;
      aspect-ratio: 1;
    }

    .work-grid-reference__mobile-copy {
      display: grid;
      gap: 0.65rem;
      margin-top: 1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import type { ShaderInstance } from 'shaders/js';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupWorkGrid: (() => void) | null = null;

  function initWorkGrid() {
    cleanupWorkGrid?.();

    const section = document.getElementById('work-minimal');
    if (!section) return;

    const cards = Array.from(section.querySelectorAll<HTMLElement>('[data-work-card]'));
    const numberEl = section.querySelector<HTMLElement>('[data-work-number]');
    const titleEl = section.querySelector<HTMLElement>('[data-work-title]');
    const descriptionEl = section.querySelector<HTMLElement>('[data-work-description]');
    const rolesEl = section.querySelector<HTMLElement>('[data-work-roles]');
    const shaderCanvas = section.querySelector<HTMLCanvasElement>('#work-minimal-shader-canvas');
    const detailEls = [titleEl, descriptionEl, rolesEl].filter(Boolean) as HTMLElement[];
    const ac = new AbortController();
    const { signal } = ac;
    const triggers: ScrollTrigger[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const desktopQuery = window.matchMedia('(min-width: 841px)');
    let activeIndex = -1;
    let progress = 0;
    let targetVelocity = 0;
    let velocity = 0;
    let frame = 0;
    let textTween: gsap.core.Tween | gsap.core.Timeline | null = null;
    let numberTween: gsap.core.Tween | null = null;
    let shaderInstance: ShaderInstance | null = null;
    let shaderDisposed = false;
    let shaderResizeFrame = 0;
    let shaderResizeTimer: ReturnType<typeof setTimeout> | null = null;
    let shaderResizeObserver: ResizeObserver | null = null;

    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

    const resizeShaderToCanvas = () => {
      shaderResizeFrame = 0;
      if (!shaderCanvas || !shaderInstance || shaderDisposed) return;

      shaderCanvas.style.width = '';
      shaderCanvas.style.height = '';
      const rect = shaderCanvas.getBoundingClientRect();
      if (rect.width > 0 && rect.height > 0) {
        shaderInstance.resize(Math.round(rect.width), Math.round(rect.height));
      }
    };

    const scheduleShaderResize = () => {
      if (shaderResizeTimer) window.clearTimeout(shaderResizeTimer);
      shaderResizeTimer = window.setTimeout(() => {
        if (shaderResizeFrame) window.cancelAnimationFrame(shaderResizeFrame);
        shaderResizeFrame = window.requestAnimationFrame(resizeShaderToCanvas);
      }, 120);
    };

    if (shaderCanvas && !prefersReducedMotion && desktopQuery.matches) {
      shaderCanvas.style.width = '';
      shaderCanvas.style.height = '';
      import('shaders/js').then(({ createShader }) => createShader(shaderCanvas, {
        components: [
          {
            type: 'DotGrid',
            id: 'idmlsai28917usa8l1j',
            props: {
              density: 200,
              dotSize: {
                type: 'map',
                source: 'idmlsaoh7xdy8aayjbd',
                channel: 'alpha',
                inputMax: 1,
                inputMin: 0,
                outputMax: 1,
                outputMin: 0,
              },
              twinkle: 0.9,
              visible: false,
            },
          },
          {
            type: 'ChromaFlow',
            id: 'idmlsaoh7xdy8aayjbd',
            props: {
              intensity: 1.4,
              radius: 2.9,
              visible: false,
            },
          },
          {
            type: 'LinearGradient',
            id: 'idmlsajwtg0emiuod2i',
            props: {
              colorA: '#C54538',
              colorB: '#C54538',
              colorSpace: 'hsl',
              end: {
                x: 1,
                y: 0,
              },
              maskSource: 'idmlsai28917usa8l1j',
              start: {
                x: 0,
                y: 1,
              },
              visible: true,
            },
          },
          {
            type: 'CursorRipples',
            id: 'idmlsgs6afobjsq7qem',
            props: {
              chromaticSplit: 3,
              decay: 5.6,
              intensity: 3,
              radius: 0.4,
            },
          },
        ],
      })).then((shader) => {
        if (shaderDisposed) {
          shader.destroy();
          return;
        }

        shaderInstance = shader;
        resizeShaderToCanvas();
        window.addEventListener('resize', scheduleShaderResize, { signal });
        shaderResizeObserver = new ResizeObserver(scheduleShaderResize);
        shaderResizeObserver.observe(shaderCanvas.parentElement ?? shaderCanvas);
      }).catch((error) => {
        console.warn('Selected work shader failed to initialize', error);
      });
    }

    const geometry = () => {
      const fallbackSize = clamp(window.innerWidth * 0.28, 288, 544);
      const cardSize = cards[0]?.getBoundingClientRect().width || fallbackSize;
      const vertexGap = clamp(window.innerWidth * 0.02, 16, 32);
      const step = cardSize + vertexGap;

      // Step from card bounds, not viewport, so diagonal neighbors never overlap.
      return {
        stepX: step,
        stepY: step,
      };
    };

    const projectData = (index: number) => {
      const card = cards[index];
      return {
        description: card?.dataset.description || '',
        roles: card?.dataset.roles || '',
        title: card?.dataset.title || '',
      };
    };

    const renderTitle = (title: string) => {
      if (!titleEl) return [];

      const chars: HTMLElement[] = [];
      titleEl.setAttribute('aria-label', title);
      titleEl.replaceChildren();

      title.split(' ').forEach((word, wordIndex) => {
        if (wordIndex > 0) titleEl.append(document.createTextNode(' '));

        const wordEl = document.createElement('span');
        wordEl.className = 'work-grid-reference__title-word';
        wordEl.setAttribute('aria-hidden', 'true');

        Array.from(word).forEach((char) => {
          const charEl = document.createElement('span');
          charEl.className = 'work-grid-reference__title-char';
          charEl.textContent = char;
          wordEl.append(charEl);
          chars.push(charEl);
        });

        titleEl.append(wordEl);
      });

      return chars;
    };

    const setCounterDigit = (index: number, immediate = false) => {
      if (!numberEl) return;

      const nextDigit = String(index + 1);
      numberTween?.kill();

      if (immediate || prefersReducedMotion) {
        numberEl.textContent = nextDigit;
        gsap.set(numberEl, { autoAlpha: 1, yPercent: 0, filter: 'blur(0px)' });
        return;
      }

      if (numberEl.textContent === nextDigit) {
        gsap.set(numberEl, { autoAlpha: 1, yPercent: 0, filter: 'blur(0px)' });
        return;
      }

      numberTween = gsap.to(numberEl, {
        autoAlpha: 0,
        yPercent: -28,
        filter: 'blur(3px)',
        duration: 0.12,
        ease: 'power2.out',
        overwrite: true,
        onComplete: () => {
          numberEl.textContent = nextDigit;
          numberTween = gsap.fromTo(
            numberEl,
            { autoAlpha: 0, yPercent: 34, filter: 'blur(4px)' },
            {
              autoAlpha: 1,
              yPercent: 0,
              filter: 'blur(0px)',
              duration: 0.3,
              ease: 'power3.out',
              overwrite: true,
            },
          );
        },
      });
    };

    const applyActiveContent = (index: number, immediate = false) => {
      const data = projectData(index);

      setCounterDigit(index, immediate);
      const titleChars = renderTitle(data.title);
      if (descriptionEl) descriptionEl.textContent = data.description;
      if (rolesEl) rolesEl.textContent = data.roles;

      return titleChars;
    };

    const setActiveIndex = (index: number, immediate = false) => {
      const nextIndex = clamp(index, 0, cards.length - 1);
      if (nextIndex === activeIndex) return;

      activeIndex = nextIndex;

      if (immediate || prefersReducedMotion || detailEls.length === 0) {
        applyActiveContent(nextIndex, true);
        gsap.set(detailEls, { autoAlpha: 1, y: 0, filter: 'blur(0px)' });
        if (titleEl) {
          gsap.set(titleEl.querySelectorAll<HTMLElement>('.work-grid-reference__title-char'), {
            autoAlpha: 1,
            yPercent: 0,
            filter: 'blur(0px)',
          });
        }
        return;
      }

      textTween?.kill();
      textTween = gsap.to(detailEls, {
        autoAlpha: 0,
        y: -5,
        filter: 'blur(2px)',
        duration: 0.12,
        ease: 'power2.out',
        overwrite: true,
        onComplete: () => {
          const titleChars = applyActiveContent(nextIndex);
          const supportingEls = [descriptionEl, rolesEl].filter(Boolean) as HTMLElement[];
          if (titleEl) gsap.set(titleEl, { autoAlpha: 1, y: 0, filter: 'blur(0px)' });

          const tl = gsap.timeline({ defaults: { ease: 'power3.out', overwrite: true } });
          textTween = tl;
          tl.fromTo(
            supportingEls,
            { autoAlpha: 0, y: 7, filter: 'blur(3px)' },
            {
              autoAlpha: 1,
              y: 0,
              filter: 'blur(0px)',
              duration: 0.28,
              stagger: 0.035,
            },
            0,
          ).fromTo(
            titleChars,
            { autoAlpha: 0, yPercent: 72, filter: 'blur(6px)' },
            {
              autoAlpha: 1,
              yPercent: 0,
              filter: 'blur(0px)',
              duration: 0.42,
              stagger: 0.018,
            },
            0.04,
          );
        },
      });
    };

    const setProgress = (nextProgress: number) => {
      progress = clamp(nextProgress, 0, 1);
      const lastIndex = Math.max(cards.length - 1, 1);
      const { stepX, stepY } = geometry();
      const active = Math.round(progress * lastIndex);

      setActiveIndex(active);

      cards.forEach((card, index) => {
        const rel = index - progress * lastIndex;
        const distance = Math.abs(rel);
        const focus = clamp(1 - distance * 0.78, 0, 1);
        const x = rel * stepX;
        const y = rel * stepY;

        card.style.setProperty('--card-x', `${x.toFixed(2)}px`);
        card.style.setProperty('--card-y', `${y.toFixed(2)}px`);
        card.style.setProperty('--card-opacity', (0.18 + focus * 0.82).toFixed(3));
        card.style.setProperty('--card-brightness', (0.46 + focus * 0.58).toFixed(3));
        card.style.setProperty('--card-saturation', (0.68 + focus * 0.42).toFixed(3));
        card.style.setProperty('--card-grayscale', `${((1 - focus) * 92).toFixed(2)}%`);
        const blurDistance = clamp((distance - 0.28) / 0.85, 0, 1);
        const parallaxX = clamp(rel * -13, -16, 16);
        const parallaxY = clamp(rel * -10, -12, 12);
        card.style.setProperty('--card-blur', `${(Math.pow(blurDistance, 1.08) * 16).toFixed(2)}px`);
        card.style.setProperty('--image-parallax-x', `${parallaxX.toFixed(2)}px`);
        card.style.setProperty('--image-parallax-y', `${parallaxY.toFixed(2)}px`);
        card.style.setProperty('--image-scale', (1.112 - focus * 0.042).toFixed(3));
        card.style.zIndex = String(80 - Math.round(distance * 10));
        card.style.pointerEvents = distance < 0.58 ? 'auto' : 'none';
        card.setAttribute('aria-hidden', distance < 1.35 ? 'false' : 'true');
        if (distance < 0.58) {
          card.removeAttribute('tabindex');
        } else {
          card.setAttribute('tabindex', '-1');
        }
      });
    };

    const renderVelocity = () => {
      velocity += (targetVelocity - velocity) * 0.12;
      targetVelocity *= 0.9;

      const shift = clamp(velocity * 0.012, -18, 18);
      cards.forEach((card) => {
        card.style.setProperty('--velocity-shift', `${shift.toFixed(2)}px`);
      });

      if (Math.abs(velocity) < 0.01 && Math.abs(targetVelocity) < 0.01) {
        velocity = 0;
        targetVelocity = 0;
      }

      frame = requestAnimationFrame(renderVelocity);
    };

    setActiveIndex(0, true);
    setProgress(0);

    if (!prefersReducedMotion && desktopQuery.matches && cards.length > 1) {
      frame = requestAnimationFrame(renderVelocity);

      const trigger = ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          targetVelocity = clamp(self.getVelocity(), -1600, 1600);
          setProgress(self.progress);
        },
      });
      triggers.push(trigger);

      window.addEventListener('resize', () => setProgress(progress), { signal });
      desktopQuery.addEventListener('change', () => ScrollTrigger.refresh(), { signal });
    } else {
      cards.forEach((card) => {
        card.style.pointerEvents = '';
        card.removeAttribute('aria-hidden');
        card.removeAttribute('tabindex');
      });
    }

    cleanupWorkGrid = () => {
      shaderDisposed = true;
      textTween?.kill();
      numberTween?.kill();
      if (shaderResizeTimer) window.clearTimeout(shaderResizeTimer);
      if (shaderResizeFrame) window.cancelAnimationFrame(shaderResizeFrame);
      shaderResizeObserver?.disconnect();
      shaderInstance?.destroy();
      cancelAnimationFrame(frame);
      triggers.forEach((trigger) => trigger.kill());
      ac.abort();
    };
  }

  initWorkGrid();
  document.addEventListener('astro:after-swap', initWorkGrid);
</script>
