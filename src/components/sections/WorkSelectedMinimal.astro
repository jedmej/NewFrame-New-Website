---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';
import { projects as allProjects } from '../../lib/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type GridProject = {
  key: keyof typeof t.work.projects;
  name: string;
  image?: string;
  category: string;
  url: string;
  placeholder?: boolean;
  tone?: 'warm' | 'cool';
};

const hubertProject: GridProject = {
  key: 'hubert',
  name: 'HUBERT',
  image: '/images/work/hubert.jpg',
  category: 'WEB',
  url: 'https://hubertkesik.com/',
};

const amvisProject: GridProject = {
  key: 'amvis',
  name: 'AMVIS',
  category: 'IN PROGRESS',
  url: '#',
  placeholder: true,
  tone: 'cool',
};

const projectKeyByUrl = {
  'https://urokitattoo.pl/': 'uroki',
  'https://panenkacreatives.com/': 'panenka',
  'https://esthetic.pl/': 'esthetic',
  'https://adfidence.com/': 'adfidence',
} satisfies Record<string, keyof typeof t.work.projects>;

const keyedProjects: GridProject[] = allProjects.map((project) => {
  const key = projectKeyByUrl[project.url];
  if (!key) {
    throw new Error(`Missing selected work project key for ${project.name}`);
  }
  return { ...project, key };
});

const gridProjects: GridProject[] = [hubertProject, ...keyedProjects, amvisProject];
---

<section id="work-minimal" class="work-grid-reference" aria-label={`${t.work.label} grid alternative`}>
  <span id="work" class="work-grid-reference__anchor" aria-hidden="true"></span>
  <canvas id="work-minimal-shader-canvas" class="work-grid-reference__shader" aria-hidden="true"></canvas>

  <div
    class="work-grid-reference__wipe work-grid-reference__wipe--in"
    data-work-grid-wipe-in
    aria-hidden="true"
  ></div>

  <div class="work-grid-reference__chrome" aria-hidden="true">
    <span>{t.work.label}</span>
    <span>{String(gridProjects.length).padStart(2, '0')} {t.work.counter} {String(gridProjects.length).padStart(2, '0')}</span>
  </div>

  <p class="work-grid-reference__wordmark" aria-hidden="true">SELECTED<br />WORK</p>

  <div class="work-grid-reference__grid" role="list">
    {gridProjects.map((project, index) => {
      const href = project.placeholder ? undefined : project.url;
      const meta = t.work.projects[project.key];
      return (
        <a
          href={href}
          target={href ? '_blank' : undefined}
          rel={href ? 'noopener noreferrer' : undefined}
          role="listitem"
          class={`work-grid-reference__card${project.placeholder ? ' work-grid-reference__card--placeholder' : ''}${project.tone ? ` work-grid-reference__card--${project.tone}` : ''}`}
          data-work-grid-card
          data-tooltip-label={href ? t.work.viewProject : t.work.previewProject}
          data-tooltip-title={project.name}
          data-tooltip-description={meta.description}
          data-tooltip-why-label={t.work.whyLabel}
          data-tooltip-why={meta.why}
          data-tooltip-roles={meta.roles.join(' · ')}
          style={`--index: ${index}; --base-rotate: ${[-2.2, 1.4, -1.1, 1.8, -1.5, 1.2][index]}deg; --current-rotate: ${[-2.2, 1.4, -1.1, 1.8, -1.5, 1.2][index]}deg;`}
          aria-label={`${project.name}. ${project.category}. ${meta.description}`}
        >
          <span class="work-grid-reference__media">
            {project.image ? (
              <img src={project.image} alt={`${project.name} project preview`} loading="lazy" />
            ) : (
              <span class="work-grid-reference__placeholder-mark">
                <span>{project.name}</span>
              </span>
            )}
          </span>
          <span class="work-grid-reference__caption">
            <span>{project.name}</span>
            <span>{project.category}</span>
          </span>
        </a>
      );
    })}
  </div>

  <div class="work-grid-reference__tooltip" data-work-grid-tooltip aria-hidden="true"></div>

  <div
    class="work-grid-reference__wipe work-grid-reference__wipe--out"
    data-work-grid-wipe-out
    aria-hidden="true"
  ></div>
</section>

<style>
  .work-grid-reference {
    position: relative;
    overflow: hidden;
    min-height: 120vh;
    padding: clamp(5rem, 8vw, 7.5rem) clamp(1.25rem, 4vw, 4rem) clamp(8.5rem, 14vw, 12rem);
    background:
      radial-gradient(circle at 18% 20%, rgba(201, 70, 57, 0.09), transparent 26rem),
      radial-gradient(circle at 82% 54%, rgba(243, 234, 223, 0.045), transparent 24rem),
      linear-gradient(180deg, var(--color-bg-dark), var(--color-bg-dark-soft));
    color: var(--color-dark-text);
    isolation: isolate;
  }

  .work-grid-reference::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(244, 240, 232, 0.035), transparent 22rem);
  }

  .work-grid-reference__shader {
    position: absolute;
    inset: 0;
    z-index: -1;
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.68;
    pointer-events: none;
  }

  .work-grid-reference__anchor {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .work-grid-reference__wipe {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 70;
    pointer-events: none;
    background: var(--color-bg);
  }

  .work-grid-reference__wipe--in {
    top: 0;
    height: 100vh;
    clip-path: inset(0% 0% 100% 0%);
  }

  .work-grid-reference__wipe--out {
    inset: 0;
    clip-path: inset(100% 0% 0% 0%);
  }

  .work-grid-reference__chrome {
    position: relative;
    z-index: 4;
    display: flex;
    justify-content: space-between;
    width: min(100%, 1180px);
    margin: 0 auto clamp(2.8rem, 5vw, 4.5rem);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244, 240, 232, 0.58);
    pointer-events: none;
  }

  .work-grid-reference__grid {
    position: relative;
    z-index: 1;
    width: min(100%, 1180px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(1rem, 2.4vw, 2.25rem);
    row-gap: clamp(1.6rem, 4vw, 3.75rem);
    align-items: start;
  }

  .work-grid-reference__card {
    --mx: 0px;
    --my: 0px;
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    --active: 0;
    --reveal-opacity: 1;
    --reveal-y: 0px;
    --reveal-blur: 0px;
    position: relative;
    display: block;
    aspect-ratio: 3.5 / 4.55;
    color: inherit;
    text-decoration: none;
    transform:
      translate3d(var(--mx), calc(var(--my) + var(--reveal-y)), 0)
      rotate(var(--current-rotate, var(--base-rotate)))
      rotateX(var(--tilt-x))
      rotateY(var(--tilt-y))
      scale(calc(1 + (var(--active) * 0.012)));
    transform-style: preserve-3d;
    opacity: var(--reveal-opacity);
    filter: blur(var(--reveal-blur));
    will-change: transform, opacity, filter;
  }

  .work-grid-reference__card:nth-child(1) {
    grid-column: 2 / span 4;
    grid-row: 1;
    margin-top: clamp(0.75rem, 2vw, 2rem);
  }

  .work-grid-reference__card:nth-child(2) {
    grid-column: 8 / span 4;
    grid-row: 1;
    margin-top: clamp(6rem, 10vw, 10rem);
  }

  .work-grid-reference__card:nth-child(3) {
    grid-column: 5 / span 4;
    grid-row: 2;
    margin-top: clamp(1.5rem, 4.5vw, 4.75rem);
  }

  .work-grid-reference__card:nth-child(4) {
    grid-column: 2 / span 4;
    grid-row: 3;
    margin-top: clamp(1rem, 4vw, 4rem);
  }

  .work-grid-reference__card:nth-child(5) {
    grid-column: 7 / span 4;
    grid-row: 3;
    margin-top: clamp(8rem, 13vw, 13.5rem);
  }

  .work-grid-reference__card:nth-child(6) {
    grid-column: 4 / span 4;
    grid-row: 4;
    margin-top: clamp(0.5rem, 3.5vw, 3.75rem);
  }

  .work-grid-reference__card.is-active {
    z-index: 6;
  }

  .work-grid-reference__media {
    position: absolute;
    inset: 0;
    display: block;
    overflow: hidden;
    border-radius: 3px;
    background: rgba(244, 240, 232, 0.06);
    box-shadow: 0 1.2rem 3.4rem rgba(42, 24, 17, 0.42);
    transition:
      box-shadow 0.65s var(--ease-out-expo),
      filter 0.55s ease;
  }

  .work-grid-reference__card.is-active .work-grid-reference__media {
    box-shadow: 0 1.55rem 4.2rem rgba(42, 24, 17, 0.52);
    filter: brightness(1.045) saturate(1.035);
  }

  .work-grid-reference__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(1.03) saturate(0.98);
    transform: scale(calc(1.006 + (var(--active) * 0.014)));
    transition: transform 0.9s var(--ease-out-expo), filter 0.75s ease;
  }

  .work-grid-reference__card.is-active .work-grid-reference__media img {
    filter: brightness(1.08) saturate(1.045) contrast(1.015);
  }

  .work-grid-reference__card--placeholder .work-grid-reference__media {
    background:
      linear-gradient(135deg, rgba(244, 240, 232, 0.08), rgba(244, 240, 232, 0.025)),
      radial-gradient(circle at 30% 22%, rgba(244, 240, 232, 0.16), transparent 12rem),
      #141413;
  }

  .work-grid-reference__card--cool .work-grid-reference__media {
    background:
      radial-gradient(circle at 72% 22%, rgba(243, 234, 223, 0.16), transparent 11rem),
      radial-gradient(circle at 22% 82%, rgba(201, 70, 57, 0.16), transparent 9rem),
      linear-gradient(135deg, rgba(244, 240, 232, 0.07), rgba(244, 240, 232, 0.02)),
      #181511;
  }

  .work-grid-reference__card--warm .work-grid-reference__media {
    background:
      radial-gradient(circle at 25% 25%, rgba(218, 56, 46, 0.26), transparent 11rem),
      linear-gradient(135deg, rgba(244, 240, 232, 0.075), rgba(244, 240, 232, 0.02)),
      #15110f;
  }

  .work-grid-reference__placeholder-mark {
    position: absolute;
    inset: 1px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(244, 240, 232, 0.12);
  }

  .work-grid-reference__placeholder-mark::before,
  .work-grid-reference__placeholder-mark::after {
    content: '';
    position: absolute;
    inset: 12%;
    border: 1px solid rgba(244, 240, 232, 0.12);
    transform: rotate(-8deg);
  }

  .work-grid-reference__placeholder-mark::after {
    inset: 20%;
    transform: rotate(7deg);
  }

  .work-grid-reference__placeholder-mark span {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 5.75rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: 0;
    color: #f4f0e8;
  }

  .work-grid-reference__caption {
    position: absolute;
    left: 50%;
    bottom: -1.1rem;
    display: grid;
    gap: 0.35rem;
    min-width: max-content;
    padding: 0.58rem 0.72rem;
    background: #f4f0e8;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    line-height: 1;
    letter-spacing: 0.11em;
    text-align: center;
    text-transform: uppercase;
    opacity: var(--active);
    transform:
      translate3d(-50%, calc(0.38rem - (var(--active) * 0.38rem)), 28px)
      rotate(calc(var(--current-rotate, var(--base-rotate)) * -1));
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .work-grid-reference__caption span:last-child {
    color: rgba(10, 10, 10, 0.52);
  }

  .work-grid-reference__wordmark {
    position: relative;
    z-index: 3;
    width: min(100%, 1180px);
    margin: 0 auto clamp(4rem, 8vw, 7rem);
    font-family: var(--font-display);
    font-size: clamp(4.4rem, 10vw, 10rem);
    font-weight: 700;
    line-height: 0.78;
    letter-spacing: 0;
    text-align: left;
    color: #f4f0e8;
    opacity: 0.92;
    pointer-events: none;
  }

  .work-grid-reference__tooltip {
    position: fixed;
    z-index: 120;
    left: 0;
    top: 0;
    display: flex;
    width: min(18rem, calc(100vw - 2rem));
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
    padding: 0.72rem;
    border: 1px solid rgba(241, 237, 232, 0.1);
    background: rgba(13, 13, 12, 0.8);
    box-shadow: 0 1rem 2.5rem rgba(42, 24, 17, 0.26);
    color: #f4f0e8;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    pointer-events: none;
    opacity: 0;
    transform: translate3d(0, -50%, 0) scale(0.98);
    transition: opacity 0.24s ease, transform 0.34s var(--ease-out-expo);
  }

  .work-grid-reference__tooltip.is-active {
    opacity: 1;
    transform: translate3d(0, -50%, 0) scale(1);
  }

  :global(.work-grid-reference__tooltip-action) {
    display: inline-flex;
    width: auto;
    min-height: 2.1rem;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid var(--color-accent);
    background: var(--color-accent);
    padding: 0.58rem 0.7rem;
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  :global(.work-grid-reference__tooltip-description) {
    max-width: 16.75rem;
    color: rgba(244, 240, 232, 0.78);
    font-family: var(--font-body);
    font-size: 0.86rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: 0;
  }

  :global(.work-grid-reference__tooltip-why) {
    max-width: 16.75rem;
    color: rgba(244, 240, 232, 0.58);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    line-height: 1.28;
    letter-spacing: 0;
  }

  :global(.work-grid-reference__tooltip-why-label) {
    display: block;
    margin-bottom: 0.16rem;
    color: rgba(244, 240, 232, 0.4);
    font-family: var(--font-mono);
    font-size: 0.52rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.work-grid-reference__tooltip-why-text) {
    display: block;
  }

  :global(.work-grid-reference__tooltip-roles) {
    display: flex;
    max-width: 17rem;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  :global(.work-grid-reference__tooltip-role) {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(244, 240, 232, 0.22);
    padding: 0.34rem 0.45rem;
    color: rgba(244, 240, 232, 0.72);
    font-family: var(--font-mono);
    font-size: 0.56rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.work-grid-reference__tooltip-icon) {
    width: 0.62rem;
    height: 0.62rem;
    flex: 0 0 auto;
    position: static;
    display: block;
  }

  @media (hover: none) {
    .work-grid-reference__tooltip {
      display: none;
    }
  }

  @media (max-width: 1100px) {
    .work-grid-reference {
      padding-top: 5rem;
    }

    .work-grid-reference__chrome {
      gap: 1rem;
    }

    .work-grid-reference__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: clamp(3.5rem, 8vw, 6rem);
      column-gap: clamp(1.75rem, 5vw, 4rem);
    }

    .work-grid-reference__card:nth-child(n) {
      grid-column: auto;
      grid-row: auto;
      margin-top: 0;
    }

    .work-grid-reference__card:nth-child(even) {
      margin-top: clamp(2rem, 6vw, 4rem);
    }

    .work-grid-reference__wordmark {
      position: relative;
      bottom: auto;
      max-width: 100%;
      font-size: clamp(4rem, 18vw, 8rem);
    }
  }

  @media (max-width: 560px) {
    .work-grid-reference {
      padding-inline: 1rem;
    }

    .work-grid-reference__chrome {
      align-items: flex-start;
      font-size: 0.62rem;
    }

    .work-grid-reference__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .work-grid-reference__card,
    .work-grid-reference__card:nth-child(even) {
      margin-top: 0;
    }

    .work-grid-reference__caption {
      opacity: 1;
      transform: translate3d(-50%, 0, 28px) rotate(calc(var(--current-rotate, var(--base-rotate)) * -1));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-grid-reference__card {
      --reveal-opacity: 1;
      --reveal-y: 0px;
      --reveal-blur: 0px;
      opacity: 1;
      transform: rotate(var(--current-rotate, var(--base-rotate)));
      filter: none;
    }

    .work-grid-reference__media,
    .work-grid-reference__media img,
    .work-grid-reference__caption {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import type { ShaderInstance } from 'shaders/js';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupWorkGrid: (() => void) | null = null;

  function initWorkGrid() {
    cleanupWorkGrid?.();

    const section = document.getElementById('work-minimal');
    if (!section) return;

    const cards = Array.from(section.querySelectorAll<HTMLElement>('[data-work-grid-card]'));
    const tooltip = section.querySelector<HTMLElement>('[data-work-grid-tooltip]');
    const wipeIn = section.querySelector<HTMLElement>('[data-work-grid-wipe-in]');
    const wipeOut = section.querySelector<HTMLElement>('[data-work-grid-wipe-out]');
    const shaderCanvas = section.querySelector<HTMLCanvasElement>('#work-minimal-shader-canvas');
    const ac = new AbortController();
    const { signal } = ac;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let shaderInstance: ShaderInstance | null = null;
    let shaderDisposed = false;

    if (shaderCanvas && !prefersReducedMotion) {
      import('shaders/js').then(({ createShader }) => createShader(shaderCanvas, {
        components: [
          {
            type: 'DotGrid',
            id: 'idmlsai28917usa8l1j',
            props: {
              density: 200,
              dotSize: {
                type: 'map',
                source: 'idmlsaoh7xdy8aayjbd',
                channel: 'alpha',
                inputMax: 1,
                inputMin: 0,
                outputMax: 1,
                outputMin: 0,
              },
              twinkle: 0.9,
              visible: false,
            },
          },
          {
            type: 'ChromaFlow',
            id: 'idmlsaoh7xdy8aayjbd',
            props: {
              intensity: 1.4,
              radius: 2.9,
              visible: false,
            },
          },
          {
            type: 'LinearGradient',
            id: 'idmlsajwtg0emiuod2i',
            props: {
              colorA: '#C54538',
              colorB: '#C54538',
              colorSpace: 'hsl',
              end: {
                x: 1,
                y: 0,
              },
              maskSource: 'idmlsai28917usa8l1j',
              start: {
                x: 0,
                y: 1,
              },
              visible: true,
            },
          },
          {
            type: 'CursorRipples',
            id: 'idmlsgs6afobjsq7qem',
            props: {
              chromaticSplit: 3,
              decay: 5.6,
              intensity: 3,
              radius: 0.4,
            },
          },
        ],
      })).then((shader) => {
        if (shaderDisposed) {
          shader.destroy();
          return;
        }

        shaderInstance = shader;
      }).catch((error) => {
        console.warn('Selected work shader failed to initialize', error);
      });
    }

    const states = new Map<HTMLElement, {
      x: number;
      y: number;
      tx: number;
      ty: number;
      rx: number;
      ry: number;
      trx: number;
      try: number;
      active: number;
      targetActive: number;
    }>();
    const tooltipState = {
      x: window.innerWidth / 2,
      y: window.innerHeight / 2,
      tx: window.innerWidth / 2,
      ty: window.innerHeight / 2,
    };
    let wipeInTrigger: ScrollTrigger | null = null;
    let wipeOutTrigger: ScrollTrigger | null = null;
    const revealTriggers: ScrollTrigger[] = [];

    cards.forEach((card) => {
      states.set(card, {
        x: 0,
        y: 0,
        tx: 0,
        ty: 0,
        rx: 0,
        ry: 0,
        trx: 0,
        try: 0,
        active: 0,
        targetActive: 0,
      });
    });

    const baseRotation = (card: HTMLElement) => {
      const value = card.style.getPropertyValue('--base-rotate').trim();
      return Number.parseFloat(value) || 0;
    };

    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

    const createTooltipSvg = () => {
      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      svg.classList.add('work-grid-reference__tooltip-icon');
      svg.setAttribute('viewBox', '0 0 12 12');
      svg.setAttribute('width', '10');
      svg.setAttribute('height', '10');
      svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor');
      svg.setAttribute('stroke-width', '1.5');
      svg.style.width = '0.62rem';
      svg.style.height = '0.62rem';
      svg.style.position = 'static';
      svg.setAttribute('aria-hidden', 'true');
      path.setAttribute('d', 'M1 11L11 1M11 1H3M11 1V9');
      svg.append(path);
      return svg;
    };

    const ensureTooltipContent = (tooltipEl: HTMLElement) => {
      let action = tooltipEl.querySelector<HTMLElement>('.work-grid-reference__tooltip-action');
      let actionText = tooltipEl.querySelector<HTMLElement>('.work-grid-reference__tooltip-action-text');
      let description = tooltipEl.querySelector<HTMLElement>('.work-grid-reference__tooltip-description');
      let why = tooltipEl.querySelector<HTMLElement>('.work-grid-reference__tooltip-why');
      let whyLabel = tooltipEl.querySelector<HTMLElement>('.work-grid-reference__tooltip-why-label');
      let whyText = tooltipEl.querySelector<HTMLElement>('.work-grid-reference__tooltip-why-text');
      let roles = tooltipEl.querySelector<HTMLElement>('.work-grid-reference__tooltip-roles');

      if (!action || !actionText || !description || !why || !whyLabel || !whyText || !roles) {
        action = document.createElement('span');
        actionText = document.createElement('span');
        description = document.createElement('span');
        why = document.createElement('span');
        whyLabel = document.createElement('span');
        whyText = document.createElement('span');
        roles = document.createElement('span');

        action.className = 'work-grid-reference__tooltip-action';
        actionText.className = 'work-grid-reference__tooltip-action-text';
        description.className = 'work-grid-reference__tooltip-description';
        why.className = 'work-grid-reference__tooltip-why';
        whyLabel.className = 'work-grid-reference__tooltip-why-label';
        whyText.className = 'work-grid-reference__tooltip-why-text';
        roles.className = 'work-grid-reference__tooltip-roles';
        action.append(actionText, createTooltipSvg());
        why.append(whyLabel, whyText);

        tooltipEl.replaceChildren(action, description, why, roles);
      }

      return { actionText, description, whyLabel, whyText, roles };
    };

    const setTooltipTarget = (event: PointerEvent | MouseEvent) => {
      if (!tooltip) return;

      const margin = 16;
      const fallbackWidth = Math.min(288, window.innerWidth - margin * 2);
      const fallbackHeight = 112;
      const width = tooltip.offsetWidth || fallbackWidth;
      const height = tooltip.offsetHeight || fallbackHeight;
      const minX = margin;
      const maxX = window.innerWidth - margin - width;
      const minY = margin + height / 2;
      const maxY = window.innerHeight - margin - height / 2;
      const rawX = event.clientX + 24;
      const rawY = event.clientY - 18;

      tooltipState.tx = clamp(rawX, minX, Math.max(minX, maxX));
      tooltipState.ty = clamp(rawY, minY, Math.max(minY, maxY));
    };

    const setTarget = (card: HTMLElement, event: PointerEvent | MouseEvent) => {
      const state = states.get(card);
      if (!state) return;

      const rect = card.getBoundingClientRect();
      const px = (event.clientX - rect.left) / rect.width - 0.5;
      const py = (event.clientY - rect.top) / rect.height - 0.5;

      state.tx = px * 14;
      state.ty = py * 12;
      state.trx = py * -3.2;
      state.try = px * 3.8;
      state.targetActive = 1;
      card.classList.add('is-active');

      if (tooltip) {
        const label = card.dataset.tooltipLabel || 'View';
        const title = card.dataset.tooltipTitle || '';
        const description = card.dataset.tooltipDescription || '';
        const whyLabel = card.dataset.tooltipWhyLabel || '';
        const why = card.dataset.tooltipWhy || '';
        const roles = card.dataset.tooltipRoles || '';
        const tooltipContent = ensureTooltipContent(tooltip);
        tooltipContent.actionText.textContent = `${label} ${title}`;
        tooltipContent.description.textContent = description;
        tooltipContent.whyLabel.textContent = whyLabel;
        tooltipContent.whyText.textContent = why;
        tooltipContent.roles.replaceChildren(
          ...roles
            .split(' · ')
            .filter(Boolean)
            .map((role) => {
              const tag = document.createElement('span');
              tag.className = 'work-grid-reference__tooltip-role';
              tag.textContent = role;
              return tag;
            }),
        );
        tooltip.classList.add('is-active');
        setTooltipTarget(event);
      }
    };

    const release = (card: HTMLElement) => {
      const state = states.get(card);
      if (!state) return;
      state.tx = 0;
      state.ty = 0;
      state.trx = 0;
      state.try = 0;
      state.targetActive = 0;
      card.classList.remove('is-active');
      tooltip?.classList.remove('is-active');
    };

    cards.forEach((card) => {
      card.addEventListener('pointerenter', (event) => setTarget(card, event), { signal });
      card.addEventListener('pointermove', (event) => setTarget(card, event), { signal });
      card.addEventListener('pointerleave', () => release(card), { signal });
      card.addEventListener('focus', () => {
        const state = states.get(card);
        if (!state) return;
        state.targetActive = 1;
        card.classList.add('is-active');
      }, { signal });
      card.addEventListener('blur', () => release(card), { signal });
    });

    let frame = 0;

    const render = () => {
      states.forEach((state, card) => {
        state.x += (state.tx - state.x) * 0.09;
        state.y += (state.ty - state.y) * 0.09;
        state.rx += (state.trx - state.rx) * 0.078;
        state.ry += (state.try - state.ry) * 0.078;
        state.active += (state.targetActive - state.active) * 0.095;
        const currentRotate = baseRotation(card) * (1 - state.active);

        card.style.setProperty('--mx', `${state.x.toFixed(2)}px`);
        card.style.setProperty('--my', `${state.y.toFixed(2)}px`);
        card.style.setProperty('--tilt-x', `${state.rx.toFixed(2)}deg`);
        card.style.setProperty('--tilt-y', `${state.ry.toFixed(2)}deg`);
        card.style.setProperty('--active', state.active.toFixed(3));
        card.style.setProperty('--current-rotate', `${currentRotate.toFixed(3)}deg`);
      });

      if (tooltip) {
        tooltipState.x += (tooltipState.tx - tooltipState.x) * 0.16;
        tooltipState.y += (tooltipState.ty - tooltipState.y) * 0.16;
        tooltip.style.left = `${tooltipState.x.toFixed(2)}px`;
        tooltip.style.top = `${tooltipState.y.toFixed(2)}px`;
      }

      frame = requestAnimationFrame(render);
    };

    if (!prefersReducedMotion) {
      frame = requestAnimationFrame(render);

      cards.forEach((card) => {
        const revealTrigger = ScrollTrigger.create({
          trigger: card,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 0.45,
          onUpdate: () => {
            const rect = card.getBoundingClientRect();
            const viewport = window.innerHeight;
            const enter = Math.min(1, Math.max(0, (viewport - rect.top) / (viewport * 0.25)));
            const exit = Math.min(1, Math.max(0, rect.bottom / (viewport * 0.25)));
            const reveal = Math.min(enter, exit);
            const y = enter < exit ? (1 - reveal) * 24 : (1 - reveal) * -18;

            card.style.setProperty('--reveal-opacity', reveal.toFixed(3));
            card.style.setProperty('--reveal-y', `${y.toFixed(2)}px`);
            card.style.setProperty('--reveal-blur', `${((1 - reveal) * 14).toFixed(2)}px`);
          },
        });
        revealTriggers.push(revealTrigger);
      });

      if (wipeIn) {
        const wipeInTween = gsap.fromTo(
          wipeIn,
          { clipPath: 'inset(0% 0% 0% 0%)' },
          {
            clipPath: 'inset(0% 0% 100% 0%)',
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'top 10%',
              scrub: true,
            },
          }
        );
        if (wipeInTween.scrollTrigger) wipeInTrigger = wipeInTween.scrollTrigger;
      }

      if (wipeOut) {
        const wipeOutTween = gsap.fromTo(
          wipeOut,
          { clipPath: 'inset(100% 0% 0% 0%)' },
          {
            clipPath: 'inset(18% 0% 0% 0%)',
            ease: 'power1.out',
            scrollTrigger: {
              trigger: section,
              start: 'bottom 58%',
              end: 'bottom -38%',
              scrub: 1.2,
            },
          }
        );
        if (wipeOutTween.scrollTrigger) wipeOutTrigger = wipeOutTween.scrollTrigger;
      }
    } else {
      cards.forEach((card) => {
        card.style.setProperty('--reveal-opacity', '1');
        card.style.setProperty('--reveal-y', '0px');
        card.style.setProperty('--reveal-blur', '0px');
      });
      if (wipeIn) wipeIn.style.display = 'none';
      if (wipeOut) wipeOut.style.display = 'none';
    }

    cleanupWorkGrid = () => {
      shaderDisposed = true;
      shaderInstance?.destroy();
      cancelAnimationFrame(frame);
      revealTriggers.forEach((trigger) => trigger.kill());
      wipeInTrigger?.kill();
      wipeOutTrigger?.kill();
      ac.abort();
    };
  }

  initWorkGrid();
  document.addEventListener('astro:after-swap', initWorkGrid);
</script>
