---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';
import { projects as allProjects } from '../../lib/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type ProjectKey = keyof typeof t.work.projects;

type GridProject = {
  key: ProjectKey;
  name: string;
  image?: string;
  category: string;
  url: string;
  placeholder?: boolean;
  tone?: 'warm' | 'cool';
};

const hubertProject: GridProject = {
  key: 'hubert',
  name: 'HUBERT PHOTOGRAPHY',
  image: '/images/work/hubert.webp',
  category: 'WEB',
  url: 'https://hubertkesik.com/',
};

const amvisProject: GridProject = {
  key: 'amvis',
  name: 'AMVIS',
  image: '/images/work/amvis.webp',
  category: 'IN PROGRESS',
  url: '#',
  placeholder: true,
  tone: 'cool',
};

const projectKeyByUrl = {
  'https://urokitattoo.pl/': 'uroki',
  'https://panenkacreatives.com/': 'panenka',
  'https://esthetic.pl/': 'esthetic',
  'https://adfidence.com/': 'adfidence',
} satisfies Record<string, ProjectKey>;

const keyedProjects: GridProject[] = allProjects.map((project) => {
  const key = projectKeyByUrl[project.url];
  if (!key) {
    throw new Error(`Missing selected work project key for ${project.name}`);
  }
  return { ...project, key };
});

const projectsByKey = Object.fromEntries(
  [...keyedProjects, hubertProject, amvisProject].map((project) => [project.key, project])
) as Record<ProjectKey, GridProject>;

const displayNameByKey = {
  hubert: 'Hubert Photography',
  uroki: 'Uroki Tattoo',
  panenka: 'Panenka Creatives',
  esthetic: 'Esthetic',
  adfidence: 'Adfidence',
  amvis: 'Amvis',
} satisfies Record<ProjectKey, string>;

const caseKeys = ['hubert', 'adfidence', 'esthetic', 'panenka', 'uroki'] as const;
const caseProjects = caseKeys.map((key) => projectsByKey[key]);
const firstProject = caseProjects[0];
const firstMeta = t.work.projects[firstProject.key];
const scrollSpan = 100 + (caseProjects.length - 1) * 62;
---

<section
  id="work-minimal"
  class="work-selected-flat"
  aria-label={t.work.label}
  style={`--work-scroll-span: ${scrollSpan}svh;`}
>
  <span id="work" class="work-selected-flat__anchor" aria-hidden="true"></span>

  <div class="work-selected-flat__stage">
    <div class="work-selected-flat__layout">
      <header class="work-selected-flat__title-area">
        <p class="work-selected-flat__label text-mono-xs">{t.work.label}</p>

        <nav class="work-selected-flat__titles" aria-label={t.work.carouselLabel}>
          {caseProjects.map((project, index) => {
            const href = project.placeholder ? undefined : project.url;
            const meta = t.work.projects[project.key];

            return (
              <a
                href={href}
                target={href ? '_blank' : undefined}
                rel={href ? 'noopener noreferrer' : undefined}
                class={`work-selected-flat__title-link${index === 0 ? ' is-active' : ''}`}
                aria-label={`${displayNameByKey[project.key]}. ${meta.description}`}
                aria-current={index === 0 ? 'true' : undefined}
                data-work-title-item
                data-index={index}
                data-title={displayNameByKey[project.key]}
                data-category={project.category}
                data-description={meta.description}
                data-roles={meta.roles.join(' / ')}
                data-meta={meta.roles.join(' / ')}
              >
                {displayNameByKey[project.key]}
              </a>
            );
          })}
        </nav>
      </header>

      <div class="work-selected-flat__meta" aria-label={`${displayNameByKey[firstProject.key]} ${firstProject.category}`}>
        <p data-work-meta>{firstMeta.roles.join(' / ')}</p>
      </div>

      <div class="work-selected-flat__reel" role="list" aria-label={t.work.carouselLabel} data-work-reel>
        {caseProjects.map((project, index) => {
          const href = project.placeholder ? undefined : project.url;
          const meta = t.work.projects[project.key];

          return (
            <a
              href={href}
              target={href ? '_blank' : undefined}
              rel={href ? 'noopener noreferrer' : undefined}
              class={`work-selected-flat__reel-item work-selected-flat__reel-item--${index + 1}${index === 0 ? ' is-active' : ''}`}
              role="listitem"
              aria-label={`${displayNameByKey[project.key]}. ${project.category}. ${meta.description}`}
              aria-current={index === 0 ? 'true' : undefined}
              data-work-reel-item
              data-index={index}
            >
              <img
                src={project.image}
                alt={`${displayNameByKey[project.key]} ${project.category}`}
                loading={index < 2 ? 'eager' : 'lazy'}
              />
            </a>
          );
        })}
      </div>

      <aside class="work-selected-flat__note" aria-live="polite">
        <p data-work-description>{firstMeta.description}</p>
      </aside>
    </div>
  </div>
</section>

<style>
  .work-selected-flat {
    position: relative;
    min-height: var(--work-scroll-span);
    background: var(--color-surface);
    color: var(--color-text);
    isolation: isolate;
  }

  .work-selected-flat__stage {
    position: sticky;
    top: 0;
    overflow: hidden;
    height: 100svh;
    padding:
      clamp(3.25rem, 5vw, 5.5rem)
      clamp(1.5rem, 3.75vw, 4.5rem);
    background: var(--color-surface);
  }

  .work-selected-flat__anchor {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .work-selected-flat__layout {
    display: grid;
    grid-template-columns:
      minmax(18rem, 1fr)
      minmax(7rem, 0.45fr)
      clamp(13.25rem, 15.65vw, 18.75rem)
      minmax(17rem, 0.9fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: center;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  .work-selected-flat__title-area {
    display: grid;
    gap: clamp(3rem, 7vw, 9.5rem);
    align-self: center;
    min-width: 0;
    transform: translate3d(0, var(--work-title-shift, 0px), 0);
    will-change: transform;
  }

  .work-selected-flat__label {
    margin: 0;
    color: rgba(20, 18, 15, 0.48);
  }

  .work-selected-flat__titles {
    display: grid;
    gap: clamp(1.7rem, 2.85vw, 4rem);
    align-content: center;
    min-width: 0;
  }

  .work-selected-flat__title-link {
    --work-title-opacity: 0.76;
    --work-title-blur: 5px;
    --work-title-x: 0px;
    display: block;
    width: fit-content;
    max-width: 100%;
    color: rgba(20, 18, 15, 0.36);
    font-family: var(--font-serif);
    font-size: clamp(2.75rem, 2.85vw, 3.5rem);
    font-weight: 400;
    line-height: 1.03;
    letter-spacing: 0;
    text-decoration: none;
    text-wrap: balance;
    opacity: var(--work-title-opacity);
    filter: blur(var(--work-title-blur));
    transform: translate3d(var(--work-title-x), 0, 0);
    transition:
      color 0.45s var(--ease-out-quart),
      filter 0.45s var(--ease-out-quart),
      opacity 0.45s var(--ease-out-quart),
      transform 0.45s var(--ease-out-quart);
  }

  .work-selected-flat__title-link.is-active {
    color: var(--color-text);
  }

  .work-selected-flat__title-link:hover,
  .work-selected-flat__title-link:focus-visible {
    color: var(--color-text);
    opacity: 1;
    filter: blur(0);
    transform: translateX(0.08em);
  }

  .work-selected-flat__title-link:focus-visible,
  .work-selected-flat__reel-item:focus-visible {
    outline: 1px solid var(--color-text);
    outline-offset: 0.45rem;
  }

  .work-selected-flat__meta {
    align-self: center;
    justify-self: center;
    width: min(12rem, 100%);
    color: rgba(20, 18, 15, 0.42);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }

  .work-selected-flat__meta p,
  .work-selected-flat__note p {
    margin: 0;
    text-wrap: pretty;
  }

  .work-selected-flat__reel {
    --reel-width: clamp(13.25rem, 15.65vw, 18.75rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: var(--reel-width);
    height: min(100%, clamp(39rem, 58vw, 58rem));
    justify-self: center;
    transform: translate3d(0, var(--work-reel-shift, 0px), 0);
    will-change: transform;
  }

  .work-selected-flat__reel-item {
    --work-item-opacity: 0.82;
    --work-item-grayscale: 100%;
    --work-item-y: 0px;
    --work-item-scale: 1;
    position: relative;
    display: block;
    overflow: hidden;
    flex: 0 0 auto;
    border-radius: 2px;
    background: rgba(20, 18, 15, 0.06);
    color: inherit;
    text-decoration: none;
    opacity: var(--work-item-opacity);
    filter: grayscale(var(--work-item-grayscale));
    transform: translate3d(0, var(--work-item-y), 0) scale(var(--work-item-scale));
    z-index: 1;
    transition:
      opacity 0.42s var(--ease-out-quart),
      filter 0.42s var(--ease-out-quart),
      transform 0.42s var(--ease-out-quart);
  }

  .work-selected-flat__reel-item:hover,
  .work-selected-flat__reel-item:focus-visible {
    opacity: 1;
    filter: grayscale(0%);
    transform: translate3d(0, -0.35rem, 0) scale(1.035);
  }

  .work-selected-flat__reel-item.is-active {
    z-index: 2;
  }

  .work-selected-flat__reel-item--1 {
    width: calc(var(--reel-width) * 0.88);
    height: clamp(10rem, 12.5vw, 15.5rem);
  }

  .work-selected-flat__reel-item--2 {
    width: calc(var(--reel-width) * 0.7);
    height: clamp(9.5rem, 11vw, 13.5rem);
  }

  .work-selected-flat__reel-item--3 {
    width: var(--reel-width);
    height: clamp(7.5rem, 8.7vw, 10.8rem);
  }

  .work-selected-flat__reel-item--4 {
    width: calc(var(--reel-width) * 0.65);
    aspect-ratio: 1;
  }

  .work-selected-flat__reel-item--5 {
    width: calc(var(--reel-width) * 0.87);
    height: clamp(11.5rem, 13.4vw, 16.5rem);
  }

  .work-selected-flat__reel-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    outline: 1px solid rgba(0, 0, 0, 0.1);
    outline-offset: -1px;
    transform: scale(1.02);
    transition: transform 0.6s var(--ease-out-quart);
  }

  .work-selected-flat__reel-item:hover img,
  .work-selected-flat__reel-item:focus-visible img {
    transform: scale(1.06);
  }

  .work-selected-flat__note {
    display: grid;
    gap: 1.1rem;
    justify-self: end;
    width: min(22.5rem, 100%);
    color: rgba(20, 18, 15, 0.66);
    font-family: var(--font-body);
    font-size: clamp(0.88rem, 0.78vw, 0.95rem);
    font-weight: 500;
    line-height: 1.16;
    letter-spacing: 0;
  }

  @media (max-width: 1180px) {
    .work-selected-flat__layout {
      grid-template-columns:
        minmax(16rem, 1fr)
        minmax(10rem, 0.5fr)
        clamp(11.5rem, 17vw, 14.5rem)
        minmax(13rem, 0.8fr);
      gap: clamp(1.35rem, 2.8vw, 3rem);
    }

    .work-selected-flat__reel {
      --reel-width: clamp(11.5rem, 17vw, 14.5rem);
      min-height: clamp(38rem, 60vw, 52rem);
    }
  }

  @media (max-width: 900px) {
    .work-selected-flat {
      min-height: auto;
    }

    .work-selected-flat__stage {
      position: relative;
      height: auto;
      overflow: clip;
      padding: 6rem 1.25rem 7rem;
    }

    .work-selected-flat__layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3.5rem;
      min-height: auto;
    }

    .work-selected-flat__title-area {
      gap: 3.75rem;
    }

    .work-selected-flat__titles {
      gap: 1.85rem;
    }

    .work-selected-flat__title-area {
      transform: none;
      will-change: auto;
    }

    .work-selected-flat__title-link {
      width: 100%;
      font-size: clamp(3rem, 14vw, 4.75rem);
      line-height: 0.94;
      filter: blur(3px);
    }

    .work-selected-flat__meta {
      justify-self: start;
      width: min(16rem, 80vw);
    }

    .work-selected-flat__reel {
      --reel-width: 100%;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      width: 100%;
      min-height: auto;
      align-items: stretch;
      transform: none;
      will-change: auto;
    }

    .work-selected-flat__reel-item,
    .work-selected-flat__reel-item--1,
    .work-selected-flat__reel-item--2,
    .work-selected-flat__reel-item--3,
    .work-selected-flat__reel-item--4,
    .work-selected-flat__reel-item--5 {
      width: 100%;
      height: auto;
      aspect-ratio: 0.86;
    }

    .work-selected-flat__reel-item--3 {
      grid-column: 1 / -1;
      aspect-ratio: 1.72;
    }

    .work-selected-flat__reel-item--5 {
      grid-column: 2;
      grid-row: 4 / span 2;
    }

    .work-selected-flat__note {
      justify-self: start;
      width: min(26rem, 100%);
      font-size: 0.95rem;
      line-height: 1.32;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-selected-flat {
      min-height: auto;
    }

    .work-selected-flat__stage {
      position: relative;
      height: auto;
    }

    .work-selected-flat__title-link,
    .work-selected-flat__reel-item,
    .work-selected-flat__reel-item img {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupWorkSelectedFlat: (() => void) | null = null;

  function initWorkSelectedFlat() {
    cleanupWorkSelectedFlat?.();

    const section = document.getElementById('work-minimal');
    if (!section) return;

    const titleItems = Array.from(section.querySelectorAll<HTMLElement>('[data-work-title-item]'));
    const reelItems = Array.from(section.querySelectorAll<HTMLElement>('[data-work-reel-item]'));
    const stage = section.querySelector<HTMLElement>('.work-selected-flat__stage');
    const titleArea = section.querySelector<HTMLElement>('.work-selected-flat__title-area');
    const reel = section.querySelector<HTMLElement>('[data-work-reel]');
    const metaEl = section.querySelector<HTMLElement>('[data-work-meta]');
    const descriptionEl = section.querySelector<HTMLElement>('[data-work-description]');
    const ac = new AbortController();
    const { signal } = ac;
    const triggers: ScrollTrigger[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const desktopQuery = window.matchMedia('(min-width: 901px)');
    let activeIndex = -1;
    let progress = 0;
    let syncFrame = 0;
    const syncTimers: ReturnType<typeof setTimeout>[] = [];
    let copyTween: gsap.core.Tween | gsap.core.Timeline | null = null;

    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
    const lerp = (start: number, end: number, amount: number) => start + (end - start) * amount;
    const smoothstep = (value: number) => value * value * (3 - 2 * value);

    const itemCenter = (item: HTMLElement) => item.offsetTop + item.offsetHeight / 2;

    const interpolatedCenter = (items: HTMLElement[], virtualIndex: number) => {
      const lowerIndex = clamp(Math.floor(virtualIndex), 0, Math.max(items.length - 1, 0));
      const upperIndex = clamp(Math.ceil(virtualIndex), 0, Math.max(items.length - 1, 0));
      const lowerItem = items[lowerIndex];
      const upperItem = items[upperIndex] || lowerItem;
      if (!lowerItem || !upperItem) return 0;

      return lerp(itemCenter(lowerItem), itemCenter(upperItem), virtualIndex - lowerIndex);
    };

    const centerTitleAt = (virtualIndex = activeIndex) => {
      if (!titleArea || !desktopQuery.matches || prefersReducedMotion) {
        titleArea?.style.removeProperty('--work-title-shift');
        return;
      }

      const stageRect = stage?.getBoundingClientRect();
      const stageIsPinned = Boolean(stageRect && stageRect.top <= 0 && stageRect.bottom >= window.innerHeight);
      if (!stageIsPinned) {
        titleArea.style.setProperty('--work-title-shift', '0px');
        return;
      }

      const titleAreaRect = titleArea.getBoundingClientRect();
      const currentShift = Number.parseFloat(titleArea.style.getPropertyValue('--work-title-shift')) || 0;
      const targetCenterInArea = window.innerHeight / 2 - (titleAreaRect.top - currentShift);
      const shift = targetCenterInArea - interpolatedCenter(titleItems, virtualIndex);
      titleArea.style.setProperty('--work-title-shift', `${shift.toFixed(2)}px`);
    };

    const centerReelAt = (virtualIndex = activeIndex) => {
      if (!reel || !desktopQuery.matches || prefersReducedMotion) {
        reel?.style.removeProperty('--work-reel-shift');
        return;
      }

      const reelCenter = reel.clientHeight / 2;
      const shift = reelCenter - interpolatedCenter(reelItems, virtualIndex);
      reel.style.setProperty('--work-reel-shift', `${shift.toFixed(2)}px`);
    };

    const applyContinuousFocus = (virtualIndex: number) => {
      titleItems.forEach((item, index) => {
        const distance = Math.abs(index - virtualIndex);
        const focus = smoothstep(clamp(1 - distance, 0, 1));
        item.style.setProperty('--work-title-opacity', (0.28 + focus * 0.72).toFixed(3));
        item.style.setProperty('--work-title-blur', `${((1 - focus) * 6.5).toFixed(2)}px`);
        item.style.setProperty('--work-title-x', `${(focus * 5).toFixed(2)}px`);
      });

      reelItems.forEach((item, index) => {
        const distance = Math.abs(index - virtualIndex);
        const focus = smoothstep(clamp(1 - distance, 0, 1));
        item.style.setProperty('--work-item-opacity', (0.34 + focus * 0.66).toFixed(3));
        item.style.setProperty('--work-item-grayscale', `${((1 - focus) * 100).toFixed(2)}%`);
        item.style.setProperty('--work-item-y', `${(-5.5 * focus).toFixed(2)}px`);
        item.style.setProperty('--work-item-scale', (1 + focus * 0.035).toFixed(3));
        item.style.zIndex = String(1 + Math.round(focus * 10));
      });
    };

    const setActiveCopy = (activeTitle: HTMLElement | undefined) => {
      const meta = activeTitle?.dataset.meta || '';
      const description = activeTitle?.dataset.description || '';
      const copyEls = [metaEl, descriptionEl].filter(Boolean) as HTMLElement[];

      copyTween?.kill();

      if (copyEls.length === 0 || prefersReducedMotion) {
        if (metaEl) metaEl.textContent = meta;
        if (descriptionEl) descriptionEl.textContent = description;
        return;
      }

      copyTween = gsap.to(copyEls, {
        autoAlpha: 0,
        y: -4,
        filter: 'blur(2px)',
        duration: 0.13,
        ease: 'power2.out',
        overwrite: true,
        onComplete: () => {
          if (metaEl) metaEl.textContent = meta;
          if (descriptionEl) descriptionEl.textContent = description;
          copyTween = gsap.fromTo(
            copyEls,
            { autoAlpha: 0, y: 6, filter: 'blur(3px)' },
            {
              autoAlpha: 1,
              y: 0,
              filter: 'blur(0px)',
              duration: 0.32,
              ease: 'power3.out',
              overwrite: true,
            },
          );
        },
      });
    };

    const setActiveIndex = (index: number) => {
      const nextIndex = clamp(index, 0, Math.max(titleItems.length - 1, 0));
      if (nextIndex === activeIndex) return;

      activeIndex = nextIndex;
      const activeTitle = titleItems[nextIndex];

      titleItems.forEach((item, itemIndex) => {
        const isActive = itemIndex === nextIndex;
        item.classList.toggle('is-active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', 'true');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      reelItems.forEach((item, itemIndex) => {
        const isActive = itemIndex === nextIndex;
        item.classList.toggle('is-active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', 'true');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      setActiveCopy(activeTitle);
    };

    const setProgress = (nextProgress: number) => {
      progress = clamp(nextProgress, 0, 1);
      const lastIndex = Math.max(titleItems.length - 1, 1);
      const virtualIndex = progress * lastIndex;
      applyContinuousFocus(virtualIndex);
      centerTitleAt(virtualIndex);
      centerReelAt(virtualIndex);
      setActiveIndex(Math.round(virtualIndex));
    };

    const syncToCurrentScroll = () => {
      const start = section.offsetTop;
      const end = section.offsetTop + section.offsetHeight - window.innerHeight;
      const distance = Math.max(end - start, 1);
      setProgress((window.scrollY - start) / distance);
    };

    const scheduleSync = () => {
      if (syncFrame) window.cancelAnimationFrame(syncFrame);
      syncFrame = window.requestAnimationFrame(() => {
        syncToCurrentScroll();
        syncFrame = 0;
      });
    };

    titleItems.forEach((item, index) => {
      item.addEventListener('mouseenter', () => setActiveIndex(index), { signal });
      item.addEventListener('focus', () => setActiveIndex(index), { signal });
    });

    reelItems.forEach((item, index) => {
      item.addEventListener('mouseenter', () => setActiveIndex(index), { signal });
      item.addEventListener('focus', () => setActiveIndex(index), { signal });
    });

    setProgress(0);
    scheduleSync();
    syncTimers.push(
      window.setTimeout(scheduleSync, 260),
      window.setTimeout(scheduleSync, 800),
      window.setTimeout(scheduleSync, 1400),
    );

    if (!prefersReducedMotion && desktopQuery.matches && titleItems.length > 1) {
      const trigger = ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: true,
        invalidateOnRefresh: true,
        onUpdate: (self) => setProgress(self.progress),
        onRefresh: (self) => setProgress(self.progress),
      });
      triggers.push(trigger);

      window.addEventListener('scroll', scheduleSync, { signal, passive: true });
      window.addEventListener('resize', () => setProgress(progress), { signal });
      desktopQuery.addEventListener('change', () => ScrollTrigger.refresh(), { signal });
    }

    cleanupWorkSelectedFlat = () => {
      triggers.forEach((trigger) => trigger.kill());
      if (syncFrame) window.cancelAnimationFrame(syncFrame);
      syncTimers.forEach((timer) => window.clearTimeout(timer));
      copyTween?.kill();
      ac.abort();
    };
  }

  initWorkSelectedFlat();
  document.addEventListener('astro:after-swap', initWorkSelectedFlat);
</script>
