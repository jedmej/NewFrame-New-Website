---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';
import { projects as allProjects } from '../../lib/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type ProjectKey = keyof typeof t.work.projects;

type GridProject = {
  key: ProjectKey;
  name: string;
  image?: string;
  category: string;
  url: string;
  placeholder?: boolean;
  tone?: 'warm' | 'cool';
};

const hubertProject: GridProject = {
  key: 'hubert',
  name: 'HUBERT PHOTOGRAPHY',
  image: '/images/work/hubert.webp',
  category: 'WEB',
  url: 'https://hubertkesik.com/',
};

const amvisProject: GridProject = {
  key: 'amvis',
  name: 'AMVIS',
  image: '/images/work/amvis.webp',
  category: 'IN PROGRESS',
  url: '#',
  placeholder: true,
  tone: 'cool',
};

const projectKeyByUrl = {
  'https://urokitattoo.pl/': 'uroki',
  'https://panenkacreatives.com/': 'panenka',
  'https://esthetic.pl/': 'esthetic',
  'https://adfidence.com/': 'adfidence',
} satisfies Record<string, ProjectKey>;

const keyedProjects: GridProject[] = allProjects.map((project) => {
  const key = projectKeyByUrl[project.url];
  if (!key) {
    throw new Error(`Missing selected work project key for ${project.name}`);
  }
  return { ...project, key };
});

const projectsByKey = Object.fromEntries(
  [...keyedProjects, hubertProject, amvisProject].map((project) => [project.key, project])
) as Record<ProjectKey, GridProject>;

const displayNameByKey = {
  hubert: 'Hubert',
  uroki: 'Uroki',
  panenka: 'Panenka',
  esthetic: 'Esthetic',
  adfidence: 'Adfidence',
  amvis: 'Amvis',
} satisfies Record<ProjectKey, string>;

const caseKeys = ['uroki', 'hubert', 'adfidence', 'panenka', 'esthetic'] as const;
const caseProjects = caseKeys.map((key) => projectsByKey[key]);
const firstProject = caseProjects[0];
const firstMeta = t.work.projects[firstProject.key];
const firstRoles = firstMeta.roles.join(' / ');
const padIndex = (index: number) => String(index + 1).padStart(2, '0');
const scrollSpan = 112 + (caseProjects.length - 1) * 45;
---

<section
  id="work-minimal"
  class="work-selected-flat"
  aria-label={t.work.label}
  style={`--work-scroll-span: ${scrollSpan}svh;`}
>
  <div class="work-selected-flat__stage">
    <div class="work-selected-flat__layout">
      <header class="work-selected-flat__title-area">
        <nav class="work-selected-flat__titles" aria-label={t.work.carouselLabel}>
          {caseProjects.map((project, index) => {
            const href = project.placeholder ? undefined : project.url;
            const meta = t.work.projects[project.key];

            return (
              <a
                href={href}
                target={href ? '_blank' : undefined}
                rel={href ? 'noopener noreferrer' : undefined}
                class={`work-selected-flat__title-link${index === 0 ? ' is-active' : ''}`}
                aria-label={`${displayNameByKey[project.key]}. ${meta.description}`}
                aria-current={index === 0 ? 'true' : undefined}
                data-work-title-item
                data-index={index}
                data-title={displayNameByKey[project.key]}
                data-description={meta.description}
                data-roles={meta.roles.join(' / ')}
              >
                {displayNameByKey[project.key]}
              </a>
            );
          })}
        </nav>
      </header>

      <div class="work-selected-flat__project-panel">
        <div class="work-selected-flat__preview" role="list" aria-label={t.work.carouselLabel}>
        {caseProjects.map((project, index) => {
          const href = project.placeholder ? undefined : project.url;
          const meta = t.work.projects[project.key];

          return (
            <a
              href={href}
              target={href ? '_blank' : undefined}
              rel={href ? 'noopener noreferrer' : undefined}
              class={`work-selected-flat__preview-item${index === 0 ? ' is-active' : ''}`}
              role="listitem"
              aria-label={`${displayNameByKey[project.key]}. ${meta.roles.join(' / ')}. ${meta.description}`}
              aria-current={index === 0 ? 'true' : undefined}
              data-work-preview-item
              data-index={index}
            >
              <img
                src={project.image}
                alt={`${displayNameByKey[project.key]} ${project.category}`}
                loading={index < 2 ? 'eager' : 'lazy'}
              />
            </a>
          );
        })}
        </div>

        <aside class="work-selected-flat__note" aria-live="polite">
          <span class="work-selected-flat__note-index" data-work-note-index>{padIndex(0)}</span>
          <div class="work-selected-flat__note-copy">
            <p class="work-selected-flat__roles" data-work-roles>{firstRoles}</p>
            <p class="work-selected-flat__description" data-work-description>{firstMeta.description}</p>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .work-selected-flat {
    --work-ink: var(--offer-work-ink, var(--color-text));
    --work-ink-muted: var(--offer-work-ink-muted, rgba(20, 18, 15, 0.58));
    --work-ink-soft: var(--offer-work-ink-soft, rgba(20, 18, 15, 0.42));
    --work-ink-faint: var(--offer-work-ink-faint, rgba(20, 18, 15, 0.26));
    --work-panel: var(--offer-work-panel, rgba(20, 18, 15, 0.06));
    --work-panel-line: var(--offer-work-panel-line, rgba(20, 18, 15, 0.1));
    --work-title-active-indent: clamp(0.25rem, 0.8vw, 0.9rem);

    position: relative;
    min-height: var(--work-scroll-span);
    background: transparent;
    color: var(--work-ink);
    isolation: isolate;
  }

  .work-selected-flat__stage {
    position: sticky;
    top: 0;
    overflow: hidden;
    height: 100svh;
    padding: clamp(4.5rem, 7.8vw, 5rem) clamp(1.5rem, 4.2vw, 5rem);
    background: transparent;
  }

  .work-selected-flat__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(22rem, clamp(28rem, 32vw, 37.75rem));
    gap: clamp(1.5rem, 3.2vw, 4rem);
    align-items: center;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  .work-selected-flat__title-area {
    display: grid;
    align-self: center;
    min-width: 0;
    overflow: visible;
  }

  .work-selected-flat__titles {
    --work-title-gap: clamp(7.1rem, 11.25vw, 14.5rem);

    position: relative;
    height: min(68vh, clamp(36rem, 48vw, 61rem));
    overflow: visible;
    min-width: 0;
  }

  .work-selected-flat__title-link {
    --work-title-distance: 0;
    --work-title-opacity: 0.95;
    --work-title-blur: 0px;
    --work-title-x: 0px;
    position: absolute;
    top: 50%;
    left: 0;
    display: block;
    width: max-content;
    max-width: 100%;
    color: color-mix(in srgb, var(--work-ink) 18%, transparent);
    font-family: var(--font-sans);
    font-size: clamp(5.25rem, 9.85vw, 12.8rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: 0;
    text-decoration: none;
    text-transform: capitalize;
    white-space: nowrap;
    opacity: var(--work-title-opacity);
    filter: blur(var(--work-title-blur));
    mix-blend-mode: overlay;
    transform: translate3d(var(--work-title-x), calc((var(--work-title-distance) * var(--work-title-gap)) - 50%), 0);
    transition:
      color 0.28s var(--ease-out-quart),
      transform 0.55s var(--ease-out-expo);
    will-change: transform, opacity, filter;
  }

  .work-selected-flat__title-link.is-active {
    color: var(--work-ink);
    mix-blend-mode: normal;
  }

  .work-selected-flat__title-link:hover,
  .work-selected-flat__title-link:focus-visible {
    color: var(--work-ink);
    cursor: pointer;
    transform: translate3d(var(--work-title-active-indent), calc((var(--work-title-distance) * var(--work-title-gap)) - 50%), 0);
  }

  .work-selected-flat__title-link:focus-visible,
  .work-selected-flat__preview-item:focus-visible {
    outline: 1px solid rgba(243, 234, 223, 0.76);
    outline-offset: 0.45rem;
  }

  .work-selected-flat__note p,
  .work-selected-flat__note span {
    margin: 0;
    hyphens: none;
    overflow-wrap: normal;
    text-wrap: pretty;
    word-break: normal;
  }

  .work-selected-flat__word {
    display: inline-block;
    white-space: nowrap;
  }

  .work-selected-flat__project-panel {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    gap: clamp(1.5rem, 2.15vw, 2rem);
    width: min(100%, clamp(28rem, 32vw, 37.75rem));
    justify-self: end;
  }

  .work-selected-flat__preview {
    position: relative;
    width: 100%;
    aspect-ratio: 1.776;
    overflow: hidden;
    border-radius: clamp(0.7rem, 1.25vw, 1.5rem);
    background: var(--work-panel);
  }

  .work-selected-flat__preview-item {
    --work-item-opacity: 0;
    --work-item-scale: 1.035;
    position: absolute;
    inset: 0;
    display: flex;
    overflow: hidden;
    width: 100%;
    height: 100%;
    background: var(--work-panel);
    color: inherit;
    text-decoration: none;
    pointer-events: none;
    opacity: var(--work-item-opacity);
    transform: scale(var(--work-item-scale));
    transition:
      opacity 0.45s var(--ease-out-quart),
      transform 0.7s var(--ease-out-expo);
    z-index: 1;
    will-change: transform, opacity;
  }

  .work-selected-flat__preview-item.is-active {
    pointer-events: auto;
    z-index: 2;
  }

  .work-selected-flat__preview-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    outline: 1px solid var(--work-panel-line);
    outline-offset: -1px;
    transform: scale(1.02);
    transition: transform 0.6s var(--ease-out-quart);
  }

  .work-selected-flat__preview-item:hover img,
  .work-selected-flat__preview-item:focus-visible img {
    transform: scale(1.06);
  }

  .work-selected-flat__note {
    display: flex;
    align-items: flex-start;
    gap: clamp(1rem, 1.7vw, 2rem);
    width: 100%;
    color: var(--work-ink);
    font-family: var(--font-sans);
    font-weight: 300;
    letter-spacing: 0;
  }

  .work-selected-flat__note-index {
    flex: 0 0 auto;
    min-width: 1.5rem;
    color: var(--work-ink-muted);
    font-family: var(--font-mono);
    font-size: clamp(0.72rem, 0.78vw, 0.875rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.12em;
  }

  .work-selected-flat__note-copy {
    display: grid;
    gap: clamp(0.75rem, 1.1vw, 1rem);
    min-width: 0;
  }

  .work-selected-flat__roles {
    color: var(--work-ink-muted);
    font-family: var(--font-mono);
    font-size: clamp(0.68rem, 0.76vw, 0.8125rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .work-selected-flat__description {
    color: var(--work-ink);
    font-size: clamp(1.3rem, 1.68vw, 2rem);
    font-weight: 300;
    line-height: 1.125;
    letter-spacing: 0;
    max-width: 18em;
  }

  @media (max-width: 1180px) {
    .work-selected-flat__layout {
      grid-template-columns: minmax(0, 1fr) minmax(20rem, 32rem);
      gap: clamp(1.75rem, 3.4vw, 3.75rem);
    }

    .work-selected-flat__project-panel {
      width: min(100%, 32rem);
    }

    .work-selected-flat__title-link {
      font-size: clamp(4.75rem, 9.4vw, 9rem);
    }
  }

  @media (max-width: 900px) {
    .work-selected-flat {
      min-height: auto;
    }

    .work-selected-flat__stage {
      position: relative;
      height: auto;
      overflow: clip;
      padding: 6rem 1.25rem 7rem;
    }

    .work-selected-flat__layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
      height: auto;
      min-height: auto;
    }

    .work-selected-flat__title-area {
      transform: none;
      will-change: auto;
    }

    .work-selected-flat__titles {
      display: grid;
      gap: 1rem;
      height: auto;
      overflow: visible;
    }

    .work-selected-flat__title-link {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      font-size: clamp(3.5rem, 17vw, 6.5rem);
      line-height: 0.98;
      filter: blur(2px);
      transform: translate3d(var(--work-title-x), 0, 0);
    }

    .work-selected-flat__title-link.is-active {
      filter: blur(0px);
    }

    .work-selected-flat__project-panel {
      width: 100%;
      align-items: flex-start;
    }

    .work-selected-flat__preview {
      aspect-ratio: 1.32;
      border-radius: 0.85rem;
    }

    .work-selected-flat__preview-item {
      position: absolute;
    }

    .work-selected-flat__note {
      gap: 1rem;
    }

    .work-selected-flat__description {
      font-size: clamp(1.35rem, 7vw, 2rem);
      line-height: 1.08;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-selected-flat {
      min-height: auto;
    }

    .work-selected-flat__stage {
      position: relative;
      height: auto;
    }

    .work-selected-flat__title-link,
    .work-selected-flat__preview-item,
    .work-selected-flat__preview-item img {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  let cleanupFn: (() => void) | null = null;

  function initWorkSelectedFlat() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('work-minimal');
    if (!section) return;

    const titleItems = Array.from(section.querySelectorAll<HTMLElement>('[data-work-title-item]'));
    const previewItems = Array.from(section.querySelectorAll<HTMLElement>('[data-work-preview-item]'));
    const noteIndexEl = section.querySelector<HTMLElement>('[data-work-note-index]');
    const rolesEl = section.querySelector<HTMLElement>('[data-work-roles]');
    const descriptionEl = section.querySelector<HTMLElement>('[data-work-description]');
    const ac = new AbortController();
    const { signal } = ac;
    const triggers: ScrollTrigger[] = [];
    const splitInstances: SplitText[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const desktopQuery = window.matchMedia('(min-width: 901px)');
    let activeIndex = -1;
    let progress = 0;
    let measureFrame = 0;
    const measureTimers: ReturnType<typeof setTimeout>[] = [];
    let copyTween: gsap.core.Tween | gsap.core.Timeline | null = null;
    let scrollScene: ScrollTrigger | null = null;

    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
    const smoothstep = (value: number) => value * value * (3 - 2 * value);
    const finalScrollTail = 0.35;
    const padIndex = (index: number) => String(index + 1).padStart(2, '0');

    const revertCopySplits = () => {
      splitInstances.splice(0).forEach((split) => split.revert());
    };

    const splitCopyToChars = (elements: HTMLElement[]) => {
      const chars: Element[] = [];

      elements.forEach((element) => {
        const existingChars = Array.from(element.querySelectorAll('.work-selected-flat__char'));
        if (existingChars.length) {
          chars.push(...existingChars);
          return;
        }

        const split = new SplitText(element, {
          type: 'words,chars',
          charsClass: 'work-selected-flat__char',
          wordsClass: 'work-selected-flat__word',
        });
        splitInstances.push(split);
        chars.push(...split.chars);
      });

      return chars;
    };

    const measureGeometry = () => {
      section.style.setProperty('--work-progress-width', `${((activeIndex + 1) / Math.max(titleItems.length, 1) * 100).toFixed(2)}%`);
    };

    const applyContinuousFocus = (virtualIndex: number) => {
      titleItems.forEach((item, index) => {
        const distance = index - virtualIndex;
        const absDistance = Math.min(3, Math.abs(distance));
        const focus = smoothstep(clamp(1 - Math.abs(distance), 0, 1));
        item.style.setProperty('--work-title-distance', distance.toFixed(3));
        item.style.setProperty('--work-title-opacity', (1 - absDistance * 0.13).toFixed(3));
        item.style.setProperty('--work-title-blur', `${(absDistance * 1.7).toFixed(2)}px`);
        item.style.setProperty('--work-title-x', `calc(var(--work-title-active-indent) * ${focus.toFixed(3)})`);
      });

      previewItems.forEach((item, index) => {
        const distance = Math.abs(index - virtualIndex);
        const focusHold = 0.18;
        const focusRange = 0.94;
        const heldDistance = clamp((distance - focusHold) / (focusRange - focusHold), 0, 1);
        const focus = smoothstep(1 - heldDistance);
        item.style.setProperty('--work-item-opacity', focus.toFixed(3));
        item.style.setProperty('--work-item-scale', (1.045 - focus * 0.045).toFixed(3));
      });
    };

    const setActiveCopy = (activeTitle: HTMLElement | undefined) => {
      const description = activeTitle?.dataset.description || '';
      const roles = activeTitle?.dataset.roles || '';
      const copyEls = [rolesEl, descriptionEl].filter(Boolean) as HTMLElement[];

      copyTween?.kill();
      gsap.killTweensOf(copyEls);
      revertCopySplits();

      if (rolesEl) rolesEl.textContent = roles;
      if (descriptionEl) descriptionEl.textContent = description;

      if (copyEls.length === 0 || prefersReducedMotion) {
        return;
      }

      copyTween = gsap.fromTo(
        copyEls,
        { autoAlpha: 0, filter: 'blur(12px)', y: 8 },
        {
          autoAlpha: 1,
          filter: 'blur(0px)',
          y: 0,
          duration: 0.46,
          stagger: 0.025,
          ease: 'power4.out',
          overwrite: true,
          onComplete: () => {
            copyTween = null;
          },
        },
      );
    };

    const setActiveIndex = (index: number) => {
      const nextIndex = clamp(index, 0, Math.max(titleItems.length - 1, 0));
      if (nextIndex === activeIndex) return;

      activeIndex = nextIndex;
      const activeTitle = titleItems[nextIndex];

      titleItems.forEach((item, itemIndex) => {
        const isActive = itemIndex === nextIndex;
        item.classList.toggle('is-active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', 'true');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      previewItems.forEach((item, itemIndex) => {
        const isActive = itemIndex === nextIndex;
        item.classList.toggle('is-active', isActive);
        if (isActive) {
          item.setAttribute('aria-current', 'true');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      const paddedIndex = padIndex(nextIndex);
      if (noteIndexEl) noteIndexEl.textContent = paddedIndex;
      section.style.setProperty('--work-progress-width', `${((nextIndex + 1) / Math.max(titleItems.length, 1) * 100).toFixed(2)}%`);
      setActiveCopy(activeTitle);
    };

    const setProgress = (nextProgress: number) => {
      progress = clamp(nextProgress, 0, 1);
      const lastIndex = Math.max(titleItems.length - 1, 1);
      const virtualIndex = progress * (lastIndex + finalScrollTail);
      applyContinuousFocus(virtualIndex);
      setActiveIndex(Math.round(virtualIndex));
    };

    const scheduleMeasure = () => {
      if (measureFrame) window.cancelAnimationFrame(measureFrame);
      measureFrame = window.requestAnimationFrame(() => {
        measureGeometry();
        setProgress(progress);
        measureFrame = 0;
      });
    };

    const scrollToIndex = (index: number) => {
      if (!scrollScene) return;
      const steps = Math.max(titleItems.length - 1, 1);
      const targetProgress = clamp(index / (steps + finalScrollTail), 0, 1);
      const targetY = scrollScene.start + (scrollScene.end - scrollScene.start) * targetProgress;
      const lenis = (window as any).lenis;
      if (lenis?.scrollTo) {
        lenis.scrollTo(targetY, { duration: 1.45 });
      } else {
        window.scrollTo({ top: targetY, behavior: 'smooth' });
      }
    };

    titleItems.forEach((item, index) => {
      item.addEventListener(
        'click',
        (event) => {
          if (!scrollScene) return;
          event.preventDefault();
          scrollToIndex(index);
        },
        { signal }
      );
    });

    previewItems.forEach((item, index) => {
      item.addEventListener('mouseenter', () => setActiveIndex(index), { signal });
      item.addEventListener('focus', () => setActiveIndex(index), { signal });
    });

    measureGeometry();
    setProgress(0);
    scheduleMeasure();
    measureTimers.push(
      window.setTimeout(scheduleMeasure, 260),
      window.setTimeout(scheduleMeasure, 800),
      window.setTimeout(scheduleMeasure, 1400),
    );

    if (!prefersReducedMotion && desktopQuery.matches && titleItems.length > 1) {
      const trigger = ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: true,
        invalidateOnRefresh: true,
        onUpdate: (self) => setProgress(self.progress),
        onRefresh: (self) => {
          measureGeometry();
          setProgress(self.progress);
        },
      });
      scrollScene = trigger;
      triggers.push(trigger);
      setProgress(trigger.progress);

      window.addEventListener('resize', scheduleMeasure, { signal });
      desktopQuery.addEventListener('change', () => {
        scheduleMeasure();
        ScrollTrigger.refresh();
      }, { signal });
    }

    cleanupFn = () => {
      triggers.forEach((trigger) => trigger.kill());
      if (measureFrame) window.cancelAnimationFrame(measureFrame);
      measureTimers.forEach((timer) => window.clearTimeout(timer));
      copyTween?.kill();
      revertCopySplits();
      ac.abort();
    };
  }

  initWorkSelectedFlat();
  document.addEventListener('astro:after-swap', initWorkSelectedFlat);
</script>
