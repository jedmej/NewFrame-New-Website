---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="scope" class="about-paper-section" aria-labelledby="about-title">
  <div class="about-paper-section__inner">
    <header class="about-paper-section__topbar">
      <h2 id="about-title" class="text-mono-xs">{t.about.label}</h2>
      <div class="about-paper-section__rule" data-line></div>
    </header>

    <p
      id="manifesto-text"
      class="about-paper-section__manifesto"
      data-highlights={JSON.stringify(t.about.manifestoHighlights)}
    >
      {t.about.manifesto}
    </p>
  </div>
</section>

<style>
  .about-paper-section__manifesto :global(.manifesto-word) {
    display: inline-block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
    vertical-align: bottom;
  }

  .about-paper-section__manifesto :global(.manifesto-char) {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
  }

  .about-paper-section__manifesto :global(.manifesto-char-inner) {
    display: inline-block;
    will-change: transform, opacity, filter;
  }

  .about-paper-section {
    display: grid;
    min-height: 100svh;
    place-items: center;
    background: transparent;
    color: var(--color-text);
  }

  .about-paper-section__inner {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 100svh;
    width: min(100% - clamp(3rem, 10vw, 10rem), 86rem);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .about-paper-section__topbar {
    visibility: hidden;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(2.25rem, 4vw, 4.5rem);
    width: min(100%, 54rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    color: rgba(24, 24, 26, 0.72);
  }

  .about-paper-section__topbar h2 {
    margin: 0;
  }

  .about-paper-section__rule {
    width: 100%;
    height: 1px;
    background: rgba(24, 24, 26, 0.12);
    transform-origin: left;
  }

  .about-paper-section__manifesto {
    width: min(100%, 54rem);
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.3125rem;
    font-weight: 300;
    line-height: 1.75rem;
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-align: center;
    text-wrap: pretty;
  }

  @media (max-width: 1023px) {
    .about-paper-section__manifesto :global(.manifesto-char-inner) {
      will-change: transform, opacity;
    }

    .about-paper-section__manifesto {
      text-align: left;
    }

    .about-paper-section__inner {
      width: min(100% - (var(--mobile-section-gutter) * 2), 52rem);
      padding-block: clamp(5rem, 12vw, 7rem);
    }

    .about-paper-section__topbar {
      gap: 1.5rem;
      margin-bottom: 3.75rem;
    }

  }

  @media (max-width: 640px) {
    .about-paper-section__inner {
      width: calc(100% - (var(--mobile-section-gutter) * 2));
    }

    .about-paper-section__topbar {
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .about-paper-section__manifesto {
      font-size: 1.70625rem;
      line-height: 1.9rem;
    }

  }

</style>

<script>
  import gsap from 'gsap';
  import { SplitText } from 'gsap/SplitText';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(SplitText, ScrollTrigger);

  let cleanupFn: (() => void) | null = null;

  function initAbout() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('scope');
    const textEl = document.getElementById('manifesto-text');
    const lines = section?.querySelectorAll('[data-line]') || [];
    if (!textEl || !section) return;

    const controller = new AbortController();
    const scrollTriggers: ScrollTrigger[] = [];
    const splitInstances: SplitText[] = [];
    const animatedGlyphs: HTMLElement[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const canUseRevealBlur = window.matchMedia('(min-width: 1024px)').matches;
    const highlights = JSON.parse(textEl.dataset.highlights || '[]') as string[];

    // Character-by-character manifesto reveal.

    const split = new SplitText(textEl, {
      type: 'words,chars',
      wordsClass: 'manifesto-word',
      charsClass: 'manifesto-char',
    });
    splitInstances.push(split);

    split.words.forEach((word: HTMLElement) => {
      word.style.transition = 'none';
      word.style.display = 'inline-block';

      const text = word.textContent?.replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, '') || '';
      if (highlights.some((h: string) => text.toLowerCase() === h.toLowerCase())) {
        word.dataset.highlight = 'true';
      }
    });

    split.chars.forEach((char: HTMLElement) => {
      const inner = document.createElement('span');
      inner.className = 'manifesto-char-inner';
      while (char.firstChild) inner.appendChild(char.firstChild);
      char.appendChild(inner);
      char.style.transition = 'none';
      animatedGlyphs.push(inner);
    });

    if (!prefersReducedMotion) {
      if (lines.length > 0) {
        gsap.set(lines, { scaleX: 0, transformOrigin: 'left' });
        const lineTween = gsap.to(lines, {
          scaleX: 1,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 85%',
            once: true,
          },
        });
        if (lineTween.scrollTrigger) scrollTriggers.push(lineTween.scrollTrigger);
      }

      const manifestoTween = gsap.fromTo(
        animatedGlyphs,
        {
          yPercent: 118,
          opacity: 0,
          filter: canUseRevealBlur ? 'blur(7px)' : 'none',
        },
        {
          yPercent: 0,
          opacity: 1,
          filter: canUseRevealBlur ? 'blur(0px)' : 'none',
          duration: 1,
          ease: 'power3.out',
          stagger: {
            each: 0.009,
            from: 'start',
          },
          scrollTrigger: {
            trigger: textEl,
            start: 'top 88%',
            end: 'bottom 66%',
            scrub: 0.45,
          },
        },
      );
      if (manifestoTween.scrollTrigger) scrollTriggers.push(manifestoTween.scrollTrigger);

    } else {
      split.words.forEach((word: HTMLElement) => {
        if (word.dataset.highlight === 'true') {
          word.style.color = 'var(--color-text)';
        }
      });
    }

    cleanupFn = () => {
      controller.abort();
      scrollTriggers.forEach((st) => st.kill());
      gsap.killTweensOf(animatedGlyphs);
      gsap.set(animatedGlyphs, { clearProps: 'willChange,filter,opacity,transform' });
      splitInstances.forEach((instance) => instance.revert());
    };
  }

  initAbout();

  document.addEventListener('astro:after-swap', () => {
    initAbout();
  });
</script>
