---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="scope" class="about-paper-section" aria-labelledby="about-title">
  <div class="about-paper-section__inner">
    <header class="about-paper-section__topbar">
      <h2 id="about-title" class="text-mono-xs">{t.about.label}</h2>
      <div class="about-paper-section__rule" data-line></div>
    </header>

    <p
      id="manifesto-text"
      class="about-paper-section__manifesto"
      data-highlights={JSON.stringify(t.about.manifestoHighlights)}
    >
      {t.about.manifesto}
    </p>

    <figure id="about-image-block" class="about-paper-section__image-block">
      <img
        src="/images/about-paper-blur.jpg"
        alt={t.about.imageAlt}
        width="970"
        height="460"
        loading="lazy"
        decoding="async"
        class="about-paper-section__image"
      />
      <figcaption id="about-body" class="about-paper-section__caption text-mono-xs">
        {t.about.body}
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .manifesto-word {
    display: inline-block;
  }

  .manifesto-char {
    display: inline-block;
    will-change: opacity;
  }

  @media (min-width: 1024px) {
    .manifesto-char {
      will-change: opacity, filter;
    }
  }

  .about-paper-section {
    background: transparent;
    color: var(--color-text);
  }

  .about-paper-section__inner {
    position: relative;
    z-index: 1;
    width: min(100% - clamp(3rem, 10vw, 10rem), 86rem);
    margin-inline: auto;
    padding-block: clamp(7rem, 11vw, 11.5rem) 0;
  }

  .about-paper-section__topbar {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(2.25rem, 4vw, 4.5rem);
    margin-bottom: clamp(4.75rem, 7.2vw, 7.25rem);
    color: rgba(24, 24, 26, 0.72);
  }

  .about-paper-section__topbar h2 {
    margin: 0;
  }

  .about-paper-section__rule {
    width: 100%;
    height: 1px;
    background: rgba(24, 24, 26, 0.12);
    transform-origin: left;
  }

  .about-paper-section__manifesto {
    max-width: 76rem;
    margin: 0 0 clamp(4.75rem, 7vw, 7rem);
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 4.55vw, 4.8rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: 0;
    color: var(--color-text);
    text-wrap: pretty;
  }

  .about-paper-section__image-block {
    position: relative;
    width: 100vw;
    margin: 0 0 0 calc(50% - 50vw);
    overflow: hidden;
    background: rgba(24, 24, 26, 0.05);
    aspect-ratio: 970 / 460;
    isolation: isolate;
  }

  .about-paper-section__image {
    position: absolute;
    inset: -8% 0;
    width: 100%;
    height: 116%;
    object-fit: cover;
    object-position: 50% 50%;
    will-change: transform;
  }

  .about-paper-section__caption {
    position: absolute;
    left: clamp(1.75rem, 3.4vw, 3rem);
    bottom: clamp(1.6rem, 3vw, 2.6rem);
    z-index: 1;
    max-width: min(22rem, 42%);
    margin: 0;
    color: rgba(24, 24, 26, 0.58);
    line-height: 1.35;
    text-wrap: balance;
  }

  @media (max-width: 1023px) {
    .about-paper-section__inner {
      width: min(100% - 3rem, 52rem);
      padding-block: clamp(5.5rem, 14vw, 8rem) 0;
    }

    .about-paper-section__topbar {
      gap: 1.5rem;
      margin-bottom: 3.75rem;
    }

    .about-paper-section__manifesto {
      font-size: clamp(2.35rem, 8vw, 4rem);
      line-height: 1.03;
      margin-bottom: 3.25rem;
    }

    .about-paper-section__image-block {
      aspect-ratio: 4 / 3;
    }

    .about-paper-section__caption {
      max-width: min(25rem, calc(100% - 3rem));
      color: rgba(24, 24, 26, 0.64);
    }
  }

  @media (max-width: 640px) {
    .about-paper-section__inner {
      width: calc(100% - 2.5rem);
    }

    .about-paper-section__topbar {
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .about-paper-section__manifesto {
      font-size: clamp(2.1rem, 11vw, 3rem);
    }

    .about-paper-section__image-block {
      aspect-ratio: 3 / 4;
    }

    .about-paper-section__caption {
      left: 1.25rem;
      bottom: 1.25rem;
      max-width: calc(100% - 2.5rem);
    }
  }

</style>

<script>
  import gsap from 'gsap';
  import { SplitText } from 'gsap/SplitText';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(SplitText, ScrollTrigger);

  let cleanupFn: (() => void) | null = null;

  function initAbout() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('scope');
    const textEl = document.getElementById('manifesto-text');
    const imageBlock = document.getElementById('about-image-block');
    const imageEl = imageBlock?.querySelector<HTMLElement>('.about-paper-section__image') ?? null;
    const bodyEl = document.getElementById('about-body');
    const lines = section?.querySelectorAll('[data-line]') || [];
    if (!textEl || !section) return;

    const scrollTriggers: ScrollTrigger[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const usesDesktopRevealBlur = window.matchMedia('(min-width: 1024px)').matches;
    const highlights = JSON.parse(textEl.dataset.highlights || '[]') as string[];

    // ===== Character-by-character manifesto reveal =====

    const split = new SplitText(textEl, {
      type: 'words,chars',
      wordsClass: 'manifesto-word',
      charsClass: 'manifesto-char',
    });

    split.words.forEach((word: HTMLElement) => {
      word.style.transition = 'none';
      word.style.display = 'inline-block';

      const text = word.textContent?.replace(/[^a-zA-ZąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/g, '') || '';
      if (highlights.some((h: string) => text.toLowerCase() === h.toLowerCase())) {
        word.dataset.highlight = 'true';
      }
    });

    split.chars.forEach((char: HTMLElement) => {
      char.style.opacity = prefersReducedMotion ? '1' : '0.06';
      char.style.filter = !prefersReducedMotion && usesDesktopRevealBlur ? 'blur(5px)' : 'none';
      char.style.transition = 'none';
    });

    if (!prefersReducedMotion) {
      if (lines.length > 0) {
        gsap.set(lines, { scaleX: 0, transformOrigin: 'left' });
        const lineTween = gsap.to(lines, {
          scaleX: 1,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 85%',
            once: true,
          },
        });
        if (lineTween.scrollTrigger) scrollTriggers.push(lineTween.scrollTrigger);
      }

      // Character reveal on scroll — same smooth frontier as testimonials
      scrollTriggers.push(ScrollTrigger.create({
        trigger: textEl,
        start: 'top 80%',
        end: 'bottom 40%',
        scrub: 1,
        onUpdate: (self) => {
          const totalChars = split.chars.length;
          const revealCenter = self.progress * totalChars;
          const spread = 8;

          split.chars.forEach((char: HTMLElement, ci: number) => {
            const t = (revealCenter - ci + spread) / spread;
            const clamped = Math.min(1, Math.max(0, t));
            const opacity = 0.06 + clamped * 0.94;
            const blur = (1 - clamped) * 5;
            char.style.opacity = String(opacity);
            char.style.filter = usesDesktopRevealBlur ? `blur(${blur.toFixed(2)}px)` : 'none';
          });
        },
      }));

      // Image block reveal
      if (imageBlock) {
        gsap.set(imageBlock, { willChange: 'clip-path, filter' });
        const maskTween = gsap.fromTo(imageBlock,
          { clipPath: 'inset(100% 0 0 0)', filter: 'blur(10px)' },
          {
            clipPath: 'inset(0% 0 0 0)',
            filter: 'blur(0px)',
            duration: 1.25,
            ease: 'power4.out',
            scrollTrigger: {
              trigger: imageBlock,
              start: 'top 85%',
              once: true,
            },
          }
        );
        if (maskTween.scrollTrigger) scrollTriggers.push(maskTween.scrollTrigger);

        if (imageEl) {
          const imageParallax = gsap.fromTo(imageEl,
            { yPercent: -4 },
            {
              yPercent: 4,
              ease: 'none',
              scrollTrigger: {
                trigger: imageBlock,
                start: 'top bottom',
                end: 'bottom top',
                scrub: 1.15,
              },
            }
          );
          if (imageParallax.scrollTrigger) scrollTriggers.push(imageParallax.scrollTrigger);
        }
      }

      // Body text reveal
      if (bodyEl) {
        const bodyTween = gsap.fromTo(bodyEl,
          { opacity: 0, filter: 'blur(8px)' },
          {
            opacity: 1,
            filter: 'blur(0px)',
            duration: 1,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: bodyEl,
              start: 'top 85%',
              once: true,
            },
          }
        );
        if (bodyTween.scrollTrigger) scrollTriggers.push(bodyTween.scrollTrigger);
      }

    } else {
      split.words.forEach((word: HTMLElement) => {
        if (word.dataset.highlight === 'true') {
          word.style.color = 'var(--color-text)';
        }
      });
    }

    cleanupFn = () => {
      scrollTriggers.forEach((st) => st.kill());
      split.revert();
    };
  }

  initAbout();

  document.addEventListener('astro:after-swap', () => {
    initAbout();
  });
</script>
