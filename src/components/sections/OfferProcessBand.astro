---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';
import WorkSelectedMinimal from './WorkSelectedMinimal.astro';
import WaysToWorkProductGrid from './WaysToWorkProductGrid.astro';
import ProcessAlternative from './ProcessAlternative.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const normalizeHeading = (value: string) => value.toLocaleLowerCase(lang === 'pl' ? 'pl-PL' : 'en-US').replace(/^./u, (char) => char.toLocaleUpperCase(lang === 'pl' ? 'pl-PL' : 'en-US'));
const introHeadings = {
  work: normalizeHeading(t.work.label),
  ways: normalizeHeading(t.waysToWork.label),
  process: t.services.heading,
};
---

<div class="offer-process-band" data-offer-process-band>
  <div class="offer-process-band__background" aria-hidden="true">
    <div class="offer-process-band__shader" data-offer-process-shader></div>
  </div>

  <div class="offer-process-band__content">
    <section id="work" class="offer-process-band__intro" data-offer-section-intro data-offer-section-intro-kind="work" aria-label={introHeadings.work}>
      <h2>{introHeadings.work}</h2>
    </section>
    <WorkSelectedMinimal lang={lang} />

    <section id="ways-to-work" class="offer-process-band__intro" data-offer-section-intro data-offer-section-intro-kind="ways" aria-label={introHeadings.ways}>
      <h2>{introHeadings.ways}</h2>
    </section>
    <WaysToWorkProductGrid lang={lang} />

    <section id="services" class="offer-process-band__intro" data-offer-section-intro data-offer-section-intro-kind="process" aria-label={introHeadings.process}>
      <h2>{introHeadings.process}</h2>
    </section>
    <ProcessAlternative lang={lang} />
  </div>
</div>

<style>
  .offer-process-band {
    --offer-process-bg: #F4F4F4;
    --offer-process-fade-size: clamp(9rem, 22svh, 20rem);
    --offer-process-shader-opacity: 0.26;
    --offer-work-to-blue-progress: 0;
    --offer-work-ink: var(--color-text);
    --offer-work-ink-muted: rgba(20, 18, 15, 0.58);
    --offer-work-ink-soft: rgba(20, 18, 15, 0.42);
    --offer-work-ink-faint: rgba(20, 18, 15, 0.26);
    --offer-work-panel: rgba(20, 18, 15, 0.06);
    --offer-work-panel-line: rgba(20, 18, 15, 0.1);

    position: relative;
    background: var(--offer-process-bg);
    isolation: isolate;
  }

  .offer-process-band::before,
  .offer-process-band::after {
    position: absolute;
    left: 0;
    z-index: 1;
    width: 100%;
    height: var(--offer-process-fade-size);
    pointer-events: none;
    content: '';
  }

  .offer-process-band::before {
    top: calc(var(--offer-process-fade-size) * -1);
    background:
      linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--offer-process-bg) 18%, transparent) 34%,
        var(--offer-process-bg) 100%
      );
  }

  .offer-process-band::after {
    bottom: calc(var(--offer-process-fade-size) * -1);
    background:
      linear-gradient(
        180deg,
        var(--offer-process-bg) 0%,
        color-mix(in srgb, var(--offer-process-bg) 18%, transparent) 58%,
        transparent 100%
      );
  }

  .offer-process-band__background {
    position: sticky;
    top: 0;
    z-index: 0;
    height: 100svh;
    margin-bottom: -100svh;
    overflow: clip;
    pointer-events: none;
  }

  .offer-process-band__shader {
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: var(--offer-process-shader-opacity);
    will-change: opacity;
  }

  .offer-process-band__shader > :global(*) {
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    min-width: 100% !important;
    min-height: 100% !important;
    transform: translate3d(-50%, -50%, 0) !important;
  }

  .offer-process-band__content {
    position: relative;
    z-index: 2;
  }

  .offer-process-band__intro {
    position: relative;
    display: grid;
    min-height: 90svh;
    place-items: center;
    padding: clamp(3.5rem, 7vw, 4rem) clamp(1.5rem, 8.9vw, 8rem);
    color: var(--offer-work-ink);
    text-align: center;
    isolation: isolate;
  }

  .offer-process-band__intro h2 {
    max-width: min(11ch, 80vw);
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 8vw, 7.4rem);
    font-weight: 500;
    line-height: 0.92;
    letter-spacing: -0.05em;
    text-transform: none;
    text-wrap: balance;
  }

  .offer-process-band__intro[data-offer-section-intro-kind='ways'],
  .offer-process-band__intro[data-offer-section-intro-kind='process'] {
    color: #f3efe5;
  }

  .offer-process-band__intro[data-offer-section-intro-kind='process'] h2 {
    max-width: min(17ch, 88vw);
    font-size: clamp(3rem, 6.45vw, 6.3rem);
    line-height: 0.96;
  }

  @media (max-width: 767px) {
    .offer-process-band__intro {
      min-height: 82svh;
      padding-inline: clamp(1.5rem, 7vw, 2.5rem);
    }

    .offer-process-band__intro h2 {
      max-width: 9ch;
      font-size: clamp(3rem, 16vw, 5rem);
      line-height: 0.92;
      letter-spacing: -0.045em;
    }

    .offer-process-band__intro[data-offer-section-intro-kind='process'] h2 {
      max-width: 10ch;
      font-size: clamp(2.9rem, 13vw, 4.6rem);
      line-height: 0.98;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { mountNeuroSectionShader } from '../../scripts/neuroSectionShader';

  gsap.registerPlugin(ScrollTrigger);

  let cleanupFn: (() => void) | null = null;

  function initOfferProcessBand() {
    cleanupFn?.();
    cleanupFn = null;

    const band = document.querySelector<HTMLElement>('[data-offer-process-band]');
    if (!band) return;

    const ac = new AbortController();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const shaderMount = band.querySelector<HTMLElement>('[data-offer-process-shader]');
    const workIntro = band.querySelector<HTMLElement>('[data-offer-section-intro-kind="work"]');
    const waysIntro = band.querySelector<HTMLElement>('[data-offer-section-intro-kind="ways"]');
    const processIntro = band.querySelector<HTMLElement>('[data-offer-section-intro-kind="process"]');
    const waysSection = band.querySelector<HTMLElement>('#ways-to-work-grid');
    const processSection = band.querySelector<HTMLElement>('#process-alternative');
    const scrollTriggers: ScrollTrigger[] = [];
    let shader: ReturnType<typeof mountNeuroSectionShader> | null = null;
    let workToWaysProgress = 0;
    let waysToProcessProgress = 0;
    let lastShaderSurfaceProgress = -1;
    let lastShaderSpeed = -1;
    const introPulses = new Map<HTMLElement, number>();
    const clamp = (value: number) => Math.max(0, Math.min(1, value));
    const easeSurface = gsap.parseEase('power2.inOut');
    const shaderBaseSpeed = 0.5;
    const shaderTransitionSpeed = 3.35;
    const transitionPulse = (progress: number) => Math.sin(clamp(progress) * Math.PI);

    if (!prefersReducedMotion && shaderMount) {
      shader = mountNeuroSectionShader(shaderMount, {
        colorMid: '#FFFDFB',
        colorFront: '#00000080',
        contrast: 0,
        speed: shaderBaseSpeed,
      });
    }

    const updateBandSurface = () => {
      const workProgress = easeSurface(clamp(workToWaysProgress));
      const processProgress = easeSurface(clamp(waysToProcessProgress));
      const blueBg = gsap.utils.interpolate('#F4F4F4', '#1a1b64', workProgress);
      const bg = gsap.utils.interpolate(blueBg, '#172825', processProgress);
      const shaderOpacity = 0.26 + workProgress * 0.74;
      const workShaderMid = gsap.utils.interpolate('#D4C9BF', '#FFFDFB', workProgress);
      const workShaderFront = gsap.utils.interpolate('#00000080', 'rgba(255, 255, 255, 0.5)', workProgress);
      const shaderContrast = gsap.utils.interpolate(0, 1, workProgress);

      band.style.setProperty('--offer-work-to-blue-progress', workProgress.toFixed(3));
      band.style.setProperty('--offer-process-bg', bg);
      band.style.setProperty('--offer-process-shader-opacity', shaderOpacity.toFixed(3));
      band.style.setProperty('--offer-work-ink', gsap.utils.interpolate('#14120f', '#f3eadf', workProgress));
      band.style.setProperty('--offer-work-ink-muted', gsap.utils.interpolate('rgba(20, 18, 15, 0.58)', 'rgba(243, 234, 223, 0.62)', workProgress));
      band.style.setProperty('--offer-work-ink-soft', gsap.utils.interpolate('rgba(20, 18, 15, 0.42)', 'rgba(243, 234, 223, 0.42)', workProgress));
      band.style.setProperty('--offer-work-ink-faint', gsap.utils.interpolate('rgba(20, 18, 15, 0.26)', 'rgba(243, 234, 223, 0.26)', workProgress));
      band.style.setProperty('--offer-work-panel', gsap.utils.interpolate('rgba(20, 18, 15, 0.06)', 'rgba(243, 234, 223, 0.08)', workProgress));
      band.style.setProperty('--offer-work-panel-line', gsap.utils.interpolate('rgba(20, 18, 15, 0.1)', 'rgba(255, 255, 255, 0.14)', workProgress));

      if (!shader) return;

      const shaderSurfaceProgress = Math.max(workProgress, processProgress);
      const shaderPulse = Math.max(
        transitionPulse(workToWaysProgress),
        transitionPulse(waysToProcessProgress),
        ...Array.from(introPulses.values()),
      );
      const shaderSpeed = shaderBaseSpeed + shaderPulse * (shaderTransitionSpeed - shaderBaseSpeed);
      const shouldUpdateSurface = Math.abs(shaderSurfaceProgress - lastShaderSurfaceProgress) > 0.025;
      const shouldUpdateSpeed = Math.abs(shaderSpeed - lastShaderSpeed) > 0.04;

      if (!shouldUpdateSurface && !shouldUpdateSpeed) return;

      lastShaderSurfaceProgress = shaderSurfaceProgress;
      lastShaderSpeed = shaderSpeed;
      shader.update({
        colorMid: gsap.utils.interpolate(workShaderMid, '#EAF2E8', processProgress),
        colorFront: gsap.utils.interpolate(workShaderFront, 'rgba(255, 255, 255, 0.69)', processProgress),
        contrast: shaderContrast,
        speed: shaderSpeed,
      });
    };

    updateBandSurface();

    [workIntro, waysIntro, processIntro].filter((intro): intro is HTMLElement => !!intro).forEach((intro) => {
      introPulses.set(intro, 0);
      scrollTriggers.push(ScrollTrigger.create({
        trigger: intro,
        start: 'top bottom',
        end: 'bottom top',
        scrub: prefersReducedMotion ? false : true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          introPulses.set(intro, transitionPulse(self.progress));
          updateBandSurface();
        },
        onRefresh: (self) => {
          introPulses.set(intro, transitionPulse(self.progress));
          updateBandSurface();
        },
      }));
    });

    if (waysIntro || waysSection) {
      scrollTriggers.push(ScrollTrigger.create({
        trigger: waysIntro ?? waysSection,
        start: 'top 100%',
        end: 'bottom 22%',
        scrub: prefersReducedMotion ? false : true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          workToWaysProgress = self.progress;
          updateBandSurface();
        },
        onRefresh: (self) => {
          workToWaysProgress = self.progress;
          updateBandSurface();
        },
      }));
    }

    if (processIntro || processSection) {
      scrollTriggers.push(ScrollTrigger.create({
        trigger: processIntro ?? processSection,
        start: 'top 100%',
        end: 'bottom 22%',
        scrub: prefersReducedMotion ? false : true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          waysToProcessProgress = self.progress;
          updateBandSurface();
        },
        onRefresh: (self) => {
          waysToProcessProgress = self.progress;
          updateBandSurface();
        },
      }));
    }

    cleanupFn = () => {
      scrollTriggers.forEach((trigger) => trigger.kill());
      shader?.destroy();
      ac.abort();
    };
  }

  initOfferProcessBand();
  document.addEventListener('astro:after-swap', initOfferProcessBand);
</script>
