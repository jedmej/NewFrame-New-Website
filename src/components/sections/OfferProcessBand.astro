---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';
import Hero from './Hero.astro';
import About from './About.astro';
import WorkSelectedCards from './WorkSelectedCards.astro';
import WaysToWorkPaperRows from './WaysToWorkPaperRows.astro';
import Testimonials from './Testimonials.astro';
import Footer from '../global/Footer.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const normalizeHeading = (value: string) => value.toLocaleLowerCase(lang === 'pl' ? 'pl-PL' : 'en-US').replace(/^./u, (char) => char.toLocaleUpperCase(lang === 'pl' ? 'pl-PL' : 'en-US'));
const introHeadings = {
  work: normalizeHeading(t.work.label),
  ways: normalizeHeading(t.waysToWork.label),
  testimonials: t.testimonials.heading,
};
---

<div class="offer-process-band" data-offer-process-band data-offer-process-surface="A">
  <div class="offer-process-band__background" aria-hidden="true">
    <div class="offer-process-band__shader" data-offer-process-shader></div>
  </div>

  <div class="offer-process-band__content">
    <Hero lang={lang} />
    <About lang={lang} />

    <section id="work" class="offer-process-band__intro" data-offer-section-intro data-offer-section-intro-kind="work" aria-label={introHeadings.work}>
      <h2>{introHeadings.work}</h2>
    </section>
    <WorkSelectedCards lang={lang} />

    <section id="ways-to-work" class="offer-process-band__intro" data-offer-section-intro data-offer-section-intro-kind="ways" aria-label={introHeadings.ways}>
      <h2>{introHeadings.ways}</h2>
    </section>
    <WaysToWorkPaperRows lang={lang} />

    <section id="testimonials-intro" class="offer-process-band__intro" data-offer-section-intro data-offer-section-intro-kind="testimonials" aria-label={introHeadings.testimonials}>
      <h2>{introHeadings.testimonials}</h2>
    </section>
    <Testimonials lang={lang} />
    <Footer lang={lang} />
  </div>
</div>

<style>
  .offer-process-band {
    --offer-process-bg: #F4F4F4;
    --offer-process-fade-size: clamp(9rem, 22svh, 20rem);
    --offer-process-grain-opacity: 0.1;
    --offer-process-grain-size-a: 53px;
    --offer-process-grain-size-b: 79px;
    --offer-process-shader-opacity: 0.26;
    --offer-work-to-blue-progress: 0;
    --offer-work-ink: var(--color-text);
    --offer-work-ink-muted: rgba(20, 18, 15, 0.58);
    --offer-work-ink-soft: rgba(20, 18, 15, 0.42);
    --offer-work-ink-faint: rgba(20, 18, 15, 0.26);
    --offer-work-panel: rgba(20, 18, 15, 0.06);
    --offer-work-panel-line: rgba(20, 18, 15, 0.1);

    position: relative;
    background: var(--offer-process-bg);
    isolation: isolate;
  }

  .offer-process-band::before,
  .offer-process-band::after {
    position: absolute;
    left: 0;
    z-index: 1;
    width: 100%;
    height: var(--offer-process-fade-size);
    pointer-events: none;
    content: '';
  }

  .offer-process-band::before {
    top: calc(var(--offer-process-fade-size) * -1);
    background:
      linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--offer-process-bg) 20%, transparent) 42%,
        var(--offer-process-bg) 100%
      );
  }

  .offer-process-band::after {
    bottom: 0;
    background:
      linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--offer-process-bg) 18%, transparent) 42%,
        var(--offer-process-bg) 100%
      );
  }

  .offer-process-band__background {
    position: sticky;
    top: 0;
    z-index: 0;
    height: 100svh;
    margin-bottom: -100svh;
    overflow: clip;
    pointer-events: none;
  }

  .offer-process-band__background::after {
    position: absolute;
    inset: -16%;
    z-index: 2;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 53 53' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='grain'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='4.1' numOctaves='7' seed='11' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3CfeComponentTransfer%3E%3CfeFuncA type='table' tableValues='0 0.78'/%3E%3C/feComponentTransfer%3E%3C/filter%3E%3Crect width='53' height='53' filter='url(%23grain)'/%3E%3C/svg%3E"),
      url("data:image/svg+xml,%3Csvg viewBox='0 0 79 79' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='grain'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='3.45' numOctaves='6' seed='23' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0'/%3E%3CfeComponentTransfer%3E%3CfeFuncA type='table' tableValues='0 0.58'/%3E%3C/feComponentTransfer%3E%3C/filter%3E%3Crect width='79' height='79' filter='url(%23grain)'/%3E%3C/svg%3E");
    background-position:
      0 0,
      19px 31px;
    background-size:
      var(--offer-process-grain-size-a) var(--offer-process-grain-size-a),
      var(--offer-process-grain-size-b) var(--offer-process-grain-size-b);
    mix-blend-mode: soft-light;
    opacity: var(--offer-process-grain-opacity);
    pointer-events: none;
    content: '';
    transition:
      opacity 180ms var(--ease-out-quart),
      visibility 180ms var(--ease-out-quart);
  }

  :global(.film-grain-disabled) .offer-process-band__background::after {
    opacity: 0;
    visibility: hidden;
  }

  .offer-process-band__shader {
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: var(--offer-process-shader-opacity);
    transition:
      opacity 220ms var(--ease-out-quart),
      visibility 220ms var(--ease-out-quart);
    will-change: opacity;
  }

  :global(.shader-background-disabled) .offer-process-band__shader {
    opacity: 0 !important;
    visibility: hidden;
  }

  .offer-process-band__shader > :global(*) {
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    min-width: 100% !important;
    min-height: 100% !important;
    transform: translate3d(-50%, -50%, 0) !important;
  }

  .offer-process-band__content {
    position: relative;
    z-index: 2;
  }

  .offer-process-band__intro {
    position: relative;
    display: grid;
    min-height: 90svh;
    place-items: center;
    padding: clamp(3.5rem, 7vw, 4rem) clamp(1.5rem, 8.9vw, 8rem);
    color: var(--offer-work-ink);
    text-align: center;
    isolation: isolate;
  }

  .offer-process-band__intro h2 {
    max-width: min(11ch, 80vw);
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 4.35vw, 3rem);
    font-weight: 300;
    line-height: 0.96;
    letter-spacing: -0.03em;
    text-transform: none;
    text-wrap: balance;
  }

  .offer-process-band__intro h2 :global(.offer-intro-title-word) {
    display: inline-block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
    vertical-align: bottom;
  }

  .offer-process-band__intro h2 :global(.offer-intro-title-char) {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
  }

  .offer-process-band__intro h2 :global(.offer-intro-title-char-inner) {
    display: inline-block;
    will-change: transform, opacity, filter;
  }

  .offer-process-band__intro[data-offer-section-intro-kind='ways'],
  .offer-process-band__intro[data-offer-section-intro-kind='testimonials'] {
    color: #f3efe5;
  }

  .offer-process-band__intro[data-offer-section-intro-kind='work'] {
    min-height: auto;
    padding-block: clamp(12rem, 20vw, 17rem);
  }

  .offer-process-band__intro[data-offer-section-intro-kind='testimonials'] h2 {
    max-width: min(12ch, 86vw);
  }

  @media (max-width: 767px) {
    .offer-process-band__intro {
      min-height: 82svh;
      padding-inline: var(--mobile-section-gutter);
    }

    .offer-process-band__intro h2 {
      max-width: 9ch;
      font-size: clamp(2.65rem, 12vw, 3rem);
      line-height: 0.96;
      letter-spacing: -0.03em;
    }

    .offer-process-band__intro[data-offer-section-intro-kind='work'] {
      min-height: auto;
      padding-block: clamp(10rem, 36vw, 13rem);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  import { mountNeuroSectionShader } from '../../scripts/neuroSectionShader';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  let cleanupFn: (() => void) | null = null;

  function initOfferProcessBand() {
    cleanupFn?.();
    cleanupFn = null;

    const band = document.querySelector<HTMLElement>('[data-offer-process-band]');
    if (!band) return;

    const ac = new AbortController();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const shaderMount = band.querySelector<HTMLElement>('[data-offer-process-shader]');
    const workIntro = band.querySelector<HTMLElement>('[data-offer-section-intro-kind="work"]');
    const waysIntro = band.querySelector<HTMLElement>('[data-offer-section-intro-kind="ways"]');
    const testimonialsIntro = band.querySelector<HTMLElement>('[data-offer-section-intro-kind="testimonials"]');
    const introSections = [workIntro, waysIntro, testimonialsIntro].filter((intro): intro is HTMLElement => !!intro);
    const aboutSection = band.querySelector<HTMLElement>('#scope');
    const waysRowsSection = band.querySelector<HTMLElement>('#ways-to-work-paper-rows');
    const testimonialsSection = band.querySelector<HTMLElement>('#testimonials');
    const scrollTriggers: ScrollTrigger[] = [];
    const splitInstances: SplitText[] = [];
    const introTitleGlyphs: HTMLElement[] = [];
    let shader: ReturnType<typeof mountNeuroSectionShader> | null = null;
    let workToWaysProgress = 0;
    let waysToTestimonialsProgress = 0;
    let testimonialsToFooterProgress = 0;
    let aboutHoldProgress = 0;
    let waysHoldProgress = 0;
    let lastShaderSurfaceProgress = -1;
    let lastShaderSpeed = -1;
    let shaderVelocityBoost = 0;
    let shaderVelocityFrame = 0;
    const introPulses = new Map<HTMLElement, number>();
    const clamp = (value: number) => Math.max(0, Math.min(1, value));
    const easeSurface = gsap.parseEase('power2.inOut');
    const shaderBaseSpeed = 0.5;
    const shaderTransitionSpeed = 3.35;
    const transitionPulse = (progress: number) => Math.sin(clamp(progress) * Math.PI);

    if (!prefersReducedMotion) {
      introSections.forEach((intro) => {
        const title = intro.querySelector<HTMLElement>('h2');
        if (!title) return;

        const split = new SplitText(title, {
          type: 'words,chars',
          wordsClass: 'offer-intro-title-word',
          charsClass: 'offer-intro-title-char',
        });
        splitInstances.push(split);

        const glyphs = split.chars.map((char) => {
          const inner = document.createElement('span');
          inner.className = 'offer-intro-title-char-inner';
          while (char.firstChild) inner.appendChild(char.firstChild);
          char.appendChild(inner);
          return inner;
        });
        introTitleGlyphs.push(...glyphs);

        const revealTween = gsap.fromTo(
          glyphs,
          {
            yPercent: 112,
            opacity: 0,
            filter: 'blur(8px)',
          },
          {
            yPercent: 0,
            opacity: 1,
            filter: 'blur(0px)',
            duration: 1,
            ease: 'power3.out',
            stagger: {
              each: 0.018,
              from: 'start',
            },
            scrollTrigger: {
              trigger: title,
              start: 'top 88%',
              end: 'center 54%',
              scrub: 0.9,
            },
          },
        );
        if (revealTween.scrollTrigger) scrollTriggers.push(revealTween.scrollTrigger);
      });
    }

    if (!prefersReducedMotion && shaderMount) {
      shader = mountNeuroSectionShader(shaderMount, {
        colorMid: '#BDB4AA',
        colorFront: '#000000B0',
        contrast: 0.18,
        speed: shaderBaseSpeed,
      });
    }

    const updateBandSurface = () => {
      const workProgress = easeSurface(clamp(workToWaysProgress));
      const testimonialsProgress = easeSurface(clamp(waysToTestimonialsProgress));
      const blueBg = gsap.utils.interpolate('#F4F4F4', '#1a1b64', workProgress);
      const testimonialBg = gsap.utils.interpolate(blueBg, '#C43E3D', testimonialsProgress);
      const bg = gsap.utils.interpolate(testimonialBg, '#14120F', easeSurface(clamp(testimonialsToFooterProgress)));
      const shaderOpacity = 0.38 + workProgress * 0.62;
      const workShaderMid = gsap.utils.interpolate('#BDB4AA', '#FFFDFB', workProgress);
      const workShaderFront = gsap.utils.interpolate('#000000B0', 'rgba(255, 255, 255, 0.5)', workProgress);
      const shaderContrast = gsap.utils.interpolate(0.18, 1, workProgress);

      band.style.setProperty('--offer-work-to-blue-progress', workProgress.toFixed(3));
      band.style.setProperty('--offer-process-bg', bg);
      band.style.setProperty('--offer-process-grain-opacity', (0.1 + workProgress * 0.18 + testimonialsProgress * 0.1).toFixed(3));
      band.style.setProperty('--offer-process-shader-opacity', (shaderOpacity + testimonialsProgress * 0.1).toFixed(3));
      band.style.setProperty('--offer-work-ink', gsap.utils.interpolate('#14120f', '#f3eadf', Math.max(workProgress, testimonialsProgress)));
      band.style.setProperty('--offer-work-ink-muted', gsap.utils.interpolate('rgba(20, 18, 15, 0.58)', 'rgba(243, 234, 223, 0.62)', Math.max(workProgress, testimonialsProgress)));
      band.style.setProperty('--offer-work-ink-soft', gsap.utils.interpolate('rgba(20, 18, 15, 0.42)', 'rgba(243, 234, 223, 0.42)', Math.max(workProgress, testimonialsProgress)));
      band.style.setProperty('--offer-work-ink-faint', gsap.utils.interpolate('rgba(20, 18, 15, 0.26)', 'rgba(243, 234, 223, 0.26)', Math.max(workProgress, testimonialsProgress)));
      band.style.setProperty('--offer-work-panel', gsap.utils.interpolate('rgba(20, 18, 15, 0.06)', 'rgba(243, 234, 223, 0.08)', Math.max(workProgress, testimonialsProgress)));
      band.style.setProperty('--offer-work-panel-line', gsap.utils.interpolate('rgba(20, 18, 15, 0.1)', 'rgba(255, 255, 255, 0.14)', Math.max(workProgress, testimonialsProgress)));

      if (!shader) return;

      const footerProgress = easeSurface(clamp(testimonialsToFooterProgress));
      const shaderSurfaceProgress = Math.max(workProgress, testimonialsProgress, footerProgress);
      const shaderPulseRaw = Math.max(
        transitionPulse(workToWaysProgress),
        transitionPulse(waysToTestimonialsProgress),
        ...Array.from(introPulses.values()),
      );
      const holdProgress = Math.max(aboutHoldProgress, waysHoldProgress);
      const shaderPulse = gsap.utils.interpolate(shaderPulseRaw, 0, holdProgress * 0.82);
      const heldVelocityBoost = shaderVelocityBoost * (1 - holdProgress * 0.75);
      const shaderSpeed = shaderBaseSpeed + shaderPulse * (shaderTransitionSpeed - shaderBaseSpeed) + heldVelocityBoost;
      const shouldUpdateSurface = Math.abs(shaderSurfaceProgress - lastShaderSurfaceProgress) > 0.025;
      const shouldUpdateSpeed = Math.abs(shaderSpeed - lastShaderSpeed) > 0.04;

      if (!shouldUpdateSurface && !shouldUpdateSpeed) return;

      lastShaderSurfaceProgress = shaderSurfaceProgress;
      lastShaderSpeed = shaderSpeed;
      shader.update({
        colorMid: gsap.utils.interpolate(gsap.utils.interpolate(workShaderMid, '#FFD6CC', testimonialsProgress), '#8F8477', footerProgress),
        colorFront: gsap.utils.interpolate(gsap.utils.interpolate(workShaderFront, 'rgba(255, 255, 255, 0.72)', testimonialsProgress), 'rgba(243, 234, 223, 0.34)', footerProgress),
        contrast: shaderContrast,
        speed: shaderSpeed,
      });
    };

    const animateShaderVelocityReturn = () => {
      shaderVelocityFrame = window.requestAnimationFrame(animateShaderVelocityReturn);
      shaderVelocityBoost *= 0.88;

      if (shaderVelocityBoost < 0.01) {
        shaderVelocityBoost = 0;
        if (shaderVelocityFrame) window.cancelAnimationFrame(shaderVelocityFrame);
        shaderVelocityFrame = 0;
      }

      updateBandSurface();
    };

	    const setShaderVelocityBoost = (velocity: number) => {
	      const velocityProgress = easeSurface(clamp(Math.abs(velocity) / 3200));
	      shaderVelocityBoost = velocityProgress * 1.05;
	      updateBandSurface();
	      if (!shaderVelocityFrame) animateShaderVelocityReturn();
	    };
	
	    const getElementProgress = (element: HTMLElement | null, startViewportRatio: number, endViewportRatio: number) => {
	      if (!element) return 0;

	      const rect = element.getBoundingClientRect();
	      const top = rect.top + window.scrollY;
	      const bottom = rect.bottom + window.scrollY;
	      const start = top - window.innerHeight * startViewportRatio;
	      const end = bottom - window.innerHeight * endViewportRatio;
	      const distance = end - start;

	      if (distance <= 0) return window.scrollY >= end ? 1 : 0;
	      return clamp((window.scrollY - start) / distance);
	    };

	    const getElementBottomProgress = (element: HTMLElement | null, startViewportRatio: number, endViewportRatio: number) => {
	      if (!element) return 0;

	      const rect = element.getBoundingClientRect();
	      const bottom = rect.bottom + window.scrollY;
	      const start = bottom - window.innerHeight * startViewportRatio;
	      const end = bottom - window.innerHeight * endViewportRatio;
	      const distance = end - start;

	      if (distance <= 0) return window.scrollY >= end ? 1 : 0;
	      return clamp((window.scrollY - start) / distance);
	    };

	    const syncSurfaceProgressFromLayout = () => {
	      workToWaysProgress = getElementProgress(waysIntro ?? waysRowsSection, 1, 0.22);
	      waysToTestimonialsProgress = getElementProgress(testimonialsIntro ?? testimonialsSection, 1, 0.18);
	      testimonialsToFooterProgress = getElementBottomProgress(testimonialsSection, 0.96, 0.38);
	      updateBandSurface();
	    };

	    syncSurfaceProgressFromLayout();
	
	    scrollTriggers.push(ScrollTrigger.create({
	      trigger: band,
	      start: 'top bottom',
	      end: 'bottom top',
	      invalidateOnRefresh: true,
	      onUpdate: (self) => {
	        if (!prefersReducedMotion) setShaderVelocityBoost(self.getVelocity());
	        syncSurfaceProgressFromLayout();
	      },
	      onRefresh: () => {
	        syncSurfaceProgressFromLayout();
	      },
	    }));

    if (aboutSection) {
      scrollTriggers.push(ScrollTrigger.create({
        trigger: aboutSection,
        start: 'top 78%',
        end: 'bottom 22%',
        scrub: prefersReducedMotion ? false : true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          aboutHoldProgress = transitionPulse(self.progress);
          updateBandSurface();
        },
        onRefresh: (self) => {
          aboutHoldProgress = transitionPulse(self.progress);
          updateBandSurface();
        },
      }));
    }

    introSections.forEach((intro) => {
      introPulses.set(intro, 0);
      scrollTriggers.push(ScrollTrigger.create({
        trigger: intro,
        start: 'top bottom',
        end: 'bottom top',
        scrub: prefersReducedMotion ? false : true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          introPulses.set(intro, transitionPulse(self.progress));
          updateBandSurface();
        },
        onRefresh: (self) => {
          introPulses.set(intro, transitionPulse(self.progress));
          updateBandSurface();
        },
      }));
    });

	    if (waysRowsSection) {
	      scrollTriggers.push(ScrollTrigger.create({
	        trigger: waysRowsSection,
        start: 'top 78%',
        end: 'bottom 22%',
        scrub: prefersReducedMotion ? false : true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          waysHoldProgress = transitionPulse(self.progress);
          updateBandSurface();
        },
        onRefresh: (self) => {
          waysHoldProgress = transitionPulse(self.progress);
          updateBandSurface();
        },
      }));
    }

	    cleanupFn = () => {
      if (shaderVelocityFrame) window.cancelAnimationFrame(shaderVelocityFrame);
      scrollTriggers.forEach((trigger) => trigger.kill());
      gsap.killTweensOf(introTitleGlyphs);
      gsap.set(introTitleGlyphs, { clearProps: 'willChange,filter,opacity,transform' });
      splitInstances.forEach((split) => split.revert());
      shader?.destroy();
      ac.abort();
    };
  }

  initOfferProcessBand();
  document.addEventListener('astro:after-swap', initOfferProcessBand);
</script>
