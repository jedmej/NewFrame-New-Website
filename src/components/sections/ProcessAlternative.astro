---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const totalSteps = t.services.groups.length;
---

<section id="process-alternative" class="process-alt" aria-label={t.services.altAriaLabel}>
  <div class="process-alt__stage">
    <div class="process-alt__body">
      <div class="process-alt__titles" aria-hidden="true">
        {t.services.groups.map((group, index) => (
          <p class="process-alt__phase" data-phase={index}>
            {group.category}
          </p>
        ))}
      </div>

      <div class="process-alt__meta">
        {t.services.groups.map((group, index) => (
          <article class="process-alt__panel" data-panel={index}>
            <p class="process-alt__eyebrow text-mono-xs">
              {t.services.stepLabel} {String(index + 1).padStart(2, '0')}
            </p>
            <p class="process-alt__description">{group.description}</p>
          </article>
        ))}
      </div>

      <div class="process-alt__menu" aria-label={t.services.altMenuLabel}>
        {t.services.groups.map((group, groupIndex) => (
          <ul class="process-alt__items" data-items={groupIndex}>
            {group.items.map((item) => (
              <li>{item.title}</li>
            ))}
          </ul>
        ))}
      </div>
    </div>

    <div class="process-alt__mobile-list">
      {t.services.groups.map((group, index) => (
        <article class="process-alt__mobile-step">
          <p class="process-alt__eyebrow text-mono-xs">
            {t.services.stepLabel} {String(index + 1).padStart(2, '0')}
          </p>
          <h3>{group.category}</h3>
          <p>{group.description}</p>
          <ul>
            {group.items.map((item) => (
              <li>{item.title}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="process-alt__rail" aria-hidden="true">
      <span class="process-alt__rail-number" data-current-step>01</span>
      <span class="process-alt__rail-track">
        <span class="process-alt__rail-fill"></span>
      </span>
      <span class="process-alt__rail-number process-alt__rail-number--muted">
        {String(totalSteps).padStart(2, '0')}
      </span>
    </div>
  </div>
</section>

<style>
  .process-alt {
    --process-step: 0;
    --process-progress: 0%;
    --process-title-active-indent: 14.4px;

    position: relative;
    min-height: calc(100svh + 220vh);
    background: transparent;
    color: #f3efe5;
  }

  .process-alt__stage {
    position: sticky;
    top: 0;
    display: flex;
    min-height: 100svh;
    overflow: clip;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(3.5rem, 7vw, 4rem) clamp(1.5rem, 8.9vw, 8rem);
    isolation: isolate;
  }

  .process-alt__body {
    position: relative;
    z-index: 2;
    display: grid;
    width: 100%;
    max-width: 1184px;
    grid-template-columns: minmax(0, 1fr) minmax(17rem, 1fr) minmax(13rem, 1fr);
    gap: clamp(3rem, 7vw, 6.375rem);
    align-items: center;
  }

  .process-alt__titles {
    --process-phase-gap: clamp(11.5rem, 13vw, 15rem);

    position: relative;
    height: clamp(34rem, 42vw, 42rem);
    overflow: visible;
  }

  .process-alt__phase {
    --phase-distance: 0;
    --phase-abs: 0;
    --phase-title-x: 0px;

    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    margin: 0;
    color: rgba(243, 239, 229, calc(0.95 - (min(var(--phase-abs), 3) * 0.19)));
    filter: blur(calc(min(var(--phase-abs), 3) * 2.2px));
    font-family: var(--font-serif);
    font-size: clamp(3.05rem, 4.3vw, 3.875rem);
    line-height: 1.06;
    letter-spacing: 0;
    transform: translate3d(var(--phase-title-x), calc((var(--phase-distance) * var(--process-phase-gap)) - 50%), 0);
    transition:
      color 0.18s var(--ease-out-quart),
      filter 0.18s var(--ease-out-quart),
      transform 0.55s var(--ease-out-expo);
    cursor: pointer;
  }

  @media (hover: hover) {
    .process-alt__phase:hover {
      transform: translate3d(var(--process-title-active-indent), calc((var(--phase-distance) * var(--process-phase-gap)) - 50%), 0);
    }
  }

  .process-alt__phase:nth-child(1) {
    --index: 0;
  }

  .process-alt__phase:nth-child(2) {
    --index: 1;
  }

  .process-alt__phase:nth-child(3) {
    --index: 2;
  }

  .process-alt__phase:nth-child(4) {
    --index: 3;
  }

  .process-alt__meta {
    position: relative;
    min-height: 8.8rem;
  }

  .process-alt__panel {
    position: absolute;
    inset: 0;
    display: grid;
    align-content: center;
    gap: 0.75rem;
    opacity: 0;
    filter: blur(10px);
    transition:
      opacity 0.55s var(--ease-out-expo),
      filter 0.55s var(--ease-out-expo);
    pointer-events: none;
  }

  .process-alt__panel.is-active {
    opacity: 1;
    filter: blur(0);
  }

  .process-alt__eyebrow {
    color: rgba(243, 239, 229, 0.72);
  }

  .process-alt__description {
    max-width: 31rem;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.25vw, 1.125rem);
    line-height: 1.5;
    letter-spacing: 0;
    color: rgba(243, 239, 229, 0.72);
    text-wrap: pretty;
  }

  .process-alt__menu {
    position: relative;
    min-height: 9.25rem;
  }

  .process-alt__items {
    position: absolute;
    inset: 0;
    display: grid;
    align-content: center;
    justify-items: end;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
    opacity: 0;
    filter: blur(8px);
    transition:
      opacity 0.55s var(--ease-out-expo),
      filter 0.55s var(--ease-out-expo);
  }

  .process-alt__items.is-active {
    opacity: 1;
    filter: blur(0);
  }

  .process-alt__items li {
    width: fit-content;
    font-family: var(--font-sans);
    font-size: clamp(0.82rem, 1vw, 0.875rem);
    line-height: 2.05;
    letter-spacing: 0.02em;
    color: #f3efe5;
    text-align: right;
    text-transform: uppercase;
  }

  .process-alt__rail {
    position: absolute;
    bottom: clamp(5rem, 8.5vw, 6rem);
    left: 50%;
    z-index: 2;
    display: flex;
    width: min(100%, 22.25rem);
    height: 2.125rem;
    flex: 0 0 auto;
    align-items: center;
    gap: 1.125rem;
    translate: -50% 0;
  }

  .process-alt__mobile-list {
    display: none;
    position: relative;
    z-index: 2;
  }

  .process-alt__rail-number {
    width: 1.75rem;
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.35;
    letter-spacing: 0.08em;
  }

  .process-alt__rail-number--muted {
    color: rgba(243, 239, 229, 0.5);
    text-align: right;
  }

  .process-alt__rail-track {
    display: flex;
    height: 1px;
    flex: 1 1 auto;
    align-items: center;
    background: rgba(243, 239, 229, 0.22);
  }

  .process-alt__rail-fill {
    width: var(--process-progress);
    height: 1px;
    background: #f3efe5;
    transition: width 0.12s linear;
  }

  @media (max-width: 1023px) {
    .process-alt {
      min-height: auto;
    }

    .process-alt__stage {
      position: relative;
      min-height: auto;
      gap: 4.5rem;
      padding-block: clamp(5rem, 12vw, 7rem);
    }

    .process-alt__body {
      display: none;
    }

    .process-alt__mobile-list {
      display: grid;
      width: 100%;
      gap: 0;
    }

    .process-alt__mobile-step {
      display: grid;
      gap: 1.1rem;
      padding-block: 2rem;
      border-top: 1px solid rgba(243, 239, 229, 0.2);
    }

    .process-alt__mobile-step:last-child {
      border-bottom: 1px solid rgba(243, 239, 229, 0.18);
    }

    .process-alt__mobile-step h3 {
      font-family: var(--font-serif);
      font-size: clamp(2.4rem, 12vw, 4.5rem);
      font-weight: 400;
      line-height: 1.04;
      letter-spacing: 0;
      color: #f3efe5;
    }

    .process-alt__mobile-step p:not(.process-alt__eyebrow) {
      max-width: 36rem;
      font-family: var(--font-sans);
      font-size: 1rem;
      line-height: 1.55;
      color: rgba(243, 239, 229, 0.72);
    }

    .process-alt__mobile-step ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem 0.8rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .process-alt__mobile-step li {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      line-height: 1.35;
      letter-spacing: 0.08em;
      color: rgba(243, 239, 229, 0.84);
      text-transform: uppercase;
    }

    .process-alt__rail {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-alt__phase,
    .process-alt__panel,
    .process-alt__items,
    .process-alt__rail-fill {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  let cleanupFn: (() => void) | null = null;

  function initProcessAlternative() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('process-alternative');
    if (!section) return;

    const ac = new AbortController();
    const scrollTriggers: ScrollTrigger[] = [];
    const timelines: gsap.core.Timeline[] = [];
    const splitInstances: SplitText[] = [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const desktopQuery = window.matchMedia('(min-width: 1024px)');

    const phases = Array.from(section.querySelectorAll<HTMLElement>('.process-alt__phase'));
    const panels = Array.from(section.querySelectorAll<HTMLElement>('.process-alt__panel'));
    const itemLists = Array.from(section.querySelectorAll<HTMLElement>('.process-alt__items'));
    const rail = section.querySelector('.process-alt__rail');
    const currentStep = section.querySelector<HTMLElement>('[data-current-step]');
    const totalSteps = Math.max(1, panels.length);
    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
    const smoothstep = (value: number) => value * value * (3 - 2 * value);
    let scrollScene: ScrollTrigger | null = null;
    let activeStep = -1;
    let processSwitchTl: gsap.core.Timeline | null = null;
    const scrollToStep = (index: number) => {
      if (!scrollScene) return;
      const steps = Math.max(totalSteps - 1, 1);
      const progress = clamp(index / steps, 0, 1);
      const targetY = scrollScene.start + (scrollScene.end - scrollScene.start) * progress;
      const lenis = (window as any).lenis;
      if (lenis?.scrollTo) {
        lenis.scrollTo(targetY, { duration: 1.45 });
      } else {
        window.scrollTo({ top: targetY, behavior: 'smooth' });
      }
    };

    const splitContentToChars = (elements: Element[]) => {
      const chars: Element[] = [];
      const splits: SplitText[] = [];
      elements.forEach((element) => {
        const existingChars = Array.from(element.querySelectorAll('.process-alt__char'));
        if (existingChars.length) {
          chars.push(...existingChars);
          return;
        }

        const split = new SplitText(element, {
          type: 'chars',
          charsClass: 'process-alt__char',
        });
        splitInstances.push(split);
        splits.push(split);
        chars.push(...split.chars);
      });
      return { chars, splits };
    };

    const setProcessContent = (nextStep: number, animate = true) => {
      if (nextStep === activeStep) return;
      const previousStep = activeStep;
      const previousPanel = panels[previousStep];
      const previousItems = itemLists[previousStep];
      const nextPanel = panels[nextStep];
      const nextItems = itemLists[nextStep];
      if (!nextPanel || !nextItems) return;

      activeStep = nextStep;
      if (currentStep) currentStep.textContent = String(nextStep + 1).padStart(2, '0');

      processSwitchTl?.kill();
      panels.forEach((panel, index) => panel.classList.toggle('is-active', index === nextStep));
      itemLists.forEach((items, index) => items.classList.toggle('is-active', index === nextStep));

      if (prefersReducedMotion || !desktopQuery.matches || !animate || previousStep < 0) {
        splitInstances.splice(0).forEach((split) => split.revert());
        gsap.set([...panels, ...itemLists], { clearProps: 'all' });
        return;
      }

      const outgoing = [previousPanel, previousItems].filter(Boolean) as HTMLElement[];
      const incoming = [nextPanel, nextItems];
      const inactive = [...panels, ...itemLists].filter((el) => !outgoing.includes(el) && !incoming.includes(el));
      const previousPanelSplit = previousPanel
        ? splitContentToChars(Array.from(previousPanel.querySelectorAll('.process-alt__eyebrow, .process-alt__description')))
        : { chars: [], splits: [] };
      const previousItemSplit = previousItems
        ? splitContentToChars(Array.from(previousItems.querySelectorAll('li')))
        : { chars: [], splits: [] };
      const nextPanelSplit = splitContentToChars(Array.from(nextPanel.querySelectorAll('.process-alt__eyebrow, .process-alt__description')));
      const nextItemSplit = splitContentToChars(Array.from(nextItems.querySelectorAll('li')));
      const previousPanelChars = previousPanelSplit.chars;
      const previousItemChars = previousItemSplit.chars;
      const nextPanelChars = nextPanelSplit.chars;
      const nextItemChars = nextItemSplit.chars;
      const outgoingChars = [...previousPanelChars, ...previousItemChars];
      const incomingChars = [...nextPanelChars, ...nextItemChars];

      gsap.killTweensOf([...outgoing, ...incoming, ...inactive, ...outgoingChars, ...incomingChars]);
      gsap.set(inactive, { opacity: 0, filter: 'blur(14px)' });
      gsap.set(incoming, { opacity: 1, filter: 'blur(0px)' });
      gsap.set(incomingChars, { opacity: 0, filter: 'blur(16px)' });

      processSwitchTl = gsap.timeline({
        defaults: { overwrite: true },
        onComplete: () => {
          gsap.set([...outgoing, ...incoming, ...outgoingChars, ...incomingChars], { clearProps: 'opacity,filter' });
          const nextSplits = [...nextPanelSplit.splits, ...nextItemSplit.splits];
          const preservedSplits = new Set(nextSplits);
          const staleSplits = splitInstances.filter((split) => !preservedSplits.has(split));
          staleSplits.forEach((split) => split.revert());
          splitInstances.splice(0, splitInstances.length, ...nextSplits);
          processSwitchTl = null;
        },
      });

      processSwitchTl
        .to(previousPanelChars, {
          opacity: 0,
          filter: 'blur(16px)',
          duration: 0.22,
          stagger: {
            each: 0.0028,
            from: 'end',
          },
          ease: 'power2.in',
        }, 0)
        .to(previousItemChars, {
          opacity: 0,
          filter: 'blur(14px)',
          duration: 0.2,
          stagger: {
            each: 0.0024,
            from: 'end',
          },
          ease: 'power2.in',
        }, 0.06)
        .to(nextPanelChars, {
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.78,
          stagger: 0.0034,
          ease: 'power4.out',
        }, 0.16)
        .to(nextItemChars, {
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.74,
          stagger: 0.0032,
          ease: 'power4.out',
        }, 0.32);
    };

    const setProcessState = (step: number, progress: number, animateContent = true) => {
      const clampedStep = Math.max(0, Math.min(totalSteps - 1, step));
      const nextStep = Math.round(clampedStep);

      section.style.setProperty('--process-step', String(clampedStep));
      section.style.setProperty('--process-progress', `${Math.max(0, Math.min(100, progress))}%`);

      phases.forEach((phase, index) => {
        const distance = index - clampedStep;
        const focus = smoothstep(clamp(1 - Math.abs(distance), 0, 1));
        phase.style.setProperty('--phase-distance', String(distance));
        phase.style.setProperty('--phase-abs', String(Math.min(3, Math.abs(distance))));
        phase.style.setProperty('--phase-title-x', `calc(var(--process-title-active-indent) * ${focus.toFixed(3)})`);
      });
      setProcessContent(nextStep, animateContent);
    };

    setProcessState(0, 0, false);

    if (prefersReducedMotion || !desktopQuery.matches) {
      gsap.set([rail, ...phases, ...panels, ...itemLists].filter(Boolean), { clearProps: 'all' });
      cleanupFn = () => {
        ac.abort();
      };
      return;
    }

    phases.forEach((phase, index) => {
      phase.addEventListener('click', () => scrollToStep(index), { signal: ac.signal });
    });

    gsap.set([rail].filter(Boolean), {
      y: 18,
      opacity: 0,
      filter: 'blur(8px)',
    });

    const introTl = gsap.timeline({
      defaults: { ease: 'expo.out' },
      scrollTrigger: {
        trigger: section,
        start: 'top 72%',
        once: true,
      },
    });
    timelines.push(introTl);
    if (introTl.scrollTrigger) scrollTriggers.push(introTl.scrollTrigger);

    introTl
      .to(rail, { y: 0, opacity: 1, filter: 'blur(0px)', duration: 0.8 }, 0.12);

    scrollScene = ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom bottom',
      scrub: true,
      onUpdate: (self) => {
        const scrollRange = Math.max(totalSteps - 1, 1);
        setProcessState(self.progress * scrollRange, self.progress * 100);
      },
    });
    scrollTriggers.push(scrollScene);

    cleanupFn = () => {
      ac.abort();
      processSwitchTl?.kill();
      timelines.forEach((tl) => tl.kill());
      scrollTriggers.forEach((trigger) => trigger.kill());
      gsap.killTweensOf(section.querySelectorAll('*'));
      splitInstances.forEach((split) => split.revert());
    };
  }

  initProcessAlternative();
  document.addEventListener('astro:after-swap', initProcessAlternative);
</script>
