---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const offers = t.waysToWork.items;
---

<section id="ways-to-work-grid" class="ways-grid" aria-labelledby="ways-grid-title" data-offer-count={offers.length}>
  <div class="ways-grid__shell">
    <span id="ways-grid-title" class="ways-grid__sr-title">{t.waysToWork.heading}</span>

    <div class="ways-grid__main">
      <div class="ways-grid__categories" role="tablist" aria-label={t.waysToWork.heading}>
        {offers.map((offer, index) => (
          <button
            id={`ways-grid-tab-${index}`}
            class:list={['ways-grid__category', { 'is-active': index === 0 }]}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-controls={`ways-grid-panel-${index}`}
            data-offer-tab
            data-offer-index={index}
            style={`--offer-distance: ${index}; --offer-abs: ${index};`}
          >
            <span class="ways-grid__category-icon" aria-hidden="true">
              <canvas data-offer-icon data-offer-icon-index={index}></canvas>
            </span>
            <span class="ways-grid__category-title">{offer.title}</span>
            <span class="ways-grid__category-copy">{offer.description}</span>
          </button>
        ))}
      </div>

      <div class="ways-grid__details">
        {offers.map((offer, index) => (
          <article
            id={`ways-grid-panel-${index}`}
            class:list={['ways-grid__panel', { 'is-active': index === 0 }]}
            role="tabpanel"
            aria-labelledby={`ways-grid-tab-${index}`}
            data-offer-panel
            data-offer-index={index}
            hidden={index !== 0}
          >
            {offer.includes.map((entry) => (
              <div class="ways-grid__row">
                <span>{entry}</span>
              </div>
            ))}
          </article>
        ))}
      </div>
    </div>
  </div>

</section>

<style>
  .ways-grid {
    --offer-title-active-indent: 14.4px;

    position: relative;
    display: block;
    min-height: calc(100svh + 152vh);
    overflow: visible;
    background: transparent;
    color: var(--color-dark-text);
    isolation: isolate;
  }

  .ways-grid__shell {
    position: sticky;
    top: 0;
    display: flex;
    width: 100%;
    height: 100svh;
    max-height: 100svh;
    flex-direction: column;
    justify-content: center;
    margin-inline: auto;
    padding:
      clamp(3.5rem, 7vw, 4rem)
      clamp(1.5rem, 6.6vw, 8rem);
  }

  .ways-grid__sr-title {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .ways-grid__main {
    display: flex;
    gap: clamp(3rem, 5vw, 5.5rem);
    width: 100%;
    max-width: 78rem;
    min-height: 0;
    flex: 1 1 auto;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
  }

  .ways-grid__categories {
    --offer-title-gap: clamp(13.75rem, 15.5vw, 18rem);

    position: relative;
    display: flex;
    width: min(32vw, 30rem);
    height: clamp(40rem, 49vw, 50rem);
    flex: 0 0 auto;
    flex-direction: column;
    overflow: visible;
  }

  .ways-grid__category {
    --offer-distance: 0;
    --offer-abs: 0;
    --offer-title-x: 0px;

    position: absolute;
    top: 50%;
    left: 0;
    display: flex;
    gap: clamp(1rem, 1.7vw, 1.5rem);
    align-items: center;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: rgba(243, 239, 229, calc(0.95 - (min(var(--offer-abs), 3) * 0.19)));
    text-align: left;
    cursor: pointer;
    filter: blur(calc(min(var(--offer-abs), 3) * 2.2px));
    transform: translate3d(0, calc((var(--offer-distance) * var(--offer-title-gap)) - 50%), 0);
    transition:
      color 0.18s var(--ease-out-quart),
      filter 0.18s var(--ease-out-quart);
    appearance: none;
  }

  .ways-grid__category-icon {
    position: relative;
    display: block;
    width: clamp(3.25rem, 4.6vw, 4.75rem);
    height: clamp(3.25rem, 4.6vw, 4.75rem);
    flex: 0 0 auto;
    overflow: hidden;
    border-radius: 50%;
    background: transparent;
    transform: translate3d(0, 0.08em, 0) scale(0.88);
    transition:
      transform 0.55s var(--ease-out-expo);
  }

  .ways-grid__category-icon canvas {
    display: block;
    width: 100%;
    height: 100%;
    background: transparent;
  }

  .ways-grid__category.is-active .ways-grid__category-icon,
  .ways-grid__category:hover .ways-grid__category-icon {
    transform: translate3d(0, 0.08em, 0) scale(1);
  }

  .ways-grid__category:focus-visible {
    outline: 1px solid rgba(255, 255, 255, 0.74);
    outline-offset: 0.45rem;
  }

  .ways-grid__category-title {
    display: block;
    max-width: 100%;
    font-family: var(--font-serif);
    font-size: clamp(3.05rem, 4.3vw, 3.875rem);
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: 0;
    text-wrap: balance;
    transition:
      transform 0.55s var(--ease-out-expo);
  }

  .ways-grid__category-copy {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .ways-grid__category:not(.is-active) .ways-grid__category-title {
    transform: translate3d(var(--offer-title-x), 0, 0);
  }

  .ways-grid__category:nth-child(3):not(.is-active) .ways-grid__category-title {
    transform: translate3d(var(--offer-title-x), 0, 0);
  }

  .ways-grid__category .ways-grid__category-title {
    transform: translate3d(var(--offer-title-x), 0, 0);
  }

  .ways-grid__details {
    position: relative;
    display: flex;
    height: clamp(40rem, 49vw, 50rem);
    min-width: 0;
    flex: 0 0 clamp(21.7rem, 25.25vw, 28rem);
    flex-direction: column;
  }

  .ways-grid__panel {
    position: absolute;
    inset: 0;
    display: flex;
    min-height: 100%;
    flex: 1;
    flex-direction: column;
    pointer-events: none;
    will-change: opacity, filter, transform;
  }

  .ways-grid__panel[hidden] {
    display: none;
  }

  .ways-grid__row {
    display: flex;
    min-height: 0;
    flex: 1;
    align-items: center;
    padding: 0 clamp(1.5rem, 2.65vw, 2.375rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.13);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.67vw, 1.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.055em;
    color: currentColor;
    text-wrap: balance;
  }

  .ways-grid__row:first-child {
    color: currentColor;
  }

  .ways-grid__row:last-child {
    border-bottom: 0;
  }

  @media (hover: hover) {
    .ways-grid__category:hover .ways-grid__category-title {
      transform: translate3d(var(--offer-title-active-indent), 0, 0);
    }
  }

  @media (max-width: 1023px) {
    .ways-grid {
      height: auto;
      min-height: auto;
      padding: clamp(5rem, 18vw, 8rem) 1.5rem;
    }

    .ways-grid__shell {
      position: relative;
      width: 100%;
      height: auto;
      min-height: auto;
      max-height: none;
      padding-block: 0;
    }

    .ways-grid__main {
      flex-direction: column;
      gap: 2rem;
      min-height: 0;
    }

    .ways-grid__categories {
      width: 100%;
      height: auto;
      gap: 0;
      justify-content: flex-start;
      padding: 0;
    }

    .ways-grid__category {
      position: relative;
      top: auto;
      left: auto;
      min-height: clamp(4.4rem, 11vw, 5.75rem);
      align-items: flex-start;
      gap: 0.95rem;
      padding: 0.6rem 0;
      color: currentColor;
      opacity: 1;
      filter: none;
      transform: none;
    }

    .ways-grid__category:last-child {
      border-bottom: 0;
    }

    .ways-grid__category-title {
      max-width: 100%;
      font-size: clamp(2.65rem, 10vw, 4.2rem);
      line-height: 0.96;
    }

    .ways-grid__category-icon {
      width: clamp(2.85rem, 9vw, 4rem);
      height: clamp(2.85rem, 9vw, 4rem);
      transform: translate3d(0, 0.04em, 0) scale(0.92);
    }

    .ways-grid__category.is-active .ways-grid__category-icon,
    .ways-grid__category:hover .ways-grid__category-icon {
      transform: translate3d(0, 0.04em, 0) scale(1);
    }

    .ways-grid__category:not(.is-active) .ways-grid__category-title,
    .ways-grid__category:nth-child(3):not(.is-active) .ways-grid__category-title {
      opacity: 0.42;
      filter: blur(2px);
    }

    .ways-grid__row {
      min-height: clamp(4.75rem, 12vw, 6rem);
      padding-inline: 0;
      font-size: clamp(1.08rem, 4.4vw, 1.5rem);
      line-height: 1.05;
    }

    .ways-grid__details {
      height: clamp(28.5rem, 72vw, 36rem);
    }
  }

  @media (max-width: 640px) {
    .ways-grid {
      padding-inline: 1.25rem;
    }

    .ways-grid__main {
      gap: 1.25rem;
    }

    .ways-grid__category-title {
      font-size: clamp(2.2rem, 12vw, 3rem);
    }

    .ways-grid__row {
      align-items: center;
      padding-block: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ways-grid__category-title,
    .ways-grid__category-icon {
      transition: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  import { createShader } from 'shaders/js';
  import type { ShaderInstance } from 'shaders/js';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  let cleanupFn: (() => void) | null = null;

  function initWaysGrid() {
    cleanupFn?.();
    cleanupFn = null;

    const section = document.getElementById('ways-to-work-grid');
    if (!section) return;

    const ac = new AbortController();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const scrollTriggers: ScrollTrigger[] = [];
    const tabs = Array.from(section.querySelectorAll<HTMLButtonElement>('[data-offer-tab]'));
    const panels = Array.from(section.querySelectorAll<HTMLElement>('[data-offer-panel]'));
    const iconCanvases = Array.from(section.querySelectorAll<HTMLCanvasElement>('[data-offer-icon]'));
    const splitInstances: SplitText[] = [];
    const shaderInstances: ShaderInstance[] = [];
    let isCleanedUp = false;
    let activeIndex = 0;
    let scrollScene: ScrollTrigger | null = null;
    let panelSwitchTl: gsap.core.Timeline | null = null;
    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
    const smoothstep = (value: number) => value * value * (3 - 2 * value);
    const finalScrollTail = 0.35;
    const scrollToOffer = (index: number) => {
      if (!scrollScene) return;
      const steps = Math.max(tabs.length - 1, 1);
      const targetProgress = clamp(index / (steps + finalScrollTail), 0, 1);
      const targetY = scrollScene.start + (scrollScene.end - scrollScene.start) * targetProgress;
      const lenis = (window as any).lenis;
      if (lenis?.scrollTo) {
        lenis.scrollTo(targetY, { duration: 1.45 });
      } else {
        window.scrollTo({ top: targetY, behavior: 'smooth' });
      }
    };

    const splitRowsToChars = (rows: Element[]) => {
      const chars: Element[] = [];
      const splits: SplitText[] = [];
      rows.forEach((row) => {
        const existingChars = Array.from(row.querySelectorAll('.ways-grid__char'));
        if (existingChars.length) {
          chars.push(...existingChars);
          return;
        }

        const split = new SplitText(row, {
          type: 'chars',
          charsClass: 'ways-grid__char',
        });
        splitInstances.push(split);
        splits.push(split);
        chars.push(...split.chars);
      });
      return { chars, splits };
    };

    function setActiveOffer(nextIndex: number, animateRows = true) {
      if (!tabs[nextIndex] || activeIndex === nextIndex) return;
      const previousIndex = activeIndex;
      activeIndex = nextIndex;

      tabs.forEach((tab, index) => {
        const isActive = index === nextIndex;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      const previousPanel = panels[previousIndex];
      const nextPanel = panels[nextIndex];
      if (!nextPanel) return;

      panelSwitchTl?.kill();
      panels.forEach((panel, index) => {
        panel.classList.toggle('is-active', index === nextIndex);
        panel.hidden = false;
      });

      if (prefersReducedMotion || !animateRows) {
        splitInstances.splice(0).forEach((split) => split.revert());
        panels.forEach((panel, index) => {
          panel.hidden = index !== nextIndex;
          gsap.set(panel.querySelectorAll('.ways-grid__row'), { clearProps: 'all' });
        });
        return;
      }

      const previousRows = previousPanel ? Array.from(previousPanel.querySelectorAll('.ways-grid__row')) : [];
      const nextRows = Array.from(nextPanel.querySelectorAll('.ways-grid__row'));
      const outgoing = [previousPanel].filter(Boolean) as HTMLElement[];
      const incoming = [nextPanel];
      const inactive = panels.filter((panel) => !outgoing.includes(panel) && !incoming.includes(panel));
      const previousSplit = splitRowsToChars(previousRows);
      const nextSplit = splitRowsToChars(nextRows);
      const previousChars = previousSplit.chars;
      const nextChars = nextSplit.chars;

      gsap.killTweensOf([...outgoing, ...incoming, ...inactive, ...previousChars, ...nextChars]);
      gsap.set(inactive, { opacity: 0, filter: 'blur(14px)' });
      inactive.forEach((panel) => {
        panel.hidden = true;
      });
      gsap.set(incoming, { opacity: 1, filter: 'blur(0px)' });
      gsap.set(nextRows, { opacity: 1, filter: 'blur(0px)' });
      gsap.set(nextChars, { opacity: 0, filter: 'blur(16px)' });

      panelSwitchTl = gsap.timeline({
        defaults: { overwrite: true },
        onComplete: () => {
          panels.forEach((panel, index) => {
            panel.hidden = index !== nextIndex;
          });
          gsap.set([...outgoing, ...incoming, ...previousChars, ...nextChars, ...previousRows, ...nextRows], { clearProps: 'opacity,filter' });
          const preservedSplits = new Set(nextSplit.splits);
          const staleSplits = splitInstances.filter((split) => !preservedSplits.has(split));
          staleSplits.forEach((split) => split.revert());
          splitInstances.splice(0, splitInstances.length, ...nextSplit.splits);
          panelSwitchTl = null;
        },
      });

      if (previousChars.length) {
        panelSwitchTl.to(previousChars, {
          opacity: 0,
          filter: 'blur(14px)',
          duration: 0.32,
          stagger: {
            each: 0.004,
            from: 'end',
          },
          ease: 'power2.in',
        }, 0);
      }

      panelSwitchTl.to(nextChars, {
        opacity: 1,
        filter: 'blur(0px)',
        duration: 1.08,
        stagger: {
          each: 0.0052,
          from: 'start',
        },
        ease: 'power4.out',
      }, previousChars.length ? 0.22 : 0);
    }

    function setOfferProgress(progressIndex: number, animateRows = true) {
      const lastIndex = Math.max(tabs.length - 1, 0);
      const clampedProgress = clamp(progressIndex, 0, lastIndex + finalScrollTail);
      const nextIndex = clamp(Math.round(clampedProgress), 0, lastIndex);

      tabs.forEach((tab, index) => {
        const distance = index - clampedProgress;
        const focus = smoothstep(clamp(1 - Math.abs(distance), 0, 1));
        tab.style.setProperty('--offer-distance', String(distance));
        tab.style.setProperty('--offer-abs', String(Math.min(3, Math.abs(distance))));
        tab.style.setProperty('--offer-title-x', `calc(var(--offer-title-active-indent) * ${focus.toFixed(3)})`);
      });

      setActiveOffer(nextIndex, animateRows);
    }

    tabs.forEach((tab) => {
      tab.addEventListener(
        'click',
        () => {
          const nextIndex = Number(tab.dataset.offerIndex ?? 0);
          scrollToOffer(nextIndex);
        },
        { signal: ac.signal }
      );
    });

    async function initCategoryIcons() {
      if (!iconCanvases.length || prefersReducedMotion) return;

      await Promise.all(iconCanvases.map(async (canvas) => {
        if (isCleanedUp) return;

        try {
          const shader = await createShader(canvas, {
            components: [
              {
                type: 'SolidColor',
                id: 'idmop8t2dvsdkdqrtcr',
                props: {
                  color: '#0a0a0a',
                  visible: false,
                },
              },
              {
                type: 'Glass',
                id: 'idmop8t2dv4iyazjw21',
                props: {
                  aberration: 0.89,
                  cutout: true,
                  edgeSoftness: 0.2,
                  fresnel: 0.01,
                  fresnelSoftness: 0.14,
                  refraction: 1.09,
                  scale: 0.7,
                  shapeSdfUrl: 'https://data.shaders.com/storage/v1/object/public/user-uploaded-images/user_3DLKqHT8k7i5jfwRZGrJetvEjim/Hue-d8OrtjVS_sdf.bin',
                  thickness: 0.27,
                },
                children: [
                  {
                    type: 'Swirl',
                    id: 'idmop8t2dvin3ihed08',
                    props: {
                      blend: 56,
                      colorA: '#ffffff',
                      colorB: '#0a0a0a',
                      colorSpace: 'oklab',
                      detail: 4.2,
                      speed: 0.1,
                      visible: true,
                    },
                  },
                  {
                    type: 'FlowField',
                    id: 'idmop8t2dv05jgxsb3c',
                    props: {
                      detail: 1,
                      evolutionSpeed: 1.5,
                      speed: 1.8,
                      strength: 0.5,
                    },
                  },
                ],
              },
            ],
          }, {
            disableTelemetry: true,
          });

          if (isCleanedUp) {
            shader.destroy();
            return;
          }

          shaderInstances.push(shader);
        } catch (error) {
          console.warn('[ways-grid] Failed to initialize category shader icon', error);
        }
      }));
    }

    void initCategoryIcons();

    setOfferProgress(0, false);

    if (!prefersReducedMotion) {
      scrollScene = ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          const steps = Math.max(tabs.length - 1, 1);
          setOfferProgress(self.progress * (steps + finalScrollTail));
        },
      });
      scrollTriggers.push(scrollScene);
      setOfferProgress(scrollScene.progress * (Math.max(tabs.length - 1, 1) + finalScrollTail), false);
    }

    cleanupFn = () => {
      isCleanedUp = true;
      panelSwitchTl?.kill();
      scrollTriggers.forEach((trigger) => trigger.kill());
      shaderInstances.forEach((shader) => shader.destroy());
      gsap.killTweensOf(section.querySelectorAll('*'));
      splitInstances.forEach((split) => split.revert());
      ac.abort();
    };
  }

  initWaysGrid();
  document.addEventListener('astro:after-swap', initWaysGrid);
</script>
