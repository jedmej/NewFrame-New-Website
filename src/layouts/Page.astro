---
import Base from './Base.astro';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import Preloader from '../components/global/Preloader.astro';
import CustomCursor from '../components/global/CustomCursor.astro';
import PageShaderBackground from '../components/global/PageShaderBackground.astro';
import ViewportProgressiveBlur from '../components/global/ViewportProgressiveBlur.astro';
import type { Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  lang: Lang;
  showScrollShader?: boolean;
  showFooter?: boolean;
}

const { title, description, lang, showScrollShader = false, showFooter = true } = Astro.props;
const t = useTranslations(lang);
const RetuneOverlay = import.meta.env.DEV ? (await import('../components/global/RetuneOverlay.astro')).default : null;
---

<Base title={title} description={description} lang={lang}>
  <a href="#main-content" class="skip-to-content">{t.skipToContent}</a>
  <Preloader />
  <CustomCursor />
  <Nav lang={lang} />
  {showScrollShader && <PageShaderBackground />}

  <main id="main-content" class:list={{ 'page-content--scroll-shader': showScrollShader }}>
    <slot />
  </main>

  {showFooter && <Footer lang={lang} />}
  <ViewportProgressiveBlur />
  {RetuneOverlay && <RetuneOverlay />}

  <!-- Initialize Lenis smooth scroll -->
  <script>
    import Lenis from 'lenis';
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    let tickerCallback: ((time: number) => void) | null = null;

    function initSmoothScroll() {
      // Destroy previous instance to prevent memory leak
      if ((window as any).lenis) {
        (window as any).lenis.destroy();
        (window as any).lenis = null;
      }

      // Remove previous ticker callback
      if (tickerCallback) {
        gsap.ticker.remove(tickerCallback);
        tickerCallback = null;
      }

      if (window.innerWidth < 1024) return;

      const lenis = new Lenis({
        autoRaf: false,
        smoothWheel: true,
        lerp: 0.17,
        wheelMultiplier: 1.05,
      });

      // Bridge Lenis to GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);

      tickerCallback = (time: number) => {
        lenis.raf(time * 1000);
      };
      gsap.ticker.add(tickerCallback);

      gsap.ticker.lagSmoothing(0);

      // Store globally for nav scroll
      (window as any).lenis = lenis;
    }

    initSmoothScroll();
    document.addEventListener('astro:after-swap', initSmoothScroll);
  </script>
</Base>
